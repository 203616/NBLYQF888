<view class="finance-card" bind:tap="handleCardTap">
  <!-- 图标区域 -->
  <view class="card-header">
    <image class="card-icon" src="{{product.icon}}" mode="aspectFit" />
    <view animation="{{animationData}}">
      <view 
        class="fav-icon {{isFav ? 'fav-active' : ''}}" 
        catch:tap="toggleFav"
      >
        <text class="iconfont icon-heart"></text>
      </view>
    </view>
  </view>
  
  <!-- 标题和描述 -->
  <view class="card-content">
    <text class="title">{{product.title}}</text>
    <text class="desc">{{product.desc}}</text>
  </view>
  
  <!-- 标签区域 -->
  <view class="tag-area" wx:if="{{product.tags && product.tags.length}}">
    <block wx:for="{{product.tags}}" wx:key="index">
      <tag-item text="{{item}}" />
    </block>
  </view>
  
  <!-- 操作按钮 -->
  <view class="card-footer" wx:if="{{showAction}}">
    <view class="action-btn">查看详情</view>
  </view>
</view>
