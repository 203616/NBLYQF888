/* йЌ—пј„еў–зЂ№з‘°ж«’ */
.finance-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 25rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  margin-bottom: 25rpx;
}

/* йЌ—пј„еў–жѕ¶ж’®е„ґ */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  font-size: 60rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.fav-icon {
  font-size: 40rpx;
  color: #ccc;
}

.fav-active {
  color: #ff4d4f;
}

/* йЌ—пј„еў–йЌђе‘­о†ђ */
.card-content {
  margin-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: block;
}

/* йЏЌе›©о„·йЌ–е“„з…™ */
.tag-area {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

/* йЋїе¶„з¶”йЋёе¤ђжЊі */
.card-footer {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.tag-text {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  line-height: 1.4;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
}