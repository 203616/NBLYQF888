.section-card {
  background: white;
  border-radius: 16rpx;
  margin: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
}

.icon-more {
  color: #999;
  font-size: 36rpx;
}

.content {
  padding: 30rpx;
}