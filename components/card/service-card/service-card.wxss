.service-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.service-card .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #0F3D2E;
  border-left: 6rpx solid #0F3D2E;
  padding-left: 20rpx;
  margin-bottom: 25rpx;
}

.service-card .items {
  padding-left: 10rpx;
}

.service-card .item {
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.service-card .item:last-child {
  border-bottom: none;
}

.service-card .icon {
  color: #07c160;
  margin-right: 15rpx;
  font-size: 30rpx;
}