<view class="demand-card">
  <view class="header">
    <text class="type">{{data.type=='funding'?'融资需求':'资金提供'}}</text>
    <text class="title">{{data.title}}</text>
  </view>
  <view class="detail">
    <view class="item">
      <text>金额</text>
      <text class="value">{{data.amount}}</text>
    </view>
    <view class="item">
      <text>期限</text>
      <text class="value">{{data.period}}</text>
    </view>
    <view class="item">
      <text>联系方式</text>
      <text class="value">{{data.contact}}</text>
    </view>
  </view>
</view>