.news-card {
  background: var(--color-bg-card, #fff);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
}

.news-card .cover-wrap {
  width: 100%;
  height: 0;
  padding-bottom: 45%;
  overflow: hidden;
  position: relative;
}

.news-card .cover-slot-img {
  width: 100%;
  height: 100%;
  position: absolute;
  inset: 0;
  display: block;
}

.news-card .body {
  padding: 20rpx 24rpx 24rpx;
}

.news-card .category {
  display: inline-block;
  font-size: 20rpx;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-bottom: 10rpx;
}

.news-card .title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.news-card .meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--color-text-muted);
}
