# =============================================================================
# 亮叶企服 · 生产环境密钥模板
# =============================================================================
# 用法：
#   1. 复制为 .env：  cp .env.production.example .env
#   2. 填写下方「必填」项（勿提交 .env 到 Git）
#   3. 校验：         pnpm verify:env
#   4. 同步小程序：   pnpm sync:prod
#   5. 集成探测：     pnpm verify:integrations --ping  （需先 pnpm dev:server）
#
# 详细说明见 deploy/production-secrets.md
# GitHub Actions Secrets 见 .github/SECRETS.md
# =============================================================================

# --- 服务基础（必填）---
PORT=3000
NODE_ENV=production
JWT_SECRET=请替换为至少32位随机字符串
DB_PATH=apps/server/data/liangye.db
UPLOADS_DIR=apps/server/uploads
PUBLIC_BASE_URL=https://api.liangyeqf.com

# --- 管理后台（必填，与 deploy/deploy.config.json 一致）---
ADMIN_URL=https://admin.liangyeqf.com
ADMIN_PORT=5188
ADMIN_BASE_PATH=/ly-admin

# --- 微信小程序（必填）---
WECHAT_APPID=wxf49b1aeb1d62f227
WECHAT_SECRET=

# 订阅消息模板 ID（微信公众平台 → 功能 → 订阅消息）
WECHAT_TEMPLATE_INTAKE_AUDIT=
WECHAT_TEMPLATE_INTAKE_DISBURSE=
WECHAT_TEMPLATE_FINANCE_REVIEW=

# --- 阿里云 OCR（必填，否则进件 OCR 走 Mock）---
OCR_PROVIDER=aliyun
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com

# --- 阿里云内容安全 Green（融圈审核，建议生产开启）---
ALIYUN_GREEN_ENABLED=true
ALIYUN_GREEN_REGION=cn-shanghai
ALIYUN_GREEN_ENDPOINT=green.cn-shanghai.aliyuncs.com

# --- CDN / OSS（可选；useCdnImages=true 时必填）---
USE_CDN_IMAGES=false
CDN_BASE_URL=https://cdn.liangyeqf.com
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=liangye-cdn
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PREFIX=static
OSS_UPLOAD_PREFIX=uploads
OSS_CDN_BASE=https://cdn.liangyeqf.com

# --- 小程序代码上传（本地 pnpm upload:mp 或 GitHub Actions 发布）---
# 密钥路径：微信公众平台 → 开发管理 → 开发设置 → 小程序代码上传
WECHAT_UPLOAD_PRIVATE_KEY_PATH=deploy/private.key
# WECHAT_UPLOAD_PRIVATE_KEY=   # 单行 PEM，用于 CI（勿写入本地 .env 文件后提交）
MINIPROGRAM_VERSION=1.0.0
MINIPROGRAM_DESC=体验版
MINIPROGRAM_ROBOT=1

# --- DeepSeek 智能客服（可选）---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
