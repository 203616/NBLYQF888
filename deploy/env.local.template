# 复制为项目根目录 .env 后填入真实密钥
# 完整说明见 deploy/env-setup-guide.md

PORT=3000
NODE_ENV=development

# 【必填】JWT 签名密钥，请生成 32 位以上随机字符串
JWT_SECRET=

DB_PATH=apps/server/data/liangye.db
UPLOADS_DIR=apps/server/uploads

PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api/v1

# CDN（可选）本地联调：pnpm prepare:cdn 后可用 http://localhost:3000/mp-assets/...
# CDN_BASE_URL=http://localhost:3000/mp-assets
# 生产：与 deploy.config.json cdnBaseUrl 一致；useCdnImages 默认 false 不影响编译
ADMIN_URL=http://localhost:5188/ly-admin
ADMIN_PORT=5188
ADMIN_BASE_PATH=/ly-admin

# OCR：留空或设为 mock 使用模拟识别；设为 aliyun 并填写密钥启用真实 OCR
OCR_PROVIDER=aliyun
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com

# 微信小程序（订阅消息、微信登录需要 WECHAT_SECRET）
WECHAT_APPID=wxf49b1aeb1d62f227
WECHAT_SECRET=

# 订阅消息模板 ID（公众平台 → 功能 → 订阅消息）
WECHAT_TEMPLATE_INTAKE_AUDIT=
WECHAT_TEMPLATE_INTAKE_DISBURSE=
