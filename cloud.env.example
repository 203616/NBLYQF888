# ============================================
# 亮叶企服 - 微信云托管 (CloudRun) 环境变量
# 在云托管控制台 > 服务配置 > 环境变量 中设置
# 服务名称: express-gfke
# 环境 ID: prod-2g0e58nv8af29b4b
# ============================================

# ---- 基础配置 ----
NODE_ENV=production
PORT=80
JWT_SECRET=your-jwt-secret-here
ADMIN_BASE_PATH=/ly-admin
PUBLIC_BASE_URL=https://prod-2g0e58nv8af29b4b.service.tcloudbase.com/express-gfke

# ---- 数据库（SQLite 持久化需挂载卷，或改用云 MySQL）----
# SQLite 默认存储在 apps/server/data/liangye.db
# 如需持久化，请在云托管控制台配置数据卷挂载，例如：
#   容器路径: /app/apps/server/data
#   云存储路径: 自动创建的 PV（推荐 1Gi）
DB_PATH=apps/server/data/liangye.db
UPLOADS_DIR=apps/server/uploads

# ---- 微信小程序 ----
WECHAT_APPID=wxf49b1aeb1d62f227
# ⚠️ 以下为敏感信息，请从微信公众平台获取：
# WECHAT_SECRET=你的小程序AppSecret

# ---- AI 大模型 ----
# ⚠️ 请替换为你的实际 API Key
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
# QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-plus
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_API_BASE=https://dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_MODEL=claude-3-haiku
AI_DEFAULT_PROVIDER=deepseek

# ---- 电子签章（阿里云市场）----
# ⚠️ 请替换为你的实际密钥
# ESIG_APP_KEY=你的AppKey
# ESIG_APP_SECRET=你的AppSecret
# ESIG_APP_CODE=你的AppCode
ESIG_API_URL=https://qbq2024.market.alicloudapi.com/api/task/taskDetail

# ---- 向量数据库（Zilliz Cloud）----
# ⚠️ 请替换为你的实际 Token
ZILLIZ_CLUSTER_ID=in03-6dbe74324a11c90
ZILLIZ_REGION=ali-cn-hangzhou
ZILLIZ_ENDPOINT=https://in03-6dbe74324a11c90.serverless.ali-cn-hangzhou.cloud.zilliz.com.cn
# ZILLIZ_TOKEN=your-zilliz-token

# ---- 阿里云 OCR ----
OCR_PROVIDER=aliyun
# ALIYUN_ACCESS_KEY_ID=你的阿里云AccessKey
# ALIYUN_ACCESS_KEY_SECRET=你的阿里云AccessSecret
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com

# ---- 订阅消息模板（微信公众平台获取）----
# WECHAT_TEMPLATE_INTAKE_AUDIT=
# WECHAT_TEMPLATE_INTAKE_DISBURSE=
# WECHAT_TEMPLATE_FINANCE_REVIEW=
