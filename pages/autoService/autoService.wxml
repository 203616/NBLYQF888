<view class="auto-service page-shell">
  <view class="as-hero premium-hero">
    <safe-image className="premium-hero-bg" src="/images/banner2.webp" mode="aspectFill" />
    <view class="premium-hero-body">
      <text class="premium-badge">汽车企服</text>
      <text class="premium-hero-title">一站式汽车金融服务</text>
      <text class="premium-hero-sub">新车按揭 · 二手车 · 车抵贷 · 延保 · 线索跟进</text>
    </view>
  </view>

  <view class="location-bar glass-card" bindtap="handleChooseCity">
    <text class="iconfont icon-location loc-icon"></text>
    <text>{{location.city || '定位中'}} · 本地汽车企服</text>
    <text class="loc-arrow">›</text>
  </view>

  <view class="stat-row">
    <view class="stat-item glass-card" wx:for="{{stats}}" wx:key="label">
      <text class="stat-num">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <view class="section glass-card">
    <text class="section-title">汽车融资</text>
    <view class="product-grid">
      <block wx:for="{{products}}" wx:key="id">
        <view class="product-card" data-id="{{item.id}}" bindtap="handleProductTap">
          <text class="iconfont icon">{{item.icon}}</text>
          <text class="p-title">{{item.title}}</text>
          <text class="p-desc">{{item.desc}}</text>
        </view>
      </block>
    </view>
    <view class="more-row" bindtap="navigateToList">
      <text>查看全部汽车金融产品</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="section glass-card">
    <text class="section-title">车主工具</text>
    <view class="tool-grid">
      <block wx:for="{{tools}}" wx:key="id">
        <view class="tool-item" data-url="{{item.url}}" bindtap="handleToolTap">
          <text class="iconfont tool-icon">{{item.icon}}</text>
          <text class="tool-title">{{item.title}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="section glass-card">
    <text class="section-title">汽车线索</text>
    <view class="chip-row">
      <view class="chip" bindtap="handleServiceTap" data-type="clue" data-index="0">新车线索</view>
      <view class="chip" bindtap="handleServiceTap" data-type="clue" data-index="1">车抵贷线索</view>
      <view class="chip outline" bindtap="goClueList">全部线索</view>
    </view>
  </view>

  <view class="section glass-card">
    <text class="section-title">汽车延保</text>
    <view class="chip-row">
      <view class="chip" bindtap="handleServiceTap" data-type="warranty" data-index="0">基础保障</view>
      <view class="chip" bindtap="handleServiceTap" data-type="warranty" data-index="1">全面保障</view>
      <view class="chip outline" bindtap="goWarranty">延保详情</view>
    </view>
  </view>

  <view class="quick-links glass-card">
    <view class="ql-item" bindtap="navigateToPrepayment">
      <text class="ql-icon">💰</text>
      <text>提前还款计算</text>
    </view>
    <view class="ql-item" bindtap="goIntake">
      <text class="ql-icon">📋</text>
      <text>汽车进件</text>
    </view>
    <view class="ql-item" bindtap="goChat">
      <text class="ql-icon">💬</text>
      <text>智能客服</text>
    </view>
  </view>

  <view class="compliance glass-card">
    <text>本平台仅提供信息撮合服务，具体方案由持牌金融机构提供，不收取任何前置保证金。</text>
  </view>
</view>
