.auto-service {
  padding-bottom: 40rpx;
}

.as-hero {
  margin-bottom: 20rpx;
  min-height: 220rpx;
}

.loc-arrow {
  margin-left: auto;
  color: #ccc;
  font-size: 32rpx;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-num {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.section {
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid #D4A84B;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.product-card {
  text-align: center;
  padding: 20rpx 12rpx;
  background: #f7f9fc;
  border-radius: 16rpx;
}

.product-card .icon {
  width: 72rpx;
  height: 72rpx;
  display: block;
  margin: 0 auto 12rpx;
}

.p-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.p-desc {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.more-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  font-size: 24rpx;
  color: var(--color-primary);
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.tool-item {
  text-align: center;
  padding: 16rpx 8rpx;
  background: #f7f9fc;
  border-radius: 14rpx;
}

.tool-icon {
  width: 48rpx;
  height: 48rpx;
  display: block;
  margin: 0 auto 8rpx;
}

.tool-title {
  font-size: 22rpx;
  color: var(--color-primary);
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: 26rpx;
}

.chip.outline {
  background: #fff;
  border: 1rpx solid var(--color-primary);
}

.quick-links {
  display: flex;
  gap: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.ql-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  background: #f7f9fc;
  border-radius: 14rpx;
  font-size: 22rpx;
  color: var(--color-primary);
}

.ql-icon {
  display: block;
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.compliance {
  padding: 20rpx 24rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  text-align: center;
}

.arrow {
  color: #ccc;
}
