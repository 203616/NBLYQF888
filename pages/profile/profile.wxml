<view class="profile-container page-shell">
  <!-- 用户信息头部 -->
  <view class="user-header premium-hero">
    <view class="premium-hero-body profile-hero-body">
      <view class="avatar-wrap" bindtap="editAvatar">
        <safe-image class="avatar" src="{{userInfo.avatarUrl || ''}}" />
        <view class="avatar-overlay">
          <text class="avatar-camera-icon">📷</text>
        </view>
      </view>
      <!-- 昵称 -->
      <view class="nickname-row" bindtap="editNickName">
        <text class="nickname">{{userInfo.nickName || '用户'}}</text>
        <text class="nickname-edit-icon">✏️</text>
      </view>
      <!-- 个性签名 -->
      <view class="signature-row" bindtap="editSignature">
        <text class="signature" wx:if="{{userInfo.signature}}">{{userInfo.signature}}</text>
        <text class="signature signature-placeholder" wx:else>点击添加个性签名</text>
        <text class="signature-edit-icon">✏️</text>
      </view>
      <!-- 联系电话 -->
      <view class="info-row" bindtap="togglePhonePanel">
        <text class="info-label">📞</text>
        <text class="info-value" wx:if="{{userInfo.phone}}">{{maskedPhone}}</text>
        <text class="info-value info-placeholder" wx:else>点击绑定手机</text>
      </view>
      <!-- 实名认证 -->
      <view class="info-row auth-row" bindtap="toggleAuthPanel">
        <text class="info-label">🪪</text>
        <text class="info-value" wx:if="{{authStatus === 'verified'}}">已实名认证 · {{maskedRealName}}</text>
        <text class="info-value auth-pending" wx:elif="{{authStatus === 'pending'}}">审核中</text>
        <text class="info-value auth-pending" wx:else>未实名认证 ›</text>
      </view>
    </view>
  </view>

  <!-- ===== 实名认证面板 ===== -->
  <view class="auth-panel glass-card fade-in-up" wx:if="{{showAuthPanel}}">
    <view class="panel-header">
      <text class="panel-title">实名认证</text>
      <text class="panel-close" bindtap="toggleAuthPanel">✕</text>
    </view>
    <view class="panel-divider"></view>

    <!-- 已认证状态展示 -->
    <view class="auth-info-display" wx:if="{{authStatus === 'verified' && !authForm.realName}}">
      <view class="auth-badge-row">
        <text class="auth-badge-verified">✅ 已实名认证</text>
      </view>
      <view class="auth-info-row">
        <text class="auth-info-label">真实姓名</text>
        <text class="auth-info-value">{{maskedRealName}}</text>
      </view>
      <view class="auth-info-row">
        <text class="auth-info-label">证件号码</text>
        <text class="auth-info-value">{{maskedIdNo}}</text>
      </view>
      <view class="auth-info-row" wx:if="{{authVerifiedTime}}">
        <text class="auth-info-label">认证时间</text>
        <text class="auth-info-value">{{authVerifiedTime}}</text>
      </view>
      <view class="auth-info-row">
        <text class="auth-info-label">证件类型</text>
        <text class="auth-info-value">{{idType}}</text>
      </view>
      <button class="btn-outline auth-reauth-btn" bindtap="reAuth">重新认证</button>
    </view>

    <!-- 认证表单 -->
    <view class="auth-form" wx:else>
      <view class="form-field">
        <text class="field-label">真实姓名</text>
        <input class="field-input" placeholder="请输入您的真实姓名" value="{{authForm.realName}}" bindinput="onAuthNameInput" maxlength="20" />
      </view>
      <view class="form-field">
        <text class="field-label">身份证号码</text>
        <input class="field-input" placeholder="请输入18位身份证号码" value="{{authForm.idNo}}" bindinput="onAuthIdNoInput" maxlength="18" />
      </view>
      <view class="form-agreement">
        <text class="agreement-text">提交即表示您同意《实名认证协议》，信息将加密传输</text>
      </view>
      <button class="btn-gold auth-submit-btn" bindtap="submitAuth">提交认证</button>
    </view>
  </view>

  <!-- ===== 手机绑定面板 ===== -->
  <view class="phone-panel glass-card fade-in-up" wx:if="{{showPhonePanel}}">
    <view class="panel-header">
      <text class="panel-title">绑定手机</text>
      <text class="panel-close" bindtap="togglePhonePanel">✕</text>
    </view>
    <view class="panel-divider"></view>

    <!-- 当前绑定状态 -->
    <view class="phone-current" wx:if="{{userInfo.phone}}">
      <view class="phone-current-row">
        <text class="phone-current-label">当前绑定</text>
        <text class="phone-current-value">{{maskedPhone}}</text>
      </view>
      <view class="phone-current-row" wx:if="{{phoneBoundTime}}">
        <text class="phone-current-label">绑定时间</text>
        <text class="phone-current-value">{{phoneBoundTime}}</text>
      </view>
      <view class="panel-divider-light"></view>
    </view>

    <!-- 更换/绑定手机表单 -->
    <view class="phone-form">
      <view class="form-field">
        <text class="field-label">手机号码</text>
        <input class="field-input" type="number" maxlength="11" placeholder="请输入11位手机号码" value="{{phoneForm.newPhone}}" bindinput="onPhoneInput" />
        <text class="field-hint" wx:if="{{phoneFormError}}">手机号格式不正确</text>
      </view>
      <view class="form-field code-field">
        <text class="field-label">验证码</text>
        <view class="code-input-row">
          <input class="field-input code-input" type="number" maxlength="6" placeholder="请输入验证码" value="{{phoneForm.verifyCode}}" bindinput="onVerifyCodeInput" />
          <button class="code-btn {{countdown > 0 ? 'disabled' : ''}}" disabled="{{countdown > 0}}" bindtap="sendVerifyCode">
            <text wx:if="{{countdown > 0}}">{{countdown}}s</text>
            <text wx:else>获取验证码</text>
          </button>
        </view>
      </view>
      <button class="btn-gold phone-submit-btn" bindtap="submitPhoneChange">确认{{userInfo.phone ? '更换' : '绑定'}}</button>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="profile-stats">
    <view class="stat-item glass-card fade-in-up" wx:for="{{quickStats}}" wx:key="label" data-idx="{{index}}" bindtap="goStat" style="animation-delay: {{index * 0.08}}s">
      <text class="stat-num">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 智能客服入口 -->
  <view class="service-entry glass-card fade-in-up" bindtap="goServiceChat">
    <view class="service-left">
      <text class="service-icon">💬</text>
      <view>
        <text class="service-title">智能客服</text>
        <text class="service-desc">材料清单、流程咨询、风险提示</text>
      </view>
    </view>
    <text class="iconfont icon-right"></text>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section glass-card fade-in-up">
    <block wx:for="{{modules}}" wx:key="id">
      <view
        class="menu-item"
        data-id="{{item.id}}"
        bindtap="navigateToModule"
        style="animation-delay: {{0.2 + index * 0.05}}s"
      >
        <view class="menu-left">
          <text class="iconfont {{item.icon}} menu-icon"></text>
          <view class="menu-text">
            <text class="menu-title">{{item.title}}</text>
            <text class="menu-desc">{{item.desc}}</text>
          </view>
        </view>
        <view class="menu-right">
          <text class="module-badge" wx:if="{{item.id === 'notifications' && unreadCount > 0}}">{{unreadCount}}</text>
          <text class="iconfont icon-right"></text>
        </view>
      </view>
    </block>
  </view>

  <!-- 最近进件 -->
  <view class="section glass-card fade-in-up" wx:if="{{recentIntakes.length}}">
    <view class="section-header">
      <text class="title">最近进件</text>
    </view>
    <block wx:for="{{recentIntakes}}" wx:key="applicationNo">
      <view class="intake-row" data-no="{{item.applicationNo}}" bindtap="goIntakeDetail">
        <view>
          <text class="intake-name">{{item.productName}}</text>
          <text class="intake-no">{{item.applicationNo}}</text>
        </view>
        <view class="intake-right">
          <text class="intake-status">{{item.statusText}}</text>
          <text class="intake-progress">{{item.progress}}%</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 文档中心 -->
  <view class="section glass-card fade-in-up">
    <view class="section-header">
      <text class="title">文档中心</text>
    </view>
    <view class="doc-list">
      <block wx:for="{{docItems}}" wx:key="id">
        <view
          class="doc-item"
          data-id="{{item.id}}"
          bindtap="handleDocItemTap"
        >
          <view>
            <text class="doc-name">{{item.name}}</text>
            <text class="doc-desc">{{item.desc}}</text>
          </view>
          <text class="iconfont icon-right"></text>
        </view>
      </block>
    </view>
  </view>

  <!-- OA工作台 -->
  <view class="section glass-card fade-in-up">
    <view class="section-header">
      <text class="title">OA工作台</text>
    </view>
    <view class="oa-panel">
      <block wx:for="{{oaStats}}" wx:key="name">
        <view class="oa-item">
          <text class="count">{{item.count}}</text>
          <text class="oa-label">{{item.name}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 敏感信息显示开关 -->
  <view class="sensitive-toggle glass-card fade-in-up" bindtap="toggleSensitiveDisplay">
    <text class="toggle-label">敏感信息显示</text>
    <view class="toggle-switch {{sensitiveDisplay ? 'on' : ''}}">
      <view class="toggle-knob"></view>
    </view>
  </view>

  <!-- 合规底部 -->
  <view class="compliance-footer">
    <text>{{complianceNote}}</text>
  </view>
  <view class="page-safe"></view>
</view>
