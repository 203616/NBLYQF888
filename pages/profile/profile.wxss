.profile-container {
  padding-bottom: 40rpx;
  background-color: #f7f9fc;
  min-height: 100vh;
}

.user-header {
  min-height: 320rpx;
  margin-bottom: 0;
  border-radius: 0;
}

.profile-hero-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding-top: 48rpx;
  padding-bottom: 48rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.nickname {
  font-size: 36rpx;
  margin: 20rpx 0 12rpx;
  font-weight: bold;
  color: #fff;
}

.badge {
  background: rgba(212, 168, 75, 0.9);
  color: #0F3D2E;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.edit-hint {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.module-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 24rpx;
  gap: 16rpx;
  margin: 0 24rpx 24rpx;
  position: relative;
  z-index: 2;
}

.profile-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin: -40rpx 24rpx 20rpx;
  position: relative;
  z-index: 2;
}

.profile-stats .stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.profile-stats .stat-num {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.profile-stats .stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.service-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 20rpx;
  padding: 24rpx;
  position: relative;
  z-index: 2;
}

.service-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.service-icon {
  font-size: 40rpx;
}

.service-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.service-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.service-arrow {
  font-size: 40rpx;
  color: #ccc;
}

.module-item.module-wide {
  grid-column: span 3;
}

.module-item {
  display: flex;
  align-items: flex-start;
  flex-direction: column;
  background: #f7f9fc;
  border-radius: 14rpx;
  padding: 24rpx;
}

.module-item .iconfont {
  font-size: 50rpx;
  color: #0F3D2E;
  margin-bottom: 15rpx;
}

.module-desc {
  color: #777;
  font-size: 22rpx;
  margin-top: 8rpx;
  line-height: 1.4;
}

.module-item {
  position: relative;
}

.module-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #e11d48;
  color: #fff;
  font-size: 20rpx;
  text-align: center;
}

.section {
  border-radius: var(--radius-md);
  margin: 0 24rpx 24rpx;
  overflow: hidden;
}

.section-header {
  padding: 25rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-header .title {
  font-size: 32rpx;
  font-weight: bold;
}

.doc-list {
  padding: 0 25rpx;
}

.doc-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.doc-name {
  display: block;
  color: #333;
  font-size: 30rpx;
  font-weight: bold;
}

.doc-desc {
  display: block;
  color: #777;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.doc-item:last-child {
  border-bottom: none;
}

.oa-panel {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
}

.oa-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.oa-item .count {
  font-size: 44rpx;
  font-weight: bold;
  color: #0F3D2E;
  margin-bottom: 10rpx;
}

.intake-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 25rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.intake-row:last-child {
  border-bottom: none;
}

.intake-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.intake-no {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.intake-right {
  text-align: right;
}

.intake-status {
  display: block;
  font-size: 24rpx;
  color: var(--color-primary);
}

.intake-progress {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.compliance-footer {
  margin: 0 24rpx 40rpx;
  padding: 20rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.6;
  text-align: center;
}