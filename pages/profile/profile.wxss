.profile-container {
  padding-bottom: var(--space-xl);
  background-color: var(--color-bg-page);
  min-height: 100vh;
}

.user-header {
  min-height: 320rpx;
  margin-bottom: 0;
  border-radius: 0;
  overflow: hidden;
  position: relative;
}

.profile-hero-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 48rpx var(--space-md);
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  flex-shrink: 0;
}

.nickname {
  font-size: 36rpx;
  margin: 20rpx 0 12rpx;
  font-weight: bold;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 280rpx;
}

.badge {
  background: rgba(212, 168, 75, 0.9);
  color: var(--color-primary);
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.edit-hint {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.profile-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin: -40rpx var(--space-md) var(--space-md);
  position: relative;
  z-index: 2;
}

.profile-stats .stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.profile-stats .stat-num {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.profile-stats .stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.service-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 var(--space-md) var(--space-md);
  padding: var(--space-md);
  position: relative;
  z-index: 2;
}

.service-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex: 1;
}

.service-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.service-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.service-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.service-arrow {
  font-size: 40rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
  margin-left: var(--space-sm);
}

.module-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: var(--space-md);
  gap: var(--space-sm);
  margin: 0 var(--space-md) var(--space-md);
  position: relative;
  z-index: 2;
}

.module-item {
  display: flex;
  align-items: flex-start;
  flex-direction: column;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  position: relative;
  box-shadow: var(--shadow-card);
}

.module-item.module-wide {
  grid-column: span 3;
}

.module-item .iconfont {
  font-size: 50rpx;
  color: var(--color-primary);
  margin-bottom: 15rpx;
}

.module-desc {
  color: var(--color-text-secondary);
  font-size: 22rpx;
  margin-top: 8rpx;
  line-height: 1.4;
}

.module-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #e11d48;
  color: #fff;
  font-size: 20rpx;
  text-align: center;
}

.section {
  border-radius: var(--radius-md);
  margin: 0 var(--space-md) var(--space-md);
  overflow: hidden;
  padding: 0;
  box-shadow: var(--shadow-card);
}

.section .section-header {
  padding: var(--space-md);
  border-bottom: 1rpx solid var(--color-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section .section-header .title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.doc-list {
  padding: 0 var(--space-md);
}

.doc-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.doc-item:last-child {
  border-bottom: none;
}

.doc-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.doc-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.oa-panel {
  display: flex;
  justify-content: space-around;
  padding: var(--space-md) 0;
}

.oa-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.oa-item .count {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--color-primary);
  margin-bottom: 10rpx;
}

.intake-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md);
  border-bottom: 1rpx solid var(--color-border);
}

.intake-row:last-child {
  border-bottom: none;
}

.intake-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.intake-no {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.intake-right {
  text-align: right;
  flex-shrink: 0;
  margin-left: var(--space-sm);
}

.intake-status {
  display: block;
  font-size: 24rpx;
  color: var(--color-primary);
}

.intake-progress {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.compliance-footer {
  margin: 0 var(--space-md) var(--space-xl);
  padding: var(--space-md);
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  text-align: center;
}
