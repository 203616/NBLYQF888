.welcome-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.welcome-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  filter: brightness(0.55);
}

.welcome-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(15, 61, 46, 0.75) 0%, rgba(15, 61, 46, 0.92) 100%);
}

.welcome-content {
  position: relative;
  z-index: 1;
  padding: 120rpx 48rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-wrap {
  position: relative;
  margin-bottom: 48rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 40rpx;
  position: relative;
  z-index: 1;
}

.logo-ring {
  position: absolute;
  inset: -16rpx;
  border: 3rpx solid rgba(212, 168, 75, 0.5);
  border-radius: 48rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.03); }
}

.brand-copy {
  text-align: center;
  color: #fff;
  margin-bottom: 48rpx;
}

.brand-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  margin: 12rpx 0;
}

.slogan {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  opacity: 0.95;
}

.sub-slogan {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.welcome-features {
  width: 100%;
}

.welcome-features .feature-item {
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.welcome-features .feat-title {
  color: #fff;
}

.welcome-features .feat-desc {
  color: rgba(255, 255, 255, 0.75);
}

.countdown-box {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 80rpx;
  z-index: 2;
  padding: 32rpx;
  text-align: center;
}

.countdown-text {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.skip-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 32rpx;
}

.compliance-mini {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 20rpx;
  line-height: 1.5;
}
