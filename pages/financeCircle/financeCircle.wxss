.finance-circle {
  padding-bottom: 140rpx;
}

.loc-arrow {
  margin-left: auto;
  color: var(--color-text-muted);
  font-size: 32rpx;
}

.finance-hero {
  margin-bottom: 20rpx;
  min-height: 240rpx;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-num {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.flow-card, .demand-form, .demand-list {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.block-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 20rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid #D4A84B;
}

.flow-steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.flow-step {
  background: var(--color-primary-bg);
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
  text-align: center;
}

.flow-index {
  display: inline-block;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  border-radius: 50%;
  background: var(--gradient-hero);
  color: #fff;
  font-size: 22rpx;
}

.flow-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-top: 10rpx;
}

.flow-desc {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
  line-height: 1.4;
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.form-item.column {
  flex-direction: column;
  align-items: stretch;
}

.form-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  margin-right: 20rpx;
}

.form-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  margin-top: 12rpx;
  font-size: 28rpx;
  background: #f7f9fc;
  border-radius: 12rpx;
  padding: 16rpx;
}

.submit-btn {
  margin-top: 24rpx;
  width: 100%;
}

.quick-links {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.quick-link {
  text-align: center;
  padding: 24rpx 12rpx;
}

.ql-icon {
  display: block;
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.ql-title {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.count {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.filter-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.filter-tab {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: var(--color-bg-card);
  color: var(--color-text-secondary);
}

.filter-tab.active {
  background: var(--gradient-hero);
  color: #fff;
}

.demand-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx solid var(--color-border);
}

.demand-body {
  flex: 1;
  min-width: 0;
}

.demand-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.demand-type {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.tag-funding {
  background: #fff8e6;
  color: #8a6d3b;
}

.tag-loan {
  background: #e6f2ec;
  color: var(--color-primary);
}

.demand-status {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.demand-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.demand-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.mini-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.progress-wrap {
  margin-top: 12rpx;
}

.progress-bar {
  height: 8rpx;
  background: var(--color-border);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: var(--gradient-hero);
  border-radius: 4rpx;
}

.progress-text {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.demand-arrow {
  font-size: 36rpx;
  color: var(--color-text-muted);
  padding-left: 12rpx;
}

.empty-tip {
  text-align: center;
  padding: 40rpx;
  color: var(--color-text-muted);
  font-size: 26rpx;
}

.compliance-panel {
  padding: 20rpx 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.7;
}

.inst-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.inst-item {
  padding: 16rpx;
  background: var(--color-bg-soft);
  border-radius: var(--radius-sm);
}

.inst-name {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
}

.inst-products {
  display: block;
  font-size: 22rpx;
  color: var(--color-primary);
  margin-top: 6rpx;
}

.guide-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.guide-item:last-child {
  border-bottom: none;
}

.guide-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
}

.guide-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  line-height: 1.6;
}

.supply-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.supply-title {
  font-size: 26rpx;
  font-weight: bold;
}

.supply-amount {
  display: block;
  font-size: 24rpx;
  color: var(--color-gold);
  margin-top: 6rpx;
}

.purpose-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.purpose-tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border-radius: 24rpx;
}

.feed-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.feed-head {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.feed-more {
  margin-left: auto;
  font-size: 24rpx;
  color: var(--color-primary, #0F3D2E);
}

.feed-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.feed-user {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
}

.feed-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.feed-content {
  font-size: 26rpx;
  line-height: 1.7;
}

.feed-images {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.feed-img {
  width: 200rpx;
  height: 140rpx;
  border-radius: 8rpx;
}

.feed-actions {
  display: flex;
  gap: 32rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.feed-head-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.publish-btn {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.publish-box {
  background: #f7f9fc;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.publish-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 26rpx;
}

.publish-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.pub-add-img {
  font-size: 24rpx;
  color: var(--color-primary);
}

.pub-submit {
  font-size: 26rpx;
  padding: 0 32rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
}

.pub-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

.action-btn.liked {
  color: var(--color-primary);
  font-weight: 600;
}

.comment-list {
  margin-top: 12rpx;
  padding: 12rpx;
  background: #f7f9fc;
  border-radius: 8rpx;
}

.comment-line {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  margin-bottom: 4rpx;
}

.comment-user {
  font-weight: 600;
  color: var(--color-primary);
}

.comment-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  z-index: 100;
}

.comment-mask {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.4);
}

.comment-box {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 12rpx;
  padding: 16rpx;
  align-items: center;
}

.comment-input {
  flex: 1;
  font-size: 28rpx;
}
