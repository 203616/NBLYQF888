<view class="finance-circle page-shell">
  <view class="location-bar glass-card" bindtap="handleChooseCity">
    <text class="iconfont icon-location loc-icon"></text>
    <text>{{location.city || '定位中'}} · 本地需求大厅</text>
    <text class="loc-arrow">›</text>
  </view>

  <view class="finance-hero premium-hero">
    <safe-image className="premium-hero-bg" src="/images/banner3.webp" mode="aspectFill" />
    <view class="premium-hero-body">
      <text class="premium-badge">融资撮合</text>
      <text class="premium-hero-title">亮叶企服 · 易融圈</text>
      <text class="premium-hero-sub">发布资金需求 · 对接助融渠道 · 智能方案匹配</text>
    </view>
  </view>

  <view class="stat-row">
    <view class="stat-item glass-card" wx:for="{{stats}}" wx:key="label">
      <text class="stat-num">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <view class="flow-card glass-card">
    <text class="block-title">撮合流程</text>
    <view class="flow-steps">
      <block wx:for="{{flowSteps}}" wx:key="title">
        <view class="flow-step">
          <text class="flow-index">{{index + 1}}</text>
          <text class="flow-title">{{item.title}}</text>
          <text class="flow-desc">{{item.desc}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="institution-panel glass-card" wx:if="{{institutions.length}}">
    <text class="block-title">宁波合作机构</text>
    <view class="inst-grid">
      <block wx:for="{{institutions}}" wx:key="name">
        <view class="inst-item">
          <text class="inst-name">{{item.name}}</text>
          <text class="inst-products">{{item.products}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="guide-panel glass-card" wx:if="{{guides.length}}">
    <text class="block-title">撮合指南</text>
    <block wx:for="{{guides}}" wx:key="title">
      <view class="guide-item">
        <text class="guide-title">{{item.title}}</text>
        <text class="guide-desc">{{item.desc}}</text>
      </view>
    </block>
  </view>

  <view class="supply-panel glass-card" wx:if="{{institutionSupply.length}}">
    <text class="block-title">机构供给（供资金）</text>
    <block wx:for="{{institutionSupply}}" wx:key="title">
      <view class="supply-item">
        <text class="supply-title">{{item.title}}</text>
        <text class="supply-amount">{{item.amount}}</text>
        <view class="tag-row">
          <text class="mini-tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
      </view>
    </block>
  </view>

  <view class="purpose-panel glass-card" wx:if="{{hotPurposes.length}}">
    <text class="block-title">热门用途</text>
    <view class="purpose-tags">
      <text class="purpose-tag" wx:for="{{hotPurposes}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="feed-panel glass-card">
    <view class="feed-head-row">
      <text class="block-title">融圈动态</text>
      <text class="publish-btn" bindtap="togglePublish">{{showPublish ? '收起' : '+ 发布'}}</text>
    </view>

    <view class="publish-box" wx:if="{{showPublish}}">
      <textarea class="publish-textarea" placeholder="分享融资需求、机构供给或服务心得…" value="{{publishContent}}" bindinput="onPublishInput" />
      <view class="publish-images" wx:if="{{publishImages.length}}">
        <safe-image wx:for="{{publishImages}}" wx:key="*this" src="{{item || ''}}" className="pub-img" mode="aspectFill" />
      </view>
      <view class="publish-actions">
        <text class="pub-add-img" bindtap="choosePublishImage">📷 添加图片</text>
        <button class="pub-submit btn-gold" bindtap="submitPublish">发布</button>
      </view>
    </view>

    <block wx:for="{{feedPosts}}" wx:key="id">
      <view class="feed-item" data-id="{{item.id}}" bindtap="navigateToFeedDetail">
        <view class="feed-head">
          <safe-image className="feed-avatar" src="{{item.avatar || ''}}" mode="aspectFill" />
          <view class="feed-meta">
            <text class="feed-user">{{item.user}}</text>
            <text class="feed-time">{{item.time}}</text>
          </view>
          <text class="feed-more">详情 ›</text>
        </view>
        <text class="feed-content">{{item.content}}</text>
        <view class="feed-images" wx:if="{{item.images.length}}">
          <safe-image wx:for="{{item.images}}" wx:key="*this" wx:for-item="img" src="{{img || ''}}" previewUrl="{{img}}" previewUrls="{{item.images}}" className="feed-img" catch:tap="previewFeedImage" />
        </view>
        <view class="feed-actions">
          <text class="action-btn {{item.liked ? 'liked' : ''}}" data-id="{{item.id}}" catchtap="handleLike">👍 {{item.likes}}</text>
          <text class="action-btn" data-id="{{item.id}}" catchtap="openComment">💬 {{item.comments || (item.commentList ? item.commentList.length : 0)}}</text>
        </view>
        <view class="comment-list" wx:if="{{item.commentList && item.commentList.length}}">
          <block wx:for="{{item.commentList}}" wx:key="id" wx:for-item="c">
            <text class="comment-line"><text class="comment-user">{{c.user}}：</text>{{c.content}}</text>
          </block>
        </view>
      </view>
    </block>
  </view>

  <view class="comment-modal" wx:if="{{commentPostId}}">
    <view class="comment-mask" bindtap="closeComment"></view>
    <view class="comment-box glass-card">
      <input class="comment-input" placeholder="写下你的评论…" value="{{commentInput}}" bindinput="onCommentInput" focus />
      <button class="btn-gold" bindtap="submitComment">发送</button>
    </view>
  </view>

  <view class="demand-form glass-card">
    <text class="block-title">发布需求</text>
    <picker bindchange="handleTypeChange" value="{{selectedTypeIndex}}" range="{{demandTypes}}" range-key="label">
      <view class="form-item">
        <text class="form-label">需求类型</text>
        <text class="form-value">{{demandTypes[selectedTypeIndex].label}} ›</text>
      </view>
    </picker>
    <picker bindchange="handlePurposeChange" value="{{selectedPurposeIndex}}" range="{{purposes}}">
      <view class="form-item">
        <text class="form-label">资金用途</text>
        <text class="form-value">{{newDemand.purpose}} ›</text>
      </view>
    </picker>
    <view class="form-item">
      <text class="form-label">金额</text>
      <input class="form-input" placeholder="如：50万" value="{{newDemand.amount}}" bindinput="handleInputChange" data-field="amount" />
    </view>
    <picker bindchange="handlePeriodChange" value="{{selectedPeriodIndex}}" range="{{periods}}">
      <view class="form-item">
        <text class="form-label">期限</text>
        <text class="form-value">{{newDemand.period}} ›</text>
      </view>
    </picker>
    <view class="form-item">
      <text class="form-label">联系方式</text>
      <input class="form-input" placeholder="手机号" value="{{newDemand.contact}}" bindinput="handleInputChange" data-field="contact" />
    </view>
    <view class="form-item">
      <text class="form-label">所在城市</text>
      <text class="form-value">{{newDemand.city || location.city}}</text>
    </view>
    <view class="form-item column">
      <text class="form-label">补充说明</text>
      <textarea class="form-textarea" placeholder="可填写用途、主体资质、期望方案等" value="{{newDemand.remark}}" bindinput="handleInputChange" data-field="remark" />
    </view>
    <button class="submit-btn btn-gold" loading="{{submitting}}" bindtap="handleSubmit">发布需求</button>
  </view>

  <view class="quick-links">
    <view class="quick-link glass-card" bindtap="navigateToChannel">
      <text class="ql-icon">🤝</text>
      <text class="ql-title">助融渠道</text>
    </view>
    <view class="quick-link glass-card" bindtap="navigateToServiceChat">
      <text class="ql-icon">💬</text>
      <text class="ql-title">智能客服</text>
    </view>
    <view class="quick-link glass-card" bindtap="goIntake">
      <text class="ql-icon">📋</text>
      <text class="ql-title">进件系统</text>
    </view>
  </view>

  <view class="demand-list glass-card">
    <view class="section-header">
      <text class="section-title">需求大厅</text>
      <text class="count">{{filteredDemands.length}} 条</text>
    </view>
    <view class="filter-tabs">
      <text class="filter-tab {{filterType === 'all' ? 'active' : ''}}" data-type="all" bindtap="switchFilter">全部</text>
      <text class="filter-tab {{filterType === 'mine' ? 'active' : ''}}" data-type="mine" bindtap="switchFilter">我的</text>
      <text class="filter-tab {{filterType === 'funding' ? 'active' : ''}}" data-type="funding" bindtap="switchFilter">找资金</text>
      <text class="filter-tab {{filterType === 'loan' ? 'active' : ''}}" data-type="loan" bindtap="switchFilter">供资金</text>
    </view>
    <block wx:for="{{filteredDemands}}" wx:key="id">
      <view class="demand-item" data-id="{{item.id}}" bindtap="navigateToDemandDetail">
        <view class="demand-body">
          <view class="demand-top">
            <text class="demand-type tag-{{item.type}}">{{item.type === 'funding' ? '找资金' : '供资金'}}</text>
            <text class="demand-status">{{item.status}}</text>
          </view>
          <text class="demand-title">{{item.title}}</text>
          <text class="demand-meta">{{item.amount}} · {{item.period}} · {{item.city || '全国'}}</text>
          <view class="tag-row" wx:if="{{item.tags}}">
            <text class="mini-tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
          </view>
          <view class="progress-wrap">
            <view class="progress-bar"><view class="progress-inner" style="width: {{item.progress}}%;"></view></view>
            <text class="progress-text">匹配进度 {{item.progress}}%</text>
          </view>
        </view>
        <text class="demand-arrow">›</text>
      </view>
    </block>
    <view class="empty-tip" wx:if="{{!filteredDemands.length}}">暂无该类型需求，快来发布第一条吧</view>
  </view>

  <view class="compliance-panel">
    <text>温馨提示：亮叶企服仅提供金融信息咨询与居间撮合服务，不承诺审批结果，不收取前置保证金。</text>
  </view>
</view>
