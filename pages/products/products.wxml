<view class="products-page page-shell">
  <view class="hero-card premium-hero">
    <safe-image className="premium-hero-bg" src="/images/banner2.webp" mode="aspectFill" />
    <view class="premium-hero-body">
      <text class="premium-badge">产品中心</text>
      <text class="premium-hero-title">产品与服务大全</text>
      <text class="premium-hero-sub">信息咨询与居间撮合 · 以持牌机构审核为准</text>
    </view>
  </view>

  <view class="category-section glass-card">
    <view class="section-head-row">
      <text class="section-head-title">{{activeCategoryName}}</text>
      <text class="section-head-count">{{productList.length}} 款产品</text>
    </view>
  </view>

  <view class="category-grid">
    <block wx:for="{{categories}}" wx:key="id">
      <view
        class="category-grid-item {{activeCategory === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="handleCategoryTap"
      >
        <text class="grid-icon">{{item.icon}}</text>
        <text class="grid-name">{{item.name}}</text>
      </view>
    </block>
  </view>

  <view class="product-grid" wx:if="{{!loading && productList.length}}">
    <block wx:for="{{productList}}" wx:key="id">
      <view class="grid-product glass-card {{tappingId === item.id ? 'tap-active' : ''}}" data-id="{{item.id}}" bindtap="handleProductTap">
        <safe-image className="grid-cover" src="{{item.cover}}" mode="aspectFill" />
        <text class="grid-title">{{item.name}}</text>
        <text class="grid-rate">{{item.rate}}</text>
      </view>
    </block>
  </view>

  <view class="empty-state" wx:if="{{!loading && productList.length === 0}}">
    <text>当前「{{activeCategoryName}}」暂无产品</text>
    <button class="btn-outline empty-btn" bindtap="goIntake">进入进件系统</button>
  </view>
</view>
