/* ===== 页面微动效 ===== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in-up {
  animation: fadeInUp 0.45s ease-out both;
}

/* ===== 布局 ===== */
.products-page {
  padding: var(--space-md);
  min-height: 100vh;
  background: var(--color-bg-page);
}

/* ===== 英雄区 ===== */
.hero-card {
  margin-bottom: var(--space-md);
  min-height: 260rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

/* ===== 分类头部 ===== */
.category-section {
  padding: 20rpx var(--space-md);
  margin-bottom: var(--space-sm);
  border-radius: var(--radius-md);
}

.section-head-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-head-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  padding-left: 14rpx;
  border-left: 6rpx solid var(--color-gold);
}

.section-head-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* ===== 分类 Pills ===== */
.filter-tabs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.filter-pill {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 22rpx 8rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  transition: all 0.2s;
}

.filter-pill:active {
  transform: scale(0.94);
}

.filter-pill.active {
  background: var(--gradient-hero);
  color: #fff;
}

.filter-pill.active .pill-name {
  color: #fff;
}

.pill-icon {
  display: block;
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.pill-name {
  display: block;
  font-size: 22rpx;
  margin-top: 4rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

/* ===== 产品网格 ===== */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-sm);
}

.grid-product {
  overflow: hidden;
  padding: 0;
  border-radius: var(--radius-md);
  transition: transform 0.15s;
}

.grid-product:active {
  transform: scale(0.96);
}

.grid-product.tap-active {
  transform: scale(0.97);
  opacity: 0.9;
}

.grid-cover-wrap {
  width: 100%;
  height: 0;
  padding-bottom: 55%;
  overflow: hidden;
  position: relative;
  background: linear-gradient(135deg, #e8edf3, #d5dce6);
}

.grid-cover-wrap .cover-slot {
  width: 100%;
  height: 100%;
  position: absolute;
  inset: 0;
}

.grid-body {
  padding: var(--space-sm);
}

.grid-icon {
  display: block;
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.grid-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  color: var(--color-text-primary);
}

.grid-rate {
  display: block;
  font-size: 22rpx;
  color: var(--color-gold);
  margin-top: 4rpx;
  font-weight: 500;
}

.grid-desc {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.grid-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-top: 8rpx;
}

.grid-tags .tag {
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  color: var(--color-text-muted);
  padding: 120rpx 0;
  line-height: 1.7;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-state .empty-icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.empty-btn {
  margin-top: var(--space-md);
  width: 60%;
}
