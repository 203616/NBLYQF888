.home-container {
  padding-bottom: 40rpx;
}

.home-top {
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.location-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--color-primary);
}

.loc-icon {
  width: 28rpx;
  height: 28rpx;
}

.top-brand {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #f5f7fa;
  border-radius: 999rpx;
  gap: 12rpx;
}

.search-bar input {
  flex: 1;
  font-size: 26rpx;
  height: 44rpx;
  line-height: 44rpx;
}

.section-grid {
  margin-bottom: 28rpx;
}

.grid-4x4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.grid-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 8rpx;
  min-height: 140rpx;
  text-align: center;
}

.grid-icon {
  font-size: 40rpx;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.grid-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.3;
}

.stats-card {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 28rpx 10rpx;
  margin: 0 24rpx 24rpx;
}

.stat-item { text-align: center; }

.stat-value {
  display: block;
  color: var(--color-primary);
  font-size: 32rpx;
  font-weight: bold;
}

.stat-label {
  display: block;
  color: var(--color-text-secondary);
  font-size: 22rpx;
  margin-top: 6rpx;
}

.banner-swiper {
  height: 320rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  margin: 0 24rpx 28rpx;
}

.banner-swiper .banner-slide {
  width: 100%;
  height: 100%;
  display: block;
}

.section { margin-bottom: 32rpx; }

.home-container .section-header {
  margin: 0 24rpx var(--space-md);
}

/* ===== Waterfall Layout (used by both news & cases) ===== */
.waterfall-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx;
}

.waterfall-card {
  overflow: hidden;
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
}

.waterfall-card-cover {
  width: 100%;
  height: 0;
  padding-bottom: 50%;
  overflow: hidden;
  position: relative;
}

.waterfall-card-cover .wfall-cover {
  width: 100%;
  height: 100%;
  position: absolute;
  inset: 0;
  display: block;
}

.waterfall-card-body {
  padding: 20rpx 24rpx 24rpx;
}

.wfall-tag {
  display: inline-block;
  font-size: 20rpx;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.wfall-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 6rpx;
}

.wfall-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ===== Product Grid ===== */
.product-grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
}

.product-cell {
  overflow: hidden;
  padding: 0;
  border-radius: var(--radius-md);
}

.product-cell-cover {
  width: 100%;
  height: 0;
  padding-bottom: 60%;
  overflow: hidden;
  position: relative;
}

.product-cell-cover .cover-slot {
  width: 100%;
  height: 100%;
  position: absolute;
  inset: 0;
  display: block;
}

.product-cell-body {
  padding: 12rpx 10rpx 16rpx;
}

.product-cell-name {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-cell-rate {
  display: block;
  font-size: 18rpx;
  color: var(--color-danger);
  margin-top: 6rpx;
}

/* ===== Institution ===== */
.institution-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
}

.institution-card { padding: 20rpx; }

.inst-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.inst-name {
  font-size: 26rpx;
  font-weight: bold;
}

.inst-hot {
  font-size: 20rpx;
  color: var(--color-gold);
  background: rgba(212, 168, 75, 0.15);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.inst-type {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.inst-products {
  display: block;
  font-size: 22rpx;
  color: var(--color-primary);
  margin-top: 6rpx;
}

/* ===== Bottom Compliance ===== */
.compliance-tip {
  text-align: center;
  padding: 0 24rpx;
  font-size: 20rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
}
