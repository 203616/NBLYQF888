/* ===== 页面微动效 ===== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes pulseGlow {
  0%, 100% { box-shadow: var(--shadow-card); }
  50% { box-shadow: 0 8rpx 32rpx rgba(15, 61, 46, 0.15); }
}

.fade-in-up {
  animation: fadeInUp 0.45s ease-out both;
}

/* ===== 容器 ===== */
.home-container {
  padding-bottom: 60rpx;
}

/* ===== 顶部栏 ===== */
.home-top {
  padding: 16rpx var(--space-md);
  margin-bottom: var(--space-sm);
}

.top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.location-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.loc-icon {
  width: 28rpx;
  height: 28rpx;
}

.top-brand {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 2rpx;
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-pill);
  gap: 10rpx;
  border: 1rpx solid rgba(15, 61, 46, 0.06);
}

.search-bar input {
  flex: 1;
  font-size: 26rpx;
  height: 44rpx;
  line-height: 44rpx;
}

/* ===== Section 通用 ===== */
.section { margin-bottom: 32rpx; }

.home-container .section-header {
  margin: 0 var(--space-md) var(--space-md);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-header .title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  padding-left: 14rpx;
  border-left: 6rpx solid var(--color-gold);
}

.section-header .more {
  font-size: 24rpx;
  color: var(--color-primary);
  opacity: 0.7;
}

/* ===== 服务网格 ===== */
.section-grid {
  margin-bottom: 28rpx;
}

.grid-4x4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-sm);
  padding: 0 var(--space-md);
}

.grid-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 8rpx;
  min-height: 150rpx;
  text-align: center;
  border-radius: var(--radius-md);
  transition: transform 0.2s, box-shadow 0.2s;
}

.grid-cell:active {
  transform: scale(0.94);
}

.grid-icon {
  font-size: 44rpx;
  line-height: 1.2;
  margin-bottom: 10rpx;
}

.grid-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.3;
}

/* ===== 数据统计 ===== */
.stats-card {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 30rpx 10rpx;
  margin: 0 var(--space-md) var(--space-md);
  border-radius: var(--radius-md);
}

.stat-item { text-align: center; }

.stat-value {
  display: block;
  color: var(--color-primary);
  font-size: 34rpx;
  font-weight: bold;
}

.stat-label {
  display: block;
  color: var(--color-text-secondary);
  font-size: 22rpx;
  margin-top: 6rpx;
}

/* ===== Banner 轮播 ===== */
.banner-swiper {
  height: 320rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  margin: 0 var(--space-md) 32rpx;
  box-shadow: var(--shadow-card);
}

.banner-swiper .banner-slide {
  width: 100%;
  height: 100%;
  display: block;
  background: linear-gradient(135deg, #e8edf3, #d5dce6);
  border-radius: var(--radius-md);
}

/* ===== 产品网格 ===== */
.product-grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-sm);
  padding: 0 var(--space-md);
}

.product-cell {
  overflow: hidden;
  padding: 0;
  border-radius: var(--radius-md);
  transition: transform 0.2s;
}

.product-cell:active {
  transform: scale(0.94);
}

.product-cell-cover {
  width: 100%;
  height: 0;
  padding-bottom: 65%;
  overflow: hidden;
  position: relative;
}

.product-cell-cover .cover-slot {
  width: 100%;
  height: 100%;
  position: absolute;
  inset: 0;
  display: block;
  background: linear-gradient(135deg, #e8edf3, #d5dce6);
}

.product-cell-body {
  padding: 12rpx 10rpx 16rpx;
}

.product-cell-name {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-cell-rate {
  display: block;
  font-size: 18rpx;
  color: var(--color-danger);
  margin-top: 6rpx;
}

/* ===== 机构卡片 ===== */
.institution-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-sm);
  padding: 0 var(--space-md);
}

.institution-card {
  padding: 24rpx;
  border-radius: var(--radius-md);
  transition: transform 0.2s;
}

.institution-card:active {
  transform: scale(0.96);
}

.inst-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.inst-name {
  font-size: 26rpx;
  font-weight: bold;
}

.inst-hot {
  font-size: 20rpx;
  color: var(--color-gold);
  background: rgba(212, 168, 75, 0.15);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
}

.inst-type {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 10rpx;
}

.inst-products {
  display: block;
  font-size: 22rpx;
  color: var(--color-primary);
  margin-top: 6rpx;
}

/* ===== 瀑布流卡片（案例/资讯/需求） ===== */
.waterfall-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding: 0 var(--space-md);
}

.waterfall-card {
  overflow: hidden;
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  transition: transform 0.2s;
}

.waterfall-card:active {
  transform: scale(0.98);
}

.waterfall-card-cover {
  width: 100%;
  height: 0;
  padding-bottom: 48%;
  overflow: hidden;
  position: relative;
  background: linear-gradient(135deg, #e8edf3, #d5dce6);
}

.waterfall-card-cover .wfall-cover {
  width: 100%;
  height: 100%;
  position: absolute;
  inset: 0;
  display: block;
}

.waterfall-card-body {
  padding: 20rpx var(--space-md) var(--space-md);
}

.wfall-tag {
  display: inline-block;
  font-size: 20rpx;
  color: var(--color-primary);
  background: rgba(15, 61, 46, 0.08);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 8rpx;
}

.wfall-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 6rpx;
}

.wfall-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ===== 案例标签行 ===== */
.wfall-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.wfall-tags .tag {
  display: inline-block;
  font-size: 20rpx;
  color: var(--color-gold);
  background: rgba(212, 168, 75, 0.12);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
}

/* ===== 资讯元信息行 ===== */
.wfall-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.wfall-meta-row .tag {
  display: inline-block;
  font-size: 20rpx;
  color: var(--color-primary);
  background: rgba(15, 61, 46, 0.08);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
}

.wfall-date {
  font-size: 20rpx;
  color: var(--color-text-muted);
}

.wfall-views {
  font-size: 20rpx;
  color: var(--color-text-muted);
}

/* ===== 合规提示 ===== */
.compliance-tip {
  text-align: center;
  padding: 0 var(--space-md) 40rpx;
  font-size: 20rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
}
