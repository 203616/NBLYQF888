<view class="home-container page-shell">
  <view class="home-top glass-card">
    <view class="top-row">
      <view class="location-chip" bindtap="handleChooseCity">
        <text class="iconfont icon-location loc-icon"></text>
        <text>{{location.city || '宁波市'}}</text>
      </view>
      <text class="top-brand">亮叶企服</text>
    </view>
    <view class="search-bar">
      <icon type="search" size="16" color="#999" />
      <input
        placeholder="搜索产品、资讯、避坑指南"
        value="{{searchValue}}"
        confirm-type="search"
        bindinput="handleSearchInput"
        bindconfirm="handleSearch"
      />
    </view>
  </view>

  <view class="section section-grid">
    <view class="section-header">
      <text class="title">全部服务</text>
      <text class="more" bindtap="navigateToProducts">产品大全 ></text>
    </view>
    <view class="grid-4x4">
      <block wx:for="{{serviceGrid}}" wx:key="title">
        <view class="grid-cell glass-card" data-path="{{item.path}}" bindtap="navigateGrid">
          <text class="grid-icon">{{item.icon}}</text>
          <text class="grid-title">{{item.title}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="stats-card glass-card" wx:if="{{stats.length}}">
    <block wx:for="{{stats}}" wx:key="label">
      <view class="stat-item">
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </block>
  </view>

  <swiper wx:if="{{banners.length}}" class="banner-swiper" autoplay interval="5000" circular indicator-dots indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#D4A84B">
    <block wx:for="{{banners}}" wx:key="id">
      <swiper-item>
        <safe-image className="banner-slide" src="{{item.img || ''}}" mode="aspectFill" lazyLoad="{{true}}" dataIndex="{{index}}" bind:tap="handleBannerTap" />
      </swiper-item>
    </block>
  </swiper>

  <view class="section" wx:if="{{productList.length}}">
    <view class="section-header">
      <text class="title">精选产品</text>
      <text class="more" bindtap="navigateToProducts">全部 ></text>
    </view>
    <view class="product-grid-4">
      <block wx:for="{{productList}}" wx:key="id">
        <view class="product-cell glass-card" data-path="{{item.path}}" bindtap="navigateToProduct">
          <view class="product-cell-cover" wx:if="{{item.cover}}">
            <safe-image className="cover-slot" src="{{item.cover || ''}}" mode="aspectFill" />
          </view>
          <view class="product-cell-body">
            <text class="product-cell-name">{{item.name}}</text>
            <text class="product-cell-rate">{{item.rate}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="section" wx:if="{{institutions.length}}">
    <view class="section-header">
      <text class="title">合作金融机构</text>
    </view>
    <view class="institution-list">
      <block wx:for="{{institutions}}" wx:key="name">
        <view class="institution-card glass-card" data-name="{{item.name}}" bindtap="navigateToInstitutionProduct">
          <view class="inst-head">
            <text class="inst-name">{{item.name}}</text>
            <text class="inst-hot" wx:if="{{item.hot}}">热门</text>
          </view>
          <text class="inst-type">{{item.type}}</text>
          <text class="inst-products">{{item.products}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="section" wx:if="{{cases.length}}">
    <view class="section-header">
      <text class="title">服务案例</text>
    </view>
    <view class="waterfall-list">
      <block wx:for="{{cases}}" wx:key="id">
        <view class="waterfall-card glass-card" data-path="{{item.path}}" bindtap="navigateToCase">
          <view class="waterfall-card-cover" wx:if="{{item.cover}}">
            <safe-image className="wfall-cover" src="{{item.cover || ''}}" mode="aspectFill" />
          </view>
          <view class="waterfall-card-body">
            <text class="wfall-tag">{{item.tag}}</text>
            <text class="wfall-title">{{item.title}}</text>
            <text class="wfall-desc">{{item.result}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="section" wx:if="{{newsList.length}}">
    <view class="section-header">
      <text class="title">最新资讯</text>
      <text class="more" bindtap="navigateToNews">更多 ></text>
    </view>
    <view class="waterfall-list">
      <block wx:for="{{newsList}}" wx:key="id">
        <news-card
          id="{{item.id}}"
          category="{{item.category}}"
          title="{{item.title}}"
          cover="{{item.cover || ''}}"
          date="{{item.date}}"
          views="{{item.views}}"
          bind:cardtap="navigateToNewsDetail"
        />
      </block>
    </view>
  </view>

  <view class="section" wx:if="{{demandList.length}}">
    <view class="section-header">
      <text class="title">精选需求</text>
      <text class="more" bindtap="navigateToDemand">去发布 ></text>
    </view>
    <view class="waterfall-list">
      <block wx:for="{{demandList}}" wx:key="id">
        <view class="waterfall-card glass-card" data-id="{{item.id}}" bindtap="navigateToDemandDetail">
          <view class="waterfall-card-cover" wx:if="{{item.cover}}">
            <safe-image className="wfall-cover" src="{{item.cover || ''}}" mode="aspectFill" />
          </view>
          <view class="waterfall-card-body">
            <text class="wfall-tag">{{item.type === 'funding' ? '找资金' : '供资金'}}</text>
            <text class="wfall-title">{{item.title}}</text>
            <text class="wfall-desc">{{item.amount}} · {{item.period}} · {{item.city}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="compliance-tip">本平台仅提供金融信息咨询与居间撮合服务，不发放贷款</view>
</view>
