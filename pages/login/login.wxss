.login-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(160deg, #0a2e1f 0%, #0F3D2E 30%, #1a5c42 60%, #0d3524 100%);
  background-size: 400% 400%;
  animation: gradient-shift 12s ease-in-out infinite;
}

/* ===== 背景遮罩 - 光晕效果 ===== */
.login-mask {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 50% 0%, rgba(212, 168, 75, 0.1) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 80%, rgba(212, 168, 75, 0.04) 0%, transparent 50%),
    radial-gradient(ellipse at 20% 50%, rgba(255, 255, 255, 0.02) 0%, transparent 40%);
  pointer-events: none;
}

/* ===== 装饰性粒子 ===== */
.particle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  opacity: 0;
}

.particle-1 {
  width: 6rpx;
  height: 6rpx;
  top: 20%;
  left: 15%;
  background: rgba(212, 168, 75, 0.6);
  animation: particle-float 6s ease-in-out infinite;
  animation-delay: 0s;
}

.particle-2 {
  width: 4rpx;
  height: 4rpx;
  top: 35%;
  left: 75%;
  background: rgba(255, 255, 255, 0.5);
  animation: particle-float 8s ease-in-out infinite;
  animation-delay: 1.5s;
}

.particle-3 {
  width: 8rpx;
  height: 8rpx;
  top: 55%;
  left: 25%;
  background: rgba(212, 168, 75, 0.4);
  animation: particle-float 7s ease-in-out infinite;
  animation-delay: 3s;
}

.particle-4 {
  width: 3rpx;
  height: 3rpx;
  top: 70%;
  left: 65%;
  background: rgba(255, 255, 255, 0.4);
  animation: particle-float 9s ease-in-out infinite;
  animation-delay: 2s;
}

.particle-5 {
  width: 5rpx;
  height: 5rpx;
  top: 15%;
  left: 55%;
  background: rgba(212, 168, 75, 0.5);
  animation: particle-float 7.5s ease-in-out infinite;
  animation-delay: 4.5s;
}

/* 装饰性菱形 */
.deco-gem {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  pointer-events: none;
  opacity: 0.15;
}

.deco-gem-1 {
  top: 28%;
  right: 18%;
  background: rgba(212, 168, 75, 0.3);
  transform: rotate(45deg);
  animation: gem-spin 20s linear infinite;
}

.deco-gem-2 {
  bottom: 30%;
  left: 12%;
  width: 14rpx;
  height: 14rpx;
  background: rgba(255, 255, 255, 0.2);
  transform: rotate(45deg);
  animation: gem-spin 25s linear infinite reverse;
}

/* ===== 内容容器（flex space-between 与欢迎页一致） ===== */
.login-content {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  padding: 100rpx 40rpx 48rpx;
  box-sizing: border-box;
}

/* ===== 顶部徽章 ===== */
.login-top {
  flex-shrink: 0;
  animation: fadeInDown 0.8s ease-out;
}

.premium-badge {
  display: inline-block;
  font-size: 22rpx;
  color: #D4A84B;
  background: rgba(212, 168, 75, 0.12);
  padding: 10rpx 36rpx;
  border-radius: 999rpx;
  letter-spacing: 2rpx;
  font-weight: 500;
  border: 1rpx solid rgba(212, 168, 75, 0.25);
  backdrop-filter: blur(4rpx);
  -webkit-backdrop-filter: blur(4rpx);
  animation: badge-glow 3s ease-in-out infinite;
}

/* ===== 中间品牌区（与欢迎页完全一致的比例和动效） ===== */
.login-middle {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  justify-content: center;
  padding: 20rpx 0;
  animation: fadeInUp 1s ease-out 0.3s both;
}

.brand-logo-wrap {
  position: relative;
  margin-bottom: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-logo {
  width: 180rpx;
  height: 180rpx;
  line-height: 180rpx;
  text-align: center;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #D4A84B, #e8c878);
  color: #0F3D2E;
  font-size: 72rpx;
  font-weight: 800;
  position: relative;
  z-index: 2;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.35);
  animation: logo-float 4s ease-in-out infinite;
}

.logo-ring {
  position: absolute;
  border-radius: 48rpx;
  border: 2rpx solid rgba(212, 168, 75, 0.3);
  z-index: 1;
}

.ring-outer {
  inset: -16rpx;
  animation: ring-expand 3s ease-in-out infinite;
}

.ring-inner {
  inset: -6rpx;
  border-color: rgba(212, 168, 75, 0.15);
  border-width: 1.5rpx;
  animation: ring-expand 3s ease-in-out infinite 0.5s reverse;
}

.logo-glow-spot {
  position: absolute;
  width: 240rpx;
  height: 240rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(212, 168, 75, 0.12) 0%, transparent 60%);
  border-radius: 50%;
  z-index: 0;
  animation: glow-spot-pulse 3s ease-in-out infinite;
}

.brand-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 8rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.25);
  background: linear-gradient(90deg, #fff 0%, #D4A84B 50%, #fff 100%);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer-text 4s ease-in-out infinite;
}

.divider-gold {
  width: 80rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #D4A84B, #F5D97E, #D4A84B);
  background-size: 200% 100%;
  border-radius: 2rpx;
  margin: 0 auto 24rpx;
  animation: shimmer-divider 3s ease-in-out infinite;
}

.brand-slogan {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
  text-align: center;
  letter-spacing: 2rpx;
}

/* ===== 底部登录卡片 ===== */
.login-bottom {
  flex-shrink: 0;
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 36rpx 32rpx 28rpx;
  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, 0.04),
    0 12rpx 48rpx rgba(0, 0, 0, 0.08),
    0 24rpx 80rpx rgba(0, 0, 0, 0.04);
  animation: fadeInUp 1s ease-out 0.6s both;
  position: relative;
  overflow: hidden;
}

.login-bottom::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #D4A84B, #e8c878, #D4A84B, transparent);
  opacity: 0.6;
}

/* --- 切换 Tab --- */
.auth-type {
  display: flex;
  background: #f0f2f5;
  border-radius: 999rpx;
  padding: 6rpx;
  margin-bottom: 32rpx;
  position: relative;
}

.auth-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 999rpx;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  font-weight: 500;
  position: relative;
  z-index: 1;
}

.auth-tab.active {
  background: #0F3D2E;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(15, 61, 46, 0.3);
}

.tab-hover {
  opacity: 0.7;
}

/* --- 微信登录提示 --- */
.wechat-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 28rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #f0faf4, #f8faf9);
  border-radius: 20rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.08);
}

.wechat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(7, 193, 96, 0.1);
  border-radius: 50%;
  margin-bottom: 14rpx;
  animation: icon-bounce 2s ease-in-out infinite;
}

.wechat-icon {
  font-size: 36rpx;
}

.wechat-desc {
  font-size: 26rpx;
  color: #888;
}

/* --- 登录按钮 --- */
.auth-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  border-radius: 48rpx;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  letter-spacing: 4rpx;
  transition: all 0.3s ease;
  border: none;
  position: relative;
  overflow: hidden;
}

.auth-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
  transition: left 0.6s ease;
}

.auth-btn:active::after {
  left: 100%;
}

.auth-btn:active {
  transform: scale(0.97);
}

.primary-btn {
  background: linear-gradient(135deg, #0F3D2E, #1a6b4a);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(15, 61, 46, 0.3);
}

.primary-btn:active {
  box-shadow: 0 4rpx 12rpx rgba(15, 61, 46, 0.2);
}

.wechat-btn {
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.wechat-btn:active {
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2);
}

/* --- 输入框 --- */
.field-group {
  position: relative;
  margin-bottom: 24rpx;
}

.field-input {
  width: 100%;
  height: 92rpx;
  background: #f5f7fa;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.field-input::placeholder {
  color: #bbb;
  transition: color 0.3s ease;
}

.field-input:focus {
  border-color: #0F3D2E;
  background: #fff;
  box-shadow: 0 0 0 6rpx rgba(15, 61, 46, 0.08);
}

.field-input:focus::placeholder {
  color: #d0d0d0;
}

.code-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.code-field {
  flex: 1;
  margin-bottom: 0;
}

.code-btn {
  background: linear-gradient(135deg, #0F3D2E, #1a6b4a) !important;
  color: #fff !important;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 16rpx !important;
  min-width: 190rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  border: none !important;
  box-shadow: 0 4rpx 12rpx rgba(15, 61, 46, 0.2) !important;
  overflow: hidden;
  position: relative;
}

.code-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

/* ===== 协议区域 ===== */
.agree-section {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.agree-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #999;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.on {
  background: #0F3D2E;
  border-color: #0F3D2E;
  transform: scale(1.05);
  box-shadow: 0 2rpx 8rpx rgba(15, 61, 46, 0.25);
}

.checkmark {
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  animation: check-pop 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.agree-text {
  line-height: 1.5;
  color: #999;
}

.link {
  color: #0F3D2E;
  font-weight: 600;
  position: relative;
}

.link::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 0;
  width: 100%;
  height: 1rpx;
  background: #0F3D2E;
  transform: scaleX(0);
  transform-origin: right;
  transition: transform 0.3s ease;
}

.link:active::after {
  transform: scaleX(1);
  transform-origin: left;
}

/* ===== 底部链接 ===== */
.login-footer-links {
  text-align: center;
  margin-top: 24rpx;
}

.guest-link {
  display: inline-block;
  font-size: 28rpx;
  color: #0F3D2E;
  margin-bottom: 16rpx;
  padding: 14rpx 40rpx;
  border: 1.5rpx solid rgba(15, 61, 46, 0.3);
  border-radius: 999rpx;
  background: rgba(15, 61, 46, 0.04);
  font-weight: 500;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.guest-link:active {
  background: rgba(15, 61, 46, 0.1);
  transform: scale(0.97);
}

.compliance-mini {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  line-height: 1.5;
}

/* ===== 关键帧动画 ===== */
@keyframes gradient-shift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes particle-float {
  0%, 100% {
    opacity: 0;
    transform: translateY(0) scale(1);
  }
  20% {
    opacity: 1;
  }
  50% {
    transform: translateY(-80rpx) scale(1.5);
  }
  80% {
    opacity: 0.6;
  }
}

@keyframes gem-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes logo-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes glow-spot-pulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
  50% { transform: translate(-50%, -50%) scale(1.15); opacity: 0.8; }
}

@keyframes ring-expand {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.08); opacity: 1; }
}

@keyframes shimmer-text {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

@keyframes shimmer-divider {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

@keyframes badge-glow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(212, 168, 75, 0); }
  50% { box-shadow: 0 0 20rpx 4rpx rgba(212, 168, 75, 0.15); }
}

@keyframes icon-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

@keyframes check-pop {
  0% { transform: scale(0); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
