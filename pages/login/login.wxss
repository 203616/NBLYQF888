.login-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.login-bg {
  position: absolute;
  inset: 0;
}

.login-bg-img {
  width: 100%;
  height: 100%;
}

.login-bg-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(15,61,46,0.85) 0%, rgba(15,61,46,0.95) 55%, #f7f9fc 55%);
}

.login-body {
  position: relative;
  z-index: 1;
  padding: 80rpx 40rpx 48rpx;
}

.brand-block {
  text-align: center;
  color: #fff;
  margin-bottom: 48rpx;
}

.brand-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
}

.brand-name {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-top: 20rpx;
  letter-spacing: 4rpx;
}

.brand-tag {
  display: block;
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 12rpx;
}

.login-card {
  padding: 36rpx 32rpx;
  background: #fff;
}

.auth-type {
  display: flex;
  background: var(--color-primary-bg);
  border-radius: 999rpx;
  padding: 6rpx;
  margin-bottom: 32rpx;
}

.auth-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border-radius: 999rpx;
}

.auth-tab.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

.auth-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #f5f7fa;
  border-radius: var(--radius-md);
  padding: 0 28rpx;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.code-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.code-row .code {
  flex: 1;
  margin-bottom: 0;
}

.code-btn {
  background: var(--color-primary) !important;
  color: #fff !important;
  height: 88rpx;
  line-height: 88rpx;
}

.agree-section {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.agree-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border: 2rpx solid var(--color-primary);
  border-radius: 6rpx;
  margin-right: 12rpx;
  font-size: 20rpx;
  flex-shrink: 0;
}

.checkbox.on {
  background: var(--color-primary);
  color: #fff;
}

.link {
  color: var(--color-primary);
}

.loc-mini {
  font-size: 24rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  margin-top: 8rpx;
}

.guest-row {
  text-align: center;
  margin-top: 32rpx;
}

.guest-link {
  font-size: 26rpx;
  color: var(--color-primary);
}

.compliance-tip {
  text-align: center;
  margin-top: 32rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}
