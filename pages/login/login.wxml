<view class="login-page">
  <view class="login-bg">
    <safe-image className="login-bg-img" src="/images/banner1.webp" mode="aspectFill" />
    <view class="login-bg-mask"></view>
  </view>

  <view class="login-body">
    <view class="brand-block">
      <image class="brand-logo" src="/images/logo.webp" mode="aspectFit" />
      <text class="brand-name">亮叶企服</text>
      <text class="brand-tag">金融信息咨询与居间撮合平台</text>
    </view>

    <view class="login-card glass-card">
      <view class="auth-type">
        <view class="auth-tab {{authType=='wechat' ? 'active' : ''}}" data-type="wechat" bindtap="switchAuthType">微信登录</view>
        <view class="auth-tab {{authType=='phone' ? 'active' : ''}}" data-type="phone" bindtap="switchAuthType">手机登录</view>
      </view>

      <block wx:if="{{authType === 'wechat'}}">
        <button class="auth-btn primary-btn" loading="{{loggingIn}}" disabled="{{loggingIn}}" bindtap="handleWechatAuth">微信一键登录</button>
      </block>
      <block wx:else>
        <input class="field-input" type="number" maxlength="11" placeholder="手机号" value="{{phone}}" bindinput="onPhoneInput" />
        <view class="code-row">
          <input class="field-input code" type="number" maxlength="6" placeholder="验证码" value="{{smsCode}}" bindinput="onCodeInput" />
          <button class="code-btn" size="mini" disabled="{{codeSending}}" bindtap="sendSmsCode">{{codeText}}</button>
        </view>
        <button class="auth-btn primary-btn" loading="{{loggingIn}}" disabled="{{loggingIn}}" bindtap="handlePhoneLogin">登录</button>
      </block>

      <view class="agree-section">
        <view class="agree-row" bindtap="togglePrivacy">
          <text class="checkbox {{agreedPrivacy ? 'on' : ''}}">{{agreedPrivacy ? '✓' : ''}}</text>
          <text>同意 <text class="link" catchtap="viewPrivacy">《隐私政策》</text></text>
        </view>
        <view class="agree-row" bindtap="toggleService">
          <text class="checkbox {{agreedService ? 'on' : ''}}">{{agreedService ? '✓' : ''}}</text>
          <text>同意 <text class="link" catchtap="viewService">《用户服务协议》</text></text>
        </view>
        <view class="agree-row" bindtap="toggleLocationAgree">
          <text class="checkbox {{agreedLocation ? 'on' : ''}}">{{agreedLocation ? '✓' : ''}}</text>
          <text>同意获取位置信息（{{locationCity || '用于本地服务展示'}}）</text>
        </view>
        <button class="loc-mini btn-outline" bindtap="authorizeLocation" wx:if="{{!locationCity}}">立即定位</button>
      </view>
    </view>

    <view class="guest-row">
      <text class="guest-link" bindtap="guestEnter">暂不登录，先逛逛</text>
    </view>

    <view class="compliance-tip">
      <text>本平台不从事放贷业务，不承诺任何机构审批结果</text>
    </view>
  </view>
</view>
