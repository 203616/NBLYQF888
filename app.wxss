@import "./styles/tokens.wxss";
@import "./styles/premium.wxss";

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  background-color: var(--color-bg-page);
  color: var(--color-text-primary);
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

.iconfont {
  font-family: -apple-system, BlinkMacSystemFont !important;
  font-style: normal;
  font-size: inherit;
}

.icon-oa:before { content: "📋"; }
.icon-demand:before { content: "📝"; }
.icon-folder:before { content: "📁"; }
.icon-setting:before { content: "⚙️"; }
.icon-notice:before { content: "🔔"; }
.icon-heart:before { content: "♥"; }
.icon-right:before { content: "›"; }
.icon-more:before { content: "⋯"; }

.page-shell {
  min-height: 100vh;
  padding: var(--space-lg);
  padding-bottom: var(--page-bottom-padding);
  background: var(--color-bg-page);
  box-sizing: border-box;
}

.page-safe {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.fixed-bottom-safe {
  padding-bottom: calc(constant(safe-area-inset-bottom) + 24rpx);
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

.location-bar {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 18rpx 24rpx;
  margin-bottom: 20rpx;
  color: var(--color-primary);
  font-size: 26rpx;
  box-shadow: var(--shadow-card);
}

.location-bar .loc-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.hero-card {
  background: var(--gradient-hero);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
  box-shadow: var(--shadow-hero);
}

.hero-card .hero-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
}

.hero-card .hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.88);
}

.search-bar {
  height: 80rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.search-bar input {
  flex: 1;
  font-size: 28rpx;
}

.filter-pill {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  white-space: nowrap;
  border-radius: var(--radius-pill);
  margin-right: 16rpx;
  background: var(--color-bg-card);
  box-shadow: var(--shadow-card);
}

.filter-pill.active {
  background: var(--color-primary);
  color: #fff;
}

.list-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
}

.cover-thumb {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: var(--color-primary-bg);
}

.risk-high { background: #f5222d; color: #fff; }
.risk-medium { background: #faad14; color: #fff; }
.risk-low { background: #52c41a; color: #fff; }

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.text-ellipsis {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

button {
  border-radius: var(--radius-pill);
  font-size: 32rpx;
  padding: 0 30rpx;
}

.primary-btn {
  background: var(--color-primary);
  color: white;
  box-shadow: 0 4rpx 8rpx rgba(15,61,46,0.28);
}

.page-container {
  min-height: 100vh;
  padding: var(--space-lg);
  background: var(--color-bg-page);
  box-sizing: border-box;
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  box-shadow: var(--shadow-card);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-md);
}

.section-header .title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.section-header .more {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
}

.tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-lg);
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: 24rpx;
}

.empty-state {
  padding: 100rpx 0;
  text-align: center;
  color: var(--color-text-muted);
}

.compliance-tip {
  padding: 20rpx;
  background: #f9f9f9;
  color: var(--color-text-muted);
  font-size: 24rpx;
  text-align: center;
  border-radius: 12rpx;
  margin: 20rpx 0;
}

.sensitive-data {
  filter: blur(10rpx);
  transition: filter 0.3s;
  cursor: pointer;
}
.sensitive-data.active {
  filter: none;
}

@media (max-width: 480px) {
  button {
    font-size: 28rpx;
    padding: 0 20rpx;
  }
}
