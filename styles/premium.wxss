/* 亮叶企服 — 高级 UI 组件库 */

.glass-card {
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 8rpx 32rpx rgba(15, 61, 46, 0.08);
}

.premium-hero {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 24rpx;
  min-height: 280rpx;
  background: var(--gradient-hero);
  box-shadow: var(--shadow-hero);
}

.premium-hero-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  opacity: 0.25;
  display: block;
}

.premium-hero-body {
  position: relative;
  z-index: 1;
  padding: 36rpx 32rpx;
  color: #fff;
}

.premium-hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.premium-hero-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.9);
}

.premium-badge {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(212, 168, 75, 0.9);
  color: #0F3D2E;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.feature-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 28rpx 24rpx;
  box-shadow: var(--shadow-card);
  text-align: center;
}

.feature-item .feat-icon {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 16rpx;
  border-radius: 16rpx;
  background: var(--color-primary-bg);
}

.feature-item .feat-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.feature-item .feat-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
  line-height: 1.5;
}

.btn-gold {
  background: linear-gradient(135deg, #D4A84B, #E8C56A);
  color: #0F3D2E;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(212, 168, 75, 0.35);
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.stat-row {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.divider-gold {
  height: 4rpx;
  width: 60rpx;
  background: var(--color-gold);
  border-radius: 2rpx;
  margin: 16rpx auto;
}

.intake-system-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.view-only-banner {
  background: #f0f7f4;
  border-left: 6rpx solid var(--color-primary);
  padding: 20rpx 24rpx;
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}
