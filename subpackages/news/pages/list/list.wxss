.news-page {
  padding-bottom: 40rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Search ===== */
.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 20rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-pill);
  box-shadow: var(--shadow-card);
}

.search-bar input {
  flex: 1;
  font-size: 28rpx;
}

/* ===== News Card ===== */
.news-card {
  display: flex;
  overflow: hidden;
  margin-bottom: 16rpx;
  padding: 0 !important;
}

.cover {
  width: 200rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.news-body {
  flex: 1;
  padding: 20rpx;
  min-width: 0;
}

.category {
  font-size: 22rpx;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.news-body .title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 10rpx;
  color: var(--color-text-primary);
}

.summary {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.news-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}
