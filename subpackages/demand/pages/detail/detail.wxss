.demand-detail {
  padding-bottom: 160rpx;
}

.detail-hero {
  margin-bottom: 20rpx;
  min-height: 220rpx;
  background: var(--gradient-hero);
  border-radius: var(--radius-lg);
  overflow: hidden;
  position: relative;
}

.hero-cover {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  opacity: 0.25;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(255,255,255,0.2);
  color: #fff;
  border-radius: 999rpx;
}

.material-item {
  display: flex;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  padding: 8rpx 0;
}

.material-dot {
  color: var(--color-primary);
}

.muted {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.compliance {
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  background: #fff9e9;
}

.status-tag {
  display: inline-block;
  margin-top: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(212, 168, 75, 0.9);
  color: var(--color-primary);
  font-size: 22rpx;
}

.meta-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.meta-card {
  text-align: center;
  padding: 24rpx;
}

.meta-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.meta-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-top: 8rpx;
}

.section {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid #D4A84B;
}

.progress {
  height: 12rpx;
  background: #edf2ef;
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-inner {
  height: 100%;
  background: var(--gradient-hero);
}

.step {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.step:last-child {
  border-bottom: none;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #d9d9d9;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.step.done .dot {
  background: var(--color-primary);
}

.step-title, .product-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.step-desc, .product-desc, .paragraph {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
  line-height: 1.5;
}

.product-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-row:last-child {
  border-bottom: none;
}

.rate {
  color: var(--color-primary);
  font-weight: 600;
  font-size: 26rpx;
  flex-shrink: 0;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -4rpx 24rpx rgba(15, 61, 46, 0.08);
}

.action-bar button {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  margin: 0;
  padding: 0;
}
