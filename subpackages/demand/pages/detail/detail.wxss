.demand-detail {
  padding-bottom: 160rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Hero ===== */
.premium-hero {
  margin-bottom: 20rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.tag-row .tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 999rpx;
}

.status-tag {
  display: inline-block;
  margin-top: 8rpx;
  margin-left: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(212, 168, 75, 0.9);
  color: var(--color-primary);
  font-size: 22rpx;
  vertical-align: middle;
}

/* ===== Meta Row ===== */
.meta-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.meta-card {
  text-align: center;
  padding: 24rpx;
}

.meta-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.meta-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-top: 8rpx;
}

/* ===== Section ===== */
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid var(--color-gold);
}

/* ===== Progress ===== */
.progress {
  height: 12rpx;
  background: #edf2ef;
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-inner {
  height: 100%;
  background: var(--gradient-hero);
  border-radius: 999rpx;
}

/* ===== Steps ===== */
.step {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.step:last-child {
  border-bottom: none;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #d9d9d9;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.step.done .dot {
  background: var(--color-primary);
}

.step-title,
.product-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.step-desc,
.product-desc,
.paragraph {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
  line-height: 1.5;
}

.paragraph.muted {
  margin-top: 8rpx;
  font-size: 22rpx;
}

/* ===== Material ===== */
.material-item {
  display: flex;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  padding: 8rpx 0;
}

.material-dot {
  color: var(--color-primary);
}

/* ===== Compliance ===== */
.compliance {
  padding: 20rpx var(--space-md);
  margin-bottom: 20rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  background: #fff9e9;
  border-left: 6rpx solid var(--color-gold);
  border-radius: var(--radius-md);
}

/* ===== Product Row ===== */
.product-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-row:last-child {
  border-bottom: none;
}

.rate {
  color: var(--color-primary);
  font-weight: 600;
  font-size: 26rpx;
  flex-shrink: 0;
}

/* ===== Action Bar ===== */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx var(--space-md) calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -4rpx 24rpx rgba(15, 61, 46, 0.08);
}

.action-bar button {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  margin: 0;
  padding: 0;
}

.demand-detail .card {
  margin-bottom: 20rpx;
}
