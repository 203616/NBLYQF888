@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.region-page {
  padding-bottom: 40rpx;
}

.region-hero,
.location-bar,
.province-tabs,
.current-card,
.district-header,
.source-card,
.region-card,
.section,
.empty-hint {
  animation: fadeInUp 0.5s ease both;
}

.region-hero {
  margin-bottom: 20rpx;
  min-height: 200rpx;
}

.location-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: var(--space-md) 28rpx;
  margin: 0 var(--space-md) var(--space-sm);
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.loc-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.loc-arrow {
  margin-left: auto;
  color: var(--color-text-muted);
  font-size: 32rpx;
}

.current-card,
.source-card,
.region-card,
.district-header {
  padding: var(--space-md) 28rpx;
  margin: 0 var(--space-md) var(--space-sm);
}

.current-title,
.region-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: var(--space-sm);
}

.metric-item {
  text-align: center;
  padding: var(--space-sm);
  background: var(--color-bg-page);
  border-radius: 12rpx;
}

.metric-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.metric-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.source-card {
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.8;
}

.region-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.region-drill {
  font-size: 22rpx;
  color: var(--color-primary);
  flex-shrink: 0;
}

.region-source {
  display: block;
  font-size: 20rpx;
  color: #aaa;
  margin-top: 12rpx;
}

.bar {
  height: 12rpx;
  background: #edf2ef;
  border-radius: 999rpx;
  overflow: hidden;
  margin: var(--space-sm) 0;
}

.bar-inner {
  height: 100%;
  background: var(--gradient-hero);
}

.district-bar {
  background: linear-gradient(90deg, var(--color-primary), var(--color-gold));
}

.province-tabs {
  display: flex;
  white-space: nowrap;
  padding: var(--space-sm) 20rpx;
  margin: 0 var(--space-md) var(--space-sm);
}

.tab-item {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  font-size: 26rpx;
  color: var(--color-text-muted);
  border-radius: 999rpx;
  background: var(--color-bg-page);
}

.tab-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

.back-link {
  display: block;
  font-size: 26rpx;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.section {
  padding: var(--space-md) 28rpx;
  margin: 0 var(--space-md) var(--space-sm);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: var(--space-sm);
  padding-left: 14rpx;
  border-left: 6rpx solid var(--color-gold);
}

.source-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.source-item:last-child {
  border-bottom: none;
}

.source-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.source-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.source-link {
  font-size: 22rpx;
  color: var(--color-primary);
  flex-shrink: 0;
}

.empty-hint {
  text-align: center;
  padding: 40rpx;
  color: var(--color-text-muted);
  font-size: 26rpx;
  margin: 0 var(--space-md);
}

.page-safe {
  height: calc(env(safe-area-inset-bottom) + 20rpx);
}
