.region-page { padding-bottom: 40rpx; }
.region-hero { margin-bottom: 20rpx; min-height: 200rpx; }
.loc-arrow { margin-left: auto; color: #ccc; font-size: 32rpx; }
.current-card, .source-card, .region-card, .district-header { padding: 24rpx 28rpx; margin-bottom: 16rpx; }
.current-title, .region-name { display: block; font-size: 30rpx; font-weight: 700; color: var(--color-primary); }
.metric-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; margin-top: 16rpx; }
.metric-item { text-align: center; padding: 16rpx; background: #f7f9fc; border-radius: 12rpx; }
.metric-value { display: block; font-size: 36rpx; font-weight: 700; color: var(--color-primary); }
.metric-label { display: block; font-size: 22rpx; color: var(--color-text-muted); margin-top: 4rpx; }
.source-card { font-size: 24rpx; color: var(--color-text-muted); line-height: 1.8; }
.region-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 12rpx; }
.region-drill { font-size: 22rpx; color: var(--color-primary); flex-shrink: 0; }
.region-source { display: block; font-size: 20rpx; color: #aaa; margin-top: 12rpx; }
.bar { height: 12rpx; background: #edf2ef; border-radius: 999rpx; overflow: hidden; margin: 16rpx 0; }
.bar-inner { height: 100%; background: var(--gradient-hero); }
.district-bar { background: linear-gradient(90deg, #0F3D2E, #D4A84B); }
.province-tabs { display: flex; white-space: nowrap; padding: 16rpx 20rpx; margin-bottom: 16rpx; }
.tab-item { display: inline-block; padding: 10rpx 24rpx; margin-right: 12rpx; font-size: 26rpx; color: var(--color-text-muted); border-radius: 999rpx; background: #f7f9fc; }
.tab-item.active { background: var(--color-primary); color: #fff; font-weight: 600; }
.back-link { display: block; font-size: 26rpx; color: var(--color-primary); margin-bottom: 8rpx; }
.section { padding: 24rpx 28rpx; margin-bottom: 16rpx; }
.section-title { display: block; font-size: 28rpx; font-weight: 700; color: var(--color-primary); margin-bottom: 16rpx; }
.source-item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.source-item:last-child { border-bottom: none; }
.source-name { display: block; font-size: 26rpx; font-weight: 600; }
.source-desc { display: block; font-size: 22rpx; color: var(--color-text-muted); margin-top: 4rpx; }
.source-link { font-size: 22rpx; color: var(--color-primary); flex-shrink: 0; }
.empty-hint { text-align: center; padding: 40rpx; color: #999; font-size: 26rpx; }
