.report-page { padding-bottom: 40rpx; }
.report-hero { margin-bottom: 20rpx; min-height: 160rpx; background: linear-gradient(135deg, #5C1A1A, #8B2635); border-radius: var(--radius-lg); }
.tips { padding: 20rpx 24rpx; margin-bottom: 20rpx; font-size: 24rpx; color: var(--color-text-muted); line-height: 1.8; }
.tips-title { display: block; font-size: 28rpx; font-weight: 600; color: var(--color-primary); margin-bottom: 10rpx; }
.form-card { padding: 28rpx; }
.field { padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.field.column { display: block; }
.label { display: block; font-size: 28rpx; color: var(--color-text-primary); margin-bottom: 12rpx; }
.field input, .picker { font-size: 28rpx; color: var(--color-text-primary); }
.field textarea { width: 100%; min-height: 160rpx; background: #f7f9fc; border-radius: 12rpx; padding: 16rpx; box-sizing: border-box; font-size: 26rpx; }
.upload-area { display: flex; flex-wrap: wrap; gap: 12rpx; }
.upload-item { position: relative; width: 160rpx; height: 160rpx; }
.preview { width: 100%; height: 100%; border-radius: 12rpx; }
.remove { position: absolute; top: -8rpx; right: -8rpx; width: 36rpx; height: 36rpx; line-height: 36rpx; text-align: center; background: #f5222d; color: #fff; border-radius: 50%; font-size: 24rpx; }
.upload-btn { width: 160rpx; height: 160rpx; border: 2rpx dashed #ddd; border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 22rpx; color: #999; }
.add-icon { font-size: 48rpx; color: var(--color-text-muted); }
.submit-btn { margin-top: 28rpx; width: 100%; height: 88rpx; line-height: 88rpx; border-radius: 999rpx; }
