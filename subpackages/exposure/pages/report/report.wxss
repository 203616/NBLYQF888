.report-page {
  padding-bottom: 40rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Tips ===== */
.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 10rpx;
}

.tip-line {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.8;
}

/* ===== Form Fields ===== */
.field {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.field:last-of-type {
  border-bottom: none;
}

.field.column {
  display: block;
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.field .field-input,
.picker {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.field .field-textarea {
  width: 100%;
  min-height: 160rpx;
  background: var(--color-bg-page);
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 26rpx;
}

/* ===== Upload Area ===== */
.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.upload-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.preview {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: var(--color-danger);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  z-index: 1;
}

.upload-btn {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
  background: var(--color-bg-page);
}

.add-icon {
  font-size: 48rpx;
  color: var(--color-text-muted);
}

/* ===== Submit ===== */
.submit-btn {
  margin-top: 28rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: none;
}
