.exposure-detail {
  padding-bottom: 160rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Section Title ===== */
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid var(--color-gold);
}

/* ===== Meta ===== */
.meta-date {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 12rpx;
}

/* ===== Rich Content ===== */
.rich-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--color-text-primary);
}

/* ===== Evidence ===== */
.evidence-scroll {
  white-space: nowrap;
}

.evidence-img {
  display: inline-block;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
}

/* ===== Progress ===== */
.progress-item {
  display: flex;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.progress-item:last-child {
  border-bottom: none;
}

.progress-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-top: 8rpx;
  flex-shrink: 0;
}

.progress-date {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.progress-action {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* ===== Related Cards ===== */
.related-card {
  background: var(--color-bg-page);
  border-radius: 14rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
}

.related-card:last-child {
  margin-bottom: 0;
}

.related-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.related-desc,
.related-meta {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

/* ===== Action Bar ===== */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx var(--space-md) calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -4rpx 24rpx rgba(15, 61, 46, 0.08);
}

.action-bar button {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  margin: 0;
  padding: 0;
}

.exposure-detail .card {
  margin-bottom: 20rpx;
}
