.exposure-detail { padding-bottom: 160rpx; }
.detail-hero { margin-bottom: 20rpx; min-height: 180rpx; background: linear-gradient(135deg, #5C1A1A, #8B2635); border-radius: var(--radius-lg); }
.section { padding: 24rpx 28rpx; margin-bottom: 20rpx; }
.section-title { display: block; font-size: 30rpx; font-weight: 700; color: var(--color-primary); margin-bottom: 16rpx; padding-left: 14rpx; border-left: 6rpx solid #D4A84B; }
.meta-date { display: block; font-size: 24rpx; color: var(--color-text-muted); margin-bottom: 12rpx; }
.rich-content { font-size: 28rpx; line-height: 1.8; color: var(--color-text-primary); }
.evidence-scroll { white-space: nowrap; }
.evidence-img { display: inline-block; width: 200rpx; height: 200rpx; border-radius: 12rpx; margin-right: 12rpx; }
.progress-item { display: flex; gap: 14rpx; padding: 14rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.progress-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: var(--color-primary); margin-top: 8rpx; flex-shrink: 0; }
.progress-date { display: block; font-size: 26rpx; font-weight: 600; color: var(--color-text-primary); }
.progress-action { display: block; font-size: 24rpx; color: var(--color-text-muted); margin-top: 4rpx; }
.related-card { background: #f7f9fc; border-radius: 14rpx; padding: 20rpx; margin-bottom: 14rpx; }
.related-title { display: block; font-size: 28rpx; font-weight: 600; color: var(--color-primary); }
.related-desc, .related-meta { display: block; font-size: 24rpx; color: var(--color-text-muted); margin-top: 6rpx; }
.action-bar { position: fixed; left: 0; right: 0; bottom: 0; display: flex; gap: 16rpx; padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom)); background: rgba(255,255,255,0.98); box-shadow: 0 -4rpx 24rpx rgba(15,61,46,0.08); }
.action-bar button { flex: 1; height: 84rpx; line-height: 84rpx; border-radius: 999rpx; margin: 0; padding: 0; }
.loading { text-align: center; padding: 120rpx; color: var(--color-text-muted); }
