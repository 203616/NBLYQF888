.exposure-page { padding-bottom: 40rpx; }
.exp-hero { margin-bottom: 20rpx; min-height: 240rpx; position: relative; }
.hero-btn { margin-top: 16rpx; background: #fff; color: var(--color-primary); border-radius: 999rpx; font-size: 26rpx; height: 64rpx; line-height: 64rpx; padding: 0 32rpx; display: inline-block; }
.stat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; margin-bottom: 20rpx; }
.stat-item { text-align: center; padding: 20rpx 8rpx; }
.stat-num { display: block; font-size: 32rpx; font-weight: 700; color: var(--color-primary); }
.stat-label { display: block; font-size: 22rpx; color: var(--color-text-muted); margin-top: 4rpx; }
.filter-scroll { white-space: nowrap; margin-bottom: 20rpx; }
.filter-pill { display: inline-block; font-size: 24rpx; padding: 10rpx 22rpx; border-radius: 999rpx; background: #fff; color: #666; box-shadow: var(--shadow-card); margin-right: 12rpx; }
.filter-pill.active { background: var(--gradient-hero); color: #fff; }
.exposure-card { display: flex; overflow: hidden; margin-bottom: 16rpx; padding: 0; }
.cover-thumb { width: 160rpx; height: 180rpx; flex-shrink: 0; }
.card-body { flex: 1; padding: 20rpx; min-width: 0; }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.type-tag { font-size: 20rpx; color: var(--color-primary); background: var(--color-primary-bg); padding: 4rpx 12rpx; border-radius: 12rpx; }
.status { font-size: 22rpx; font-weight: 600; }
.title { display: block; font-size: 28rpx; font-weight: 700; color: var(--color-text-primary); }
.content { display: block; font-size: 24rpx; color: var(--color-text-muted); margin-top: 8rpx; line-height: 1.5; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
.card-footer { display: flex; justify-content: space-between; margin-top: 12rpx; font-size: 22rpx; color: #aaa; }
.empty-state { text-align: center; padding: 60rpx; font-size: 26rpx; color: var(--color-text-muted); }
