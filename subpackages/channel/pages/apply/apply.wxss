.apply-page {
  padding-bottom: 40rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Steps ===== */
.step-item {
  display: flex;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.step-item:last-child {
  border-bottom: none;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: 22rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.step-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.step-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* ===== Form Fields ===== */
.field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
  gap: 20rpx;
}

.field:last-of-type {
  border-bottom: none;
}

.field.column {
  flex-direction: column;
  align-items: stretch;
}

.label {
  color: var(--color-text-primary);
  flex-shrink: 0;
  min-width: 180rpx;
}

.field input {
  flex: 1;
  text-align: right;
  color: var(--color-text-primary);
  font-size: 28rpx;
}

.field.column textarea {
  width: 100%;
  min-height: 160rpx;
  margin-top: 12rpx;
  background: var(--color-bg-page);
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 26rpx;
}

/* ===== Submit ===== */
.submit-btn {
  margin-top: 28rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: none;
}

.compliance {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  text-align: center;
}
