.case-detail {
  padding-bottom: 160rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Meta Row ===== */
.meta-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.meta-card {
  padding: 20rpx;
  text-align: center;
}

.meta-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.meta-value {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-top: 6rpx;
}

/* ===== Section ===== */
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 12rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid var(--color-gold);
}

.paragraph {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
}

.info-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.info-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border-radius: 999rpx;
}

/* ===== Timeline ===== */
.timeline-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.timeline-item:last-child {
  border-bottom: none;
}

.timeline-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-top: 10rpx;
  flex-shrink: 0;
}

.timeline-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* ===== Compliance ===== */
.compliance {
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  background: #fff9e9;
  border-left: 6rpx solid var(--color-gold);
}

/* ===== Action Bar ===== */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx var(--space-md) calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -4rpx 24rpx rgba(15, 61, 46, 0.08);
}

.action-bar button {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  margin: 0;
  padding: 0;
}

.case-detail .card {
  margin-bottom: 16rpx;
}
