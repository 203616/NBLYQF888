.case-detail {
  padding-bottom: 160rpx;
}

.case-hero {
  min-height: 320rpx;
  margin-bottom: 20rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.meta-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.meta-card {
  padding: 20rpx;
  text-align: center;
}

.meta-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.meta-value {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-top: 6rpx;
}

.section {
  padding: 28rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 12rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid #D4A84B;
}

.paragraph {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
}

.info-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.info-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  background: #f0f5f3;
  color: var(--color-primary);
  border-radius: 999rpx;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.timeline-item:last-child {
  border-bottom: none;
}

.timeline-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-top: 10rpx;
  flex-shrink: 0;
}

.timeline-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.compliance {
  padding: 20rpx 24rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  background: #fff9e9;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -4rpx 24rpx rgba(15, 61, 46, 0.08);
}

.action-bar button {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  margin: 0;
  padding: 0;
}

.loading {
  text-align: center;
  padding: 80rpx;
  color: #999;
}
