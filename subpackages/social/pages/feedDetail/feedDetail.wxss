/* ===== 页面微动效 ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in-up {
  animation: fadeInUp 0.45s ease-out both;
}

.feed-detail {
  padding: var(--space-md);
  padding-bottom: 48rpx;
  background: var(--color-bg-page);
  min-height: 100vh;
}

/* ===== 卡片通用 ===== */
.feed-card,
.intake-panel,
.comment-panel {
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  border-radius: var(--radius-md);
  animation: fadeInUp 0.45s ease-out both;
}

.quick-links,
.compliance-panel {
  animation: fadeInUp 0.45s ease-out both;
}

/* ===== 动态头部 ===== */
.feed-head {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.feed-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e8edf3, #d5dce6);
  flex-shrink: 0;
}

.feed-meta {
  flex: 1;
  min-width: 0;
}

.feed-user {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.feed-time {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 2rpx;
}

/* ===== 动态内容 ===== */
.feed-content {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--color-text-primary);
  margin-bottom: var(--space-md);
}

.feed-images {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.feed-img {
  width: 200rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  background: linear-gradient(135deg, #e8edf3, #d5dce6);
}

/* ===== 动态操作区 ===== */
.feed-actions {
  display: flex;
  gap: 32rpx;
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--color-border);
}

.action-btn {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.action-btn.liked {
  color: var(--color-primary);
  font-weight: 600;
}

/* ===== 面板标题 ===== */
.intake-panel,
.comment-panel {
  border-radius: var(--radius-md);
}

.panel-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: var(--space-md);
  padding-left: 14rpx;
  border-left: 6rpx solid var(--color-gold);
}

.panel-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: var(--space-md);
}

/* ===== 评论 ===== */
.comment-item {
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.comment-user {
  font-weight: 600;
  color: var(--color-primary);
  margin-right: 8rpx;
  font-size: 26rpx;
}

.comment-content {
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.comment-time {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.comment-input-row {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-md);
  align-items: center;
}

.comment-input {
  flex: 1;
  background: var(--color-bg-page);
  border-radius: var(--radius-sm);
  padding: var(--space-sm) var(--space-md);
  font-size: 28rpx;
  min-height: 72rpx;
}

.btn-gold.mini {
  font-size: 26rpx;
  padding: 0 28rpx;
  line-height: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
}

/* ===== 快捷按钮 ===== */
.quick-links {
  display: flex;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.quick-links .btn-outline {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  margin: 0;
}

/* ===== 空状态 ===== */
.empty-tip {
  font-size: 26rpx;
  color: var(--color-text-muted);
  display: block;
  padding: var(--space-md) 0;
  text-align: center;
}

/* ===== 加载 ===== */
.loading-wrap {
  padding: 80rpx;
  text-align: center;
  color: var(--color-text-muted);
  font-size: 28rpx;
}

/* ===== 合规提示 ===== */
.compliance-panel {
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  padding: 0 8rpx;
  margin-bottom: var(--space-md);
}

.page-safe {
  height: calc(env(safe-area-inset-bottom) + 20rpx);
}
