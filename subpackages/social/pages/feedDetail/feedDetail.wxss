.feed-detail {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.feed-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.feed-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.feed-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #eee;
}

.feed-user {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.feed-time {
  font-size: 24rpx;
  color: #999;
}

.feed-content {
  display: block;
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

.feed-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.feed-img {
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
}

.feed-actions {
  display: flex;
  gap: 32rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.action-btn.liked {
  color: var(--color-primary);
  font-weight: 600;
}

.intake-panel,
.comment-panel {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.panel-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

.panel-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.comment-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.comment-user {
  font-weight: 600;
  color: var(--color-primary);
  margin-right: 8rpx;
}

.comment-content {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.comment-time {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 6rpx;
}

.comment-input-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  align-items: center;
}

.comment-input {
  flex: 1;
  background: #f7f9fc;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.btn-gold.mini {
  font-size: 26rpx;
  padding: 0 28rpx;
  line-height: 72rpx;
  height: 72rpx;
}

.quick-links {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.quick-links button {
  flex: 1;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
}

.loading-wrap {
  padding: 80rpx;
  text-align: center;
  color: #999;
}

.compliance-panel {
  font-size: 22rpx;
  color: #999;
  line-height: 1.6;
  padding: 0 8rpx;
}
