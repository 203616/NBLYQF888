.banner-detail {
  padding-bottom: 40rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Banner Image ===== */
.banner-image {
  width: 100%;
  display: block;
  border-radius: var(--radius-lg);
  margin-bottom: 20rpx;
}

/* ===== Content ===== */
.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin: 16rpx 0;
}

.rich-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--color-text-primary);
  margin-bottom: var(--space-md);
}

.highlight-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: var(--space-md);
}

.highlight-row .tag {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

/* ===== Action Button ===== */
.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  margin: 0;
  border: none;
}

/* ===== Section ===== */
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid var(--color-gold);
}

.product-scroll {
  white-space: nowrap;
}

.product-card {
  display: inline-block;
  width: 200rpx;
  margin-right: 16rpx;
  vertical-align: top;
}

.product-image {
  width: 200rpx;
  height: 140rpx;
  border-radius: 12rpx;
  display: block;
}

.product-name {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-primary);
  margin-top: 8rpx;
  white-space: normal;
  line-height: 1.4;
}

.banner-detail .card {
  margin-bottom: 20rpx;
}
