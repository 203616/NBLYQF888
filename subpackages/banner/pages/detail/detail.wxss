.banner-detail { padding-bottom: 40rpx; }
.banner-image { width: 100%; display: block; border-radius: var(--radius-lg); margin-bottom: 20rpx; }
.content-card { padding: 28rpx; margin-bottom: 20rpx; }
.title { display: block; font-size: 36rpx; font-weight: 700; color: var(--color-primary); margin: 16rpx 0; }
.rich-content { font-size: 28rpx; line-height: 1.8; color: var(--color-text-primary); margin-bottom: 24rpx; }
.action-btn { width: 100%; height: 88rpx; line-height: 88rpx; border-radius: 999rpx; margin: 0; }
.section { padding: 24rpx 28rpx; }
.section-title { display: block; font-size: 30rpx; font-weight: 700; color: var(--color-primary); margin-bottom: 16rpx; padding-left: 14rpx; border-left: 6rpx solid #D4A84B; }
.product-scroll { white-space: nowrap; }
.product-card { display: inline-block; width: 200rpx; margin-right: 16rpx; vertical-align: top; }
.product-image { width: 200rpx; height: 140rpx; border-radius: 12rpx; display: block; }
.product-name { display: block; font-size: 22rpx; color: var(--color-text-primary); margin-top: 8rpx; white-space: normal; line-height: 1.4; }
