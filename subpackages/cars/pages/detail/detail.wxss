.car-detail { padding-bottom: 40rpx; }
.cover-wrap { position: relative; margin-bottom: 20rpx; border-radius: var(--radius-lg); overflow: hidden; }
.hero-img { width: 100%; height: 400rpx; display: block; }
.cover-overlay { position: absolute; left: 0; right: 0; bottom: 0; padding: 28rpx; background: linear-gradient(transparent, rgba(15,61,46,0.9)); color: #fff; }
.cover-overlay .price { display: block; font-size: 40rpx; font-weight: 700; color: #D4A84B; margin-top: 8rpx; }
.cover-overlay .meta { display: block; font-size: 24rpx; opacity: 0.9; margin-top: 6rpx; }
.section { padding: 24rpx 28rpx; margin-bottom: 20rpx; }
.section-title { display: block; font-size: 30rpx; font-weight: 700; color: var(--color-primary); margin-bottom: 16rpx; padding-left: 14rpx; border-left: 6rpx solid #D4A84B; }
.dealer { display: block; font-size: 26rpx; color: var(--color-text-muted); margin-bottom: 10rpx; }
.desc { display: block; font-size: 26rpx; color: var(--color-text-primary); line-height: 1.7; }
.tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 14rpx; }
.tag { background: var(--color-primary-bg); color: var(--color-primary); font-size: 22rpx; padding: 6rpx 14rpx; border-radius: 999rpx; }
.tool-row { display: flex; gap: 12rpx; flex-wrap: wrap; }
.tool-row button { margin: 0; border-radius: 999rpx; }
.contact-input { width: 100%; padding: 20rpx; background: #f7f9fc; border-radius: 12rpx; margin-bottom: 16rpx; box-sizing: border-box; font-size: 28rpx; }
.submit-btn { width: 100%; height: 88rpx; line-height: 88rpx; border-radius: 999rpx; margin: 0; }
.compliance { display: block; margin-top: 14rpx; font-size: 22rpx; color: var(--color-text-muted); line-height: 1.6; text-align: center; }
