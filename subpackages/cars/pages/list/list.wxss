.cars-page {
  padding-bottom: 40rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Location Bar ===== */
.loc-arrow {
  margin-left: auto;
  color: var(--color-text-muted);
  font-size: 32rpx;
}

/* ===== Search Bar ===== */
.search-bar {
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx;
  margin-bottom: 20rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-pill);
  box-shadow: var(--shadow-card);
}

.search-bar input {
  flex: 1;
  margin-left: 12rpx;
  font-size: 28rpx;
}

.search-btn {
  color: var(--color-primary);
  font-size: 26rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
  font-weight: 600;
}

/* ===== Stat Row ===== */
.stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-num {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* ===== Car Card ===== */
.car-card {
  display: flex;
  overflow: hidden;
  margin-bottom: 16rpx;
  padding: 0;
}

.cover {
  width: 240rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.info {
  flex: 1;
  padding: 20rpx;
  min-width: 0;
}

.info .title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.meta,
.dealer {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.price {
  display: block;
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

/* Empty state uses global .empty-state class */
