.knowledge-page {
  padding-bottom: 40rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Stat Row ===== */
.stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-num {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* ===== Filter ===== */
.filter-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

/* ===== Knowledge Card ===== */
.knowledge-card {
  display: flex;
  overflow: hidden;
  margin-bottom: 16rpx;
  padding: 0 !important;
}

.cover-thumb {
  width: 180rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.card-body {
  flex: 1;
  padding: 20rpx;
  min-width: 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.card-body .title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  flex: 1;
}

.level {
  font-size: 20rpx;
  color: var(--color-gold);
  background: rgba(212, 168, 75, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.summary {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}
