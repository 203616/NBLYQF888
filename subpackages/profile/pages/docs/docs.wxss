@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== 原文档中心样式 ===== */
.docs-page {
  padding-bottom: 40rpx;
}

.docs-hero,
.stat-row,
.action-bar,
.filter-tabs,
.doc-card,
.tips-card,
.compliance-tip {
  animation: fadeInUp 0.5s ease both;
}

.docs-hero {
  margin-bottom: 20rpx;
  min-height: 240rpx;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin: 0 var(--space-md) 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-num {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.action-bar {
  display: flex;
  gap: var(--space-sm);
  padding: 20rpx;
  margin: 0 var(--space-md) 20rpx;
}

.action-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  margin: 0;
  padding: 0;
}

.action-btn.primary {
  background: var(--gradient-hero);
  color: #fff;
}

.action-btn.outline {
  background: #fff;
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
}

.filter-tabs {
  display: flex;
  gap: 12rpx;
  margin: 0 var(--space-md) 20rpx;
  flex-wrap: wrap;
}

.filter-tab {
  font-size: 24rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: var(--color-bg-card);
  color: var(--color-text-secondary);
  box-shadow: var(--shadow-card);
}

.filter-tab.active {
  background: var(--gradient-hero);
  color: #fff;
}

.doc-card {
  padding: var(--space-md);
  margin: 0 var(--space-md) var(--space-sm);
}

.doc-card.active {
  border-left: 6rpx solid var(--color-gold);
}

.doc-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--space-sm);
}

.doc-left {
  display: flex;
  gap: var(--space-sm);
  align-items: flex-start;
  flex: 1;
}

.doc-icon {
  font-size: 40rpx;
  line-height: 1;
}

.doc-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.doc-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
  line-height: 1.5;
}

.status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.status-done { background: #e6f2ec; color: var(--color-primary); }
.status-pending { background: #fff8e6; color: #b8860b; }
.status-processing { background: #e8f4fd; color: #1890ff; }
.status-empty { background: #f5f5f5; color: var(--color-text-muted); }

.progress-wrap {
  margin: var(--space-sm) 0;
}

.progress {
  height: 10rpx;
  background: #edf2ef;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: var(--gradient-hero);
}

.progress-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.required-list {
  background: #e8f0eb;
  border-radius: 12rpx;
  padding: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.required-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.required-item {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
}

.doc-foot {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
}

.mini-btn {
  background: var(--color-primary) !important;
  color: #fff !important;
  border-radius: 999rpx !important;
  border: none !important;
}

.mini-btn.outline {
  background: #fff !important;
  color: var(--color-primary) !important;
  border: 1rpx solid var(--color-primary) !important;
}

.tips-card {
  padding: var(--space-md);
  margin: 8rpx var(--space-md) 0;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

.tip-line {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.compliance-tip {
  text-align: center;
  padding: 20rpx var(--space-md);
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
}

.page-safe {
  height: calc(env(safe-area-inset-bottom) + 20rpx);
}

/* =============================================
   居间服务合同样式
   ============================================= */
:root {
  --color-primary: #0F3D2E;
  --color-gold: #D4A84B;
}

.contract-page {
  padding-bottom: 280rpx;
  background: #f5f7f6;
  min-height: 100vh;
}

/* 入场动画 */
.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* 卡券容器 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 24rpx 20rpx;
  padding: 0;
  box-shadow: 0 2rpx 12rpx rgba(15, 61, 46, 0.06);
  overflow: hidden;
}

/* 合同头部 */
.contract-hero {
  position: relative;
  background: linear-gradient(135deg, #0F3D2E 0%, #1a6b4e 100%);
  padding: 60rpx 32rpx 50rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.hero-overlay {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(212, 168, 75, 0.12);
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.hero-badge {
  display: inline-block;
  font-size: 20rpx;
  color: #D4A84B;
  background: rgba(212, 168, 75, 0.15);
  border: 1rpx solid rgba(212, 168, 75, 0.4);
  padding: 6rpx 24rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
  line-height: 1.4;
}

.hero-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}

/* 协议提示 */
.contract-notice {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx;
  background: #faf8f0 !important;
  border-left: 6rpx solid #D4A84B;
}

.notice-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 24rpx;
  color: #8b7355;
  line-height: 1.7;
}

/* 条款区块 */
.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 28rpx 0;
  border-left: 6rpx solid #D4A84B;
  margin-left: 28rpx;
}

.section-num {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-gold, #D4A84B);
  flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary, #0F3D2E);
  letter-spacing: 2rpx;
}

.section-body {
  padding: 20rpx 28rpx 28rpx;
}

/* 子标题（第三条） */
.sub-section {
  margin-bottom: 20rpx;
}

.sub-section:last-child {
  margin-bottom: 0;
}

.sub-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary, #0F3D2E);
  margin-bottom: 12rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid #edf2ef;
}

/* 条款项 */
.clause-item {
  margin-bottom: 16rpx;
}

.clause-item:last-child {
  margin-bottom: 0;
}

.clause-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 6rpx;
}

.clause-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  text-align: justify;
}

.clause-text.highlight {
  background: #faf8f0;
  border-left: 4rpx solid #D4A84B;
  padding: 12rpx 16rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

/* 签署记录 */
.sign-record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.sign-record-item:last-child {
  border-bottom: none;
}

.record-label {
  font-size: 26rpx;
  color: #888;
}

.record-value {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
}

/* 底部确认区域 */
.contract-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  padding-bottom: calc(env(safe-area-inset-bottom) + 16rpx);
}

.footer-inner {
  padding: 20rpx 32rpx;
}

/* 确认复选框行 */
.agree-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 16rpx 0;
}

.agree-row.agreed-active {
  color: var(--color-primary, #0F3D2E);
}

.check-box {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
  transition: all 0.3s;
}

.check-box.checked {
  background: var(--color-primary, #0F3D2E);
  border-color: var(--color-primary, #0F3D2E);
}

.check-mark {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.agree-label {
  font-size: 24rpx;
  color: #555;
  line-height: 1.5;
  flex: 1;
}

.agree-row.agreed-active .agree-label {
  color: var(--color-primary, #0F3D2E);
  font-weight: 500;
}

/* 金色按钮 */
.btn-gold {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, #D4A84B 0%, #c49640 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 999rpx;
  width: 100%;
  margin: 12rpx 0;
  border: none;
  padding: 0;
  letter-spacing: 4rpx;
  transition: opacity 0.3s;
}

.btn-gold.disabled {
  opacity: 0.4;
}

.btn-gold:not(.disabled):active {
  opacity: 0.85;
}

/* 下载按钮 */
.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  background: #fff;
  color: var(--color-primary, #0F3D2E);
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 999rpx;
  width: 100%;
  margin: 8rpx 0;
  border: 1rpx solid var(--color-primary, #0F3D2E);
  padding: 0;
}

.btn-outline:active {
  background: #f0f5f2;
}

/* 底部提示 */
.footer-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #aaa;
  margin-top: 8rpx;
}
