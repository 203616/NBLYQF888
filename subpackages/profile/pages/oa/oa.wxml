        <text class="form-label">产品名称 *</text>
        <input class="form-input" placeholder="请输入产品名称" value="{{productForm.name || ''}}" data-field="name" bindinput="productFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">产品类型 *</text>
        <view class="type-picker-options">
          <view
            class="tpo-item {{productForm.type === item ? 'selected' : ''}}"
            wx:for="{{productTypeOptions}}"
            wx:key="*this"
            data-type="{{item || ''}}"
            bindtap="setProductType"
          >{{item || ''}}</view>
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">利率范围</text>
        <input class="form-input" placeholder="如 3.5%~6.0%" value="{{productForm.rateRange || ''}}" data-field="rateRange" bindinput="productFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">合作机构 *</text>
        <input class="form-input" placeholder="请输入合作银行/机构" value="{{productForm.partner || ''}}" data-field="partner" bindinput="productFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">合作机构联系人</text>
        <input class="form-input" placeholder="机构对接人姓名及联系方式" value="{{productFormExtra.contactPerson || ''}}" data-field="contactPerson" bindinput="productFormExtraInput" />
      </view>
      <view class="form-row">
        <text class="form-label">产品期限范围</text>
        <input class="form-input" placeholder="如 12~60期" value="{{productFormExtra.termRange || ''}}" data-field="termRange" bindinput="productFormExtraInput" />
      </view>
      <view class="form-row">
        <text class="form-label">目标客户群体</text>
        <input class="form-input" placeholder="如 个人车主、小微企业" value="{{productFormExtra.targetCustomer || ''}}" data-field="targetCustomer" bindinput="productFormExtraInput" />
      </view>
      <view class="form-row">
        <text class="form-label">产品描述</text>
        <input class="form-input" placeholder="选填，产品主要特点" value="{{productForm.desc || ''}}" data-field="desc" bindinput="productFormInput" />
      </view>
      <view class="btn-gold submit-btn" catchtap="submitProductForm">提交审核</view>
    </view>

    <view wx:elif="{{productCurrentTab === 'authorize'}}" class="module-panel">
      <view class="section-header">
        <text class="title">代理商产品授权</text>
      </view>
      <block wx:for="{{agentProductAuth}}" wx:key="id">
        <view class="auth-card glass-card">
          <text class="auth-name">{{item.name || ''}}</text>
          <view class="ac-products">
            <view
              class="acp-item {{item.authorizedProducts && item.authorizedProducts.includes(product.id) ? 'active' : ''}}"
              wx:for="{{products}}"
              wx:key="id"
              data-agent-id="{{item.id || ''}}"
              data-product-id="{{product.id || ''}}"
              bindtap="toggleProductAuth"
            >{{product.name || ''}}</view>
          </view>
        </view>
      </block>
    </view>

    <view wx:elif="{{productCurrentTab === 'review'}}" class="module-panel">
      <view class="section-header">
        <text class="title">准入审核流程</text>
      </view>
      <block wx:for="{{reviewRecords}}" wx:key="id">
        <view class="review-card glass-card" bindtap="showReviewDetail" data-id="{{item.id || ''}}">
          <view class="rvc-head">
            <text class="rvc-name">{{item.productName || ''}}</text>
            <text class="rvc-status rvcs-{{item.status === '终审通过' ? 'done' : item.status === '初审通过' ? 'first' : item.status === '待初审' ? 'pending' : 'draft'}}">{{item.status || ''}}</text>
          </view>
          <view class="rvc-meta">
            <text>申请人：{{item.applicant || ''}}</text>
            <text>申请日期：{{item.applyDate || ''}}</text>
          </view>
          <view class="rvc-progress">
            <view class="rvcp-step {{item.history.length >= 1 ? 'done' : ''}}"><text class="rvcp-dot">{{item.history.length >= 1 ? '✓' : '1'}}</text><text class="rvcp-label">提交</text></view>
            <view class="rvcp-line {{item.history.length >= 2 ? 'done' : ''}}"></view>
            <view class="rvcp-step {{item.history.length >= 2 ? 'done' : ''}}"><text class="rvcp-dot">{{item.history.length >= 2 ? '✓' : '2'}}</text><text class="rvcp-label">初审</text></view>
            <view class="rvcp-line {{item.history.length >= 3 ? 'done' : ''}}"></view>
            <view class="rvcp-step {{item.history.length >= 3 ? 'done' : ''}}"><text class="rvcp-dot">{{item.history.length >= 3 ? '✓' : '3'}}</text><text class="rvcp-label">终审</text></view>
          </view>
          <view class="rvc-action" wx:if="{{item.currentStep === '待初审' || item.currentStep === '待终审'}}">
            <view class="action-row">
              <view class="btn-outline action-btn" data-id="{{item.id || ''}}" catchtap="rejectReview">驳回</view>
              <view class="btn-gold action-btn" data-id="{{item.id || ''}}" catchtap="approveReview">{{item.currentStep === '待初审' ? '通过初审' : '通过终审'}}</view>
            </view>
          </view>
        </view>
      </block>
      <view class="empty-state" wx:if="{{!reviewRecords.length}}">
        <text class="empty-icon">✅</text>
        <text class="empty-text">暂无审核记录</text>
      </view>
    </view>

    <view wx:if="{{selectedReview}}" class="modal-overlay" catchtap="closeReviewDetail">
      <view class="modal-content glass-card" catchtap="noop">
        <text class="modal-title">审核详情 - {{selectedReview.productName || ''}}</text>
        <view class="modal-body">
          <view class="md-row"><text>当前状态</text><text class="rvc-status rvcs-{{selectedReview.status === '终审通过' ? 'done' : selectedReview.status === '初审通过' ? 'first' : 'pending'}}">{{selectedReview.status || ''}}</text></view>
          <view class="md-divider"></view>
          <view class="md-row" wx:for="{{selectedReview.history || []}}" wx:key="step">
            <view class="md-step">
              <text class="mds-index">{{index + 1}}.</text>
              <view class="mds-body">
                <text class="mds-step">{{item.step || ''}}</text>
                <text class="mds-time">{{item.time || ''}} {{item.operator || ''}}</text>
                <text class="mds-comment" wx:if="{{item.comment}}">{{item.comment || ''}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="btn-gold modal-close" catchtap="closeReviewDetail">关闭</view>
      </view>
    </view>
  </view>

  <!-- ============================================================ -->
  <!-- TAB 5: 模板中心 -->
  <!-- ============================================================ -->
  <view wx:if="{{currentTab === 5}}" class="fade-in-up">
    <view class="oa-hero premium-hero">
      <safe-image className="premium-hero-bg" src="/images/banner1.webp" mode="aspectFill" />
      <view class="premium-hero-body">
        <text class="premium-badge">模板中心</text>
        <text class="premium-hero-title">文档 &amp; 合同模板</text>
        <text class="premium-hero-sub">合同模板 · 表单模板 · 文档模板</text>
      </view>
    </view>

    <view class="template-search-box glass-card">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索模板名称或描述..." value="{{templateSearchKeyword || ''}}" bindinput="onTemplateSearchInput" />
    </view>

    <view class="sub-tab-bar glass-card">
      <view
        class="sub-tab-item {{templateCurrentCategory === item.id ? 'active' : ''}}"
        wx:for="{{templateCategories}}"
        wx:key="id"
        data-category="{{item.id || ''}}"
        bindtap="switchTemplateCategory"
      >
        <text class="sti-name">{{item.name || ''}}</text>
      </view>
      <view
        class="sub-tab-item {{templateCurrentCategory === 'favorites' ? 'active' : ''}}"
        data-category="favorites"
        bindtap="switchTemplateCategory"
      >
        <text class="sti-name">⭐ 收藏 ({{templateFavorites.length || 0}})</text>
      </view>
    </view>

    <block wx:for="{{filteredTemplates}}" wx:key="id">
      <view class="template-card glass-card fade-in-up">
        <view class="tc-head">
          <text class="tc-icon">{{item.icon || '📄'}}</text>
          <view class="tc-head-body">
            <text class="tc-title">{{item.title || ''}}</text>
            <view class="tc-tags">
              <text class="tc-category" wx:if="{{item.category === 'contract'}}">合同模板</text>
              <text class="tc-category" wx:elif="{{item.category === 'form'}}">表单模板</text>
              <text class="tc-category" wx:elif="{{item.category === 'document'}}">文档模板</text>
              <text class="tc-fav {{templateFavorites.indexOf(item.id) !== -1 ? 'active' : ''}}" data-id="{{item.id || ''}}" catchtap="toggleFavorite">{{templateFavorites.indexOf(item.id) !== -1 ? '⭐' : '☆'}}</text>
            </view>
          </view>
        </view>
        <text class="tc-desc">{{item.desc || ''}}</text>
        <view class="tc-meta-info">
          <text class="tc-meta-item" wx:if="{{item.templateNo}}">编号：{{item.templateNo || ''}}</text>
          <text class="tc-meta-item" wx:if="{{item.version}}">版本：{{item.version || ''}}</text>
          <text class="tc-meta-item" wx:if="{{item.updateDate}}">更新：{{item.updateDate || ''}}</text>
        </view>
        <view class="tc-actions">
          <view class="btn-outline tc-btn" data-id="{{item.id || ''}}" catchtap="previewTemplate">预览</view>
          <view class="btn-gold tc-btn" data-id="{{item.id || ''}}" catchtap="copyTemplateContent">📋 复制内容</view>
        </view>
      </view>
    </block>
    <view class="empty-state" wx:if="{{!filteredTemplates.length}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无模板</text>
    </view>

    <view wx:if="{{templatePreview}}" class="modal-overlay" catchtap="closeTemplatePreview">
      <view class="modal-content glass-card" catchtap="noop">
        <text class="modal-title">{{templatePreview.icon || '📄'}} {{templatePreview.title || ''}}</text>
        <view class="tpl-meta-bar">
          <text class="tpl-meta-item" wx:if="{{templatePreview.templateNo}}">编号：{{templatePreview.templateNo || ''}}</text>
          <text class="tpl-meta-item" wx:if="{{templatePreview.version}}">版本：{{templatePreview.version || ''}}</text>
          <text class="tpl-meta-item" wx:if="{{templatePreview.updateDate}}">更新：{{templatePreview.updateDate || ''}}</text>
        </view>
        <view class="modal-body">
          <view class="tpl-preview-content">{{templatePreview.content || ''}}</view>
        </view>
        <view class="modal-actions">
          <view class="btn-gold modal-close" catchtap="copyTemplateContent" data-id="{{templatePreview.id || ''}}">📋 复制内容</view>
          <view class="btn-outline modal-close" catchtap="closeTemplatePreview">关闭</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 调试面板：账号类型切换 -->
  <view class="debug-panel glass-card" wx:if="{{showDebugPanel}}">
    <view class="dp-header">
      <text class="dp-title">🔧 调试面板</text>
      <text class="dp-close" catchtap="toggleDebugPanel">✕</text>
    </view>
    <view class="dp-body">
      <text class="dp-label">账号类型切换</text>
      <view class="dp-role-options">
        <view class="dp-role-item {{userAccountType === 'admin' ? 'active' : ''}}" data-type="admin" catchtap="switchAccountType">管理员</view>
        <view class="dp-role-item {{userAccountType === 'agent' ? 'active' : ''}}" data-type="agent" catchtap="switchAccountType">代理商</view>
        <view class="dp-role-item {{userAccountType === 'staff' ? 'active' : ''}}" data-type="staff" catchtap="switchAccountType">业务员</view>
      </view>
      <text class="dp-hint">当前：{{ACCOUNT_TYPE_LABELS[userAccountType] || '业务员'}}（{{currentAccountProfile.name || ''}}）</text>
      <text class="dp-hint">长按工作台标题也可快速切换</text>
    </view>
  </view>

  <view class="page-safe"></view>
</view>
