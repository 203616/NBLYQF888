            <text class="chart-bar-value">{{item.chartLabel || item.amount}}</text>
          </view>
          <text class="chart-bar-label">{{item.agent || ''}}</text>
        </view>
      </view>
      <view class="stat-summary glass-card">
        <view class="ss-item"><text class="ss-val">{{filteredPerformanceReports.length || 0}}</text><text class="ss-label">{{userAccountType === 'staff' ? '我的产品' : '代理商数'}}</text></view>
        <view class="ss-item"><text class="ss-val">{{totalAgentFormatted}}</text><text class="ss-label">总放款</text></view>
        <view class="ss-item"><text class="ss-val">{{latestOrderCount || 0}}</text><text class="ss-label">月订单</text></view>
      </view>
