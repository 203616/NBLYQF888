    </view>
  </view>

  <!-- ============================================================ -->
  <!-- TAB 3: 财务管理 -->
  <!-- ============================================================ -->
  <view wx:if="{{currentTab === 3}}" class="fade-in-up">
    <view class="sub-tab-bar glass-card">
      <view
        class="sub-tab-item {{financeCurrentTab === item.id ? 'active' : ''}}"
        wx:for="{{financeTabs}}"
        wx:key="id"
        data-tab="{{item.id || ''}}"
        bindtap="switchFinanceTab"
      >
        <text class="sti-icon">{{item.icon || ''}}</text>
        <text class="sti-name">{{item.name || ''}}</text>
      </view>
    </view>

    <view wx:if="{{financeCurrentTab === 'overview'}}" class="module-panel">
      <view class="finance-overview glass-card">
        <text class="fo-month">{{financeOverviewData.month || ''}} 财务概览</text>
        <view class="fo-grid">
          <view class="fo-item income"><text class="foi-val">{{financeOverviewData.totalIncome_str}}</text><text class="foi-label">总收入</text></view>
          <view class="fo-item expense"><text class="foi-val">{{financeOverviewData.totalExpense_str}}</text><text class="foi-label">总支出</text></view>
          <view class="fo-item {{financeOverviewData.balanceClass || 'balance'}}" wx:if="{{(financeOverviewData.balance || 0) < 0}}" bindtap="handleFinanceAlarmTap">
            <text class="foi-val alarm-pulse">{{financeOverviewData.balance_str}}</text>
            <text class="foi-label">赤字 ‣ 去处理</text>
          </view>
          <view class="fo-item balance" wx:else>
            <text class="foi-val">{{financeOverviewData.balance_str}}</text>
            <text class="foi-label">结余</text>
          </view>
        </view>
      </view>

      <view class="fo-stat-row">
        <view class="fo-stat-item"><text class="fo-stat-val">{{filteredFinanceRecords.length || 0}}</text><text class="fo-stat-label">本月记录</text></view>
        <view class="fo-stat-item"><text class="fo-stat-val">{{financeOverviewData.incomeItems.length || 0}}</text><text class="fo-stat-label">收入项数</text></view>
        <view class="fo-stat-item"><text class="fo-stat-val">{{financeOverviewData.expenseItems.length || 0}}</text><text class="fo-stat-label">支出项数</text></view>
      </view>

      <view class="fo-detail-grid">
        <view class="fo-section glass-card">
          <text class="fos-title">📈 收入构成</text>
          <view class="fos-item" wx:for="{{financeOverviewData.incomeItems || []}}" wx:key="category">
            <text class="fosi-name">{{item.category || ''}}</text>
            <view class="fosi-bar-bg"><view class="fosi-bar inc" style="width: {{(item.amount / (financeOverviewData.totalIncome || 1)) * 100}}%"></view></view>
            <text class="fosi-val">{{item.amount_str}}</text>
          </view>
          <view class="empty-tip" wx:if="{{!financeOverviewData.incomeItems || !financeOverviewData.incomeItems.length}}">暂无收入数据</view>
        </view>
        <view class="fo-section glass-card">
          <text class="fos-title">📉 支出构成</text>
          <view class="fos-item" wx:for="{{financeOverviewData.expenseItems || []}}" wx:key="category">
            <text class="fosi-name">{{item.category || ''}}</text>
            <view class="fosi-bar-bg"><view class="fosi-bar exp" style="width: {{(item.amount / (financeOverviewData.totalExpense || 1)) * 100}}%"></view></view>
            <text class="fosi-val">{{item.amount_str}}</text>
          </view>
          <view class="empty-tip" wx:if="{{!financeOverviewData.expenseItems || !financeOverviewData.expenseItems.length}}">暂无支出数据</view>
        </view>
      </view>
    </view>

    <view wx:elif="{{financeCurrentTab === 'records'}}" class="module-panel">
      <view class="section-head-actions">
        <view class="section-header">
          <text class="title">收支记录</text>
        </view>
        <view class="btn-outline add-btn" catchtap="toggleFinanceForm">+ 添加</view>
      </view>

      <view class="month-picker">
        <picker mode="selector" range="{{financeMonths}}" bindchange="onFinanceMonthChange">
          <view class="picker-btn">{{financeMonthLabels[financeFilterMonth] || financeFilterMonth || '选择月份'}} ▾</view>
        </picker>
      </view>

      <view wx:if="{{financeShowForm}}" class="finance-form glass-card">
        <text class="ff-title">新增收支记录</text>
        <view class="ff-type-switch">
          <view class="ffts-item {{financeForm.type === 'income' ? 'active' : ''}}" data-value="income" bindtap="setFinanceType">收入</view>
          <view class="ffts-item {{financeForm.type === 'expense' ? 'active' : ''}}" data-value="expense" bindtap="setFinanceType">支出</view>
        </view>
        <view class="form-row"><text class="form-label">分类</text><input class="form-input" placeholder="如：渠道分润、工资、办公" value="{{financeForm.category || ''}}" data-field="category" bindinput="financeInputChange" /></view>
        <view class="form-row"><text class="form-label">金额（元）</text><input class="form-input" type="digit" placeholder="请输入金额" value="{{financeForm.amount || ''}}" data-field="amount" bindinput="financeInputChange" /></view>
        <view class="form-row"><text class="form-label">日期</text><input class="form-input" placeholder="{{today}}" value="{{financeForm.date || ''}}" data-field="date" bindinput="financeInputChange" /></view>
        <view class="form-row"><text class="form-label">备注</text><input class="form-input" placeholder="选填" value="{{financeForm.note || ''}}" data-field="note" bindinput="financeInputChange" /></view>
        <view class="btn-gold" catchtap="submitFinanceRecord">保存</view>
      </view>

      <block wx:for="{{filteredFinanceRecords}}" wx:key="id">
        <view class="finance-record glass-card">
          <view class="fr-icon">{{item.type === 'income' ? '💚' : '🔴'}}</view>
          <view class="fr-body">
            <text class="fr-category">{{item.category || ''}}</text>
            <text class="fr-note">{{item.note || ''}} · {{item.date || ''}}</text>
          </view>
          <text class="fr-amount {{item.type === 'income' ? 'in' : 'out'}}">{{item.amount_str}}</text>
          <view class="fr-delete" data-id="{{item.id || ''}}" catchtap="deleteFinanceRecord">✕</view>
        </view>
      </block>
      <view class="empty-state" wx:if="{{!filteredFinanceRecords.length}}">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无收支记录</text>
      </view>
    </view>

    <view wx:elif="{{financeCurrentTab === 'reports'}}" class="module-panel">
      <view class="section-head-actions">
        <view class="section-header">
          <text class="title">财务报表</text>
        </view>
        <view class="btn-outline add-btn" catchtap="exportFinanceReport">📋 导出</view>
      </view>
      <view class="month-picker">
        <picker mode="selector" range="{{financeMonths}}" bindchange="onFinanceMonthChange">
          <view class="picker-btn">{{financeMonthLabels[financeFilterMonth] || financeFilterMonth || '选择月份'}} ▾</view>
        </picker>
      </view>
      <view class="report-summary glass-card">
        <text class="rs-title">{{financeFilterMonth || '选择月份'}} 财务摘要</text>
        <view class="rs-grid">
          <view class="rs-item"><text class="rs-val in">{{financeOverviewData.totalIncome_str}}</text><text class="rs-label">收入</text></view>
          <view class="rs-item"><text class="rs-val out">{{financeOverviewData.totalExpense_str}}</text><text class="rs-label">支出</text></view>
          <view class="rs-item"><text class="rs-val {{financeOverviewData.balanceClass || 'in'}}">{{financeOverviewData.balance_str}}</text><text class="rs-label">结余</text></view>
        </view>
      </view>
      <view class="report-detail glass-card">
        <text class="rd-title">收支明细</text>
        <view class="rd-item" wx:for="{{financeOverviewData.incomeItems || []}}" wx:key="category">
          <text class="rdi-name">💚 {{item.category || ''}}</text>
          <text class="rdi-val">{{item.amount_str}}</text>
        </view>
        <view class="rd-divider"></view>
        <view class="rd-item" wx:for="{{financeOverviewData.expenseItems || []}}" wx:key="category">
          <text class="rdi-name">🔴 {{item.category || ''}}</text>
          <text class="rdi-val">{{item.amount_str}}</text>
        </view>
      </view>
    </view>

    <view wx:elif="{{financeCurrentTab === 'reminders'}}" class="module-panel">
      <view class="section-header">
        <text class="title">收付款提醒</text>
      </view>
      <view class="sub-section-title">待处理</view>
      <block wx:for="{{financeReminders}}" wx:key="id">
        <view class="reminder-card glass-card">
          <view class="rm-head">
            <text class="rm-title">{{item.title || ''}}</text>
            <text class="rm-status rms-pending">{{item.status || ''}}</text>
          </view>
          <view class="rm-meta">
            <text class="rm-type">{{item.type || ''}}</text>
            <text class="rm-amount">{{item.amount_str}}</text>
            <text class="rm-due">截止 {{item.dueDate || ''}}</text>
          </view>
          <view class="btn-gold rm-btn" data-id="{{item.id || ''}}" catchtap="completeReminder">标记完成</view>
        </view>
      </block>
      <view class="empty-tip" wx:if="{{!financeReminders.length}}">暂无待处理提醒</view>

