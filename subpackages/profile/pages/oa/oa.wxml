          <view class="md-row"><text>总佣金</text><text class="gold">¥{{agentSelectedReport.totalCommission || '0.00'}}</text></view>
          <view class="md-row"><text>总订单数</text><text>{{agentSelectedReport.orderCount || 0}} 单</text></view>
          <view class="md-divider"></view>
