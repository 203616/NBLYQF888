    <view wx:if="{{agentDetailItem}}" class="modal-overlay" catchtap="closeAgentDetail">
      <view class="modal-content glass-card" catchtap="noop">
        <text class="modal-title">代理商详情</text>
        <view class="modal-body">
          <view class="md-row"><text>企业名称</text><text>{{agentDetailItem.company || ''}}</text></view>
          <view class="md-row"><text>联系人</text><text>{{agentDetailItem.contact || ''}}</text></view>
          <view class="md-row"><text>手机号</text><text>{{agentDetailItem.phone || ''}}</text></view>
          <view class="md-row"><text>所在区域</text><text>{{agentDetailItem.region || ''}}</text></view>
          <view class="md-row"><text>资质说明</text><text>{{agentDetailItem.qualification || ''}}</text></view>
          <view class="md-row"><text>申请时间</text><text>{{agentDetailItem.applyDate || ''}}</text></view>
          <view class="md-row"><text>审核状态</text><text class="ac-status acs-{{agentDetailItem.status === '已通过' ? 'pass' : agentDetailItem.status === '待审核' ? 'pending' : 'reject'}}">{{agentDetailItem.status || ''}}</text></view>
