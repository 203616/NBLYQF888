<view class="oa-page page-shell">
  <!-- ====== Tab 顶部导航 ====== -->
  <view class="oa-tab-bar glass-card">
    <view
      wx:for="{{tabs}}"
      wx:key="id"
      class="oa-tab-item {{currentTab === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <text class="oa-tab-icon">{{item.icon || ''}}</text>
      <text class="oa-tab-name">{{item.name || ''}}</text>
    </view>
  </view>

  <!-- ============================================================ -->
  <!-- TAB 0: 工作台 -->
  <!-- ============================================================ -->
  <view wx:if="{{currentTab === 0}}" class="fade-in-up">
    <view class="oa-hero premium-hero">
      <safe-image className="premium-hero-bg" src="/images/banner1.webp" mode="aspectFill" />
      <view class="premium-hero-body">
        <text class="premium-badge">工作台</text>
        <text class="premium-hero-title" bindlongpress="onTitleLongPress">OA工作台</text>
        <text class="premium-hero-sub">客户跟进 · 材料审核 · 会议提醒 · 审批事项</text>
        <!-- 角色标识 -->
        <view class="role-badge">
          <text class="role-badge-icon">👤</text>
          <text class="role-badge-text">{{currentAccountProfile.name || ''}}</text>
          <text class="role-badge-type tag">{{ACCOUNT_TYPE_LABELS[userAccountType] || '业务员'}}</text>
        </view>
      </view>
    </view>

    <view class="stats-grid">
      <block wx:for="{{stats}}" wx:key="name">
        <view class="stat-card glass-card" bindtap="onStatTap" data-name="{{item.name || ''}}">
          <text class="stat-icon">{{item.icon || '📌'}}</text>
          <text class="stat-count">{{item.count || 0}}</text>
          <text class="stat-name">{{item.name || ''}}</text>
        </view>
      </block>
    </view>

    <view class="quick-actions glass-card">
      <view class="quick-item" bindtap="goIntake">
        <text class="qi-icon">📋</text>
        <text>进件管理</text>
      </view>
      <view class="quick-item" bindtap="goFinanceCircle">
        <text class="qi-icon">🤝</text>
        <text>易融圈</text>
      </view>
      <view class="quick-item" bindtap="goDocs">
        <text class="qi-icon">📁</text>
        <text>文档中心</text>
      </view>
      <view class="quick-item" bindtap="goChat">
        <text class="qi-icon">💬</text>
        <text>智能客服</text>
      </view>
    </view>

    <view class="section glass-card">
      <view class="section-head">
        <text class="section-title">待办任务</text>
        <text class="task-filter" bindtap="toggleTaskFilter">{{taskFilterLabel || ''}}</text>
      </view>
      <block wx:for="{{filteredTasks}}" wx:key="id">
        <view class="task-card" bindtap="handleTaskTap" data-id="{{item.id || ''}}">
          <view class="task-head">
            <text class="task-title">{{item.title || ''}}</text>
            <text class="priority priority-{{item.priorityKey || 'medium'}}">{{item.priority || ''}}</text>
          </view>
          <text class="task-desc">{{item.desc || ''}}</text>
          <view class="task-meta">
            <text class="meta-tag">{{item.type || ''}}</text>
            <text>{{item.due || ''}}</text>
            <text class="status-tag">{{item.status || ''}}</text>
          </view>
          <text class="task-assignee" wx:if="{{item.assignee}}">负责人：{{item.assignee || ''}}</text>
        </view>
      </block>
      <view class="empty-tip" wx:if="{{!filteredTasks.length}}">暂无待办任务</view>
    </view>

    <view class="section glass-card">
      <view class="section-head">
        <text class="section-title">会议通知</text>
        <text class="meeting-count">{{meetings.length || 0}} 场</text>
      </view>
      <block wx:for="{{meetings}}" wx:key="id">
        <view class="meeting-card" bindtap="handleMeetingTap" data-id="{{item.id || ''}}">
          <view class="meeting-time-badge">
            <text class="mt-day">{{item.dayLabel || ''}}</text>
            <text class="mt-time">{{item.timeShort || ''}}</text>
          </view>
          <view class="meeting-body">
            <text class="meeting-title">{{item.title || ''}}</text>
            <text class="meeting-desc">{{item.place || ''}} · {{item.host || ''}}</text>
            <text class="meeting-agenda" wx:if="{{item.agenda}}">{{item.agenda || ''}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- ============================================================ -->
  <!-- TAB 1: 税务报税 -->
  <!-- ============================================================ -->
  <view wx:if="{{currentTab === 1}}" class="fade-in-up">
    <view class="tax-tip-banner glass-card">
      <text class="tax-tip-icon">💡</text>
      <text class="tax-tip-text">本月申报截止日期：07月15日，请及时完成增值税及附加税申报</text>
    </view>

    <view class="tax-quick-actions">
      <view class="tax-qua-item" bindtap="resetTaxWizard">
        <text class="tqa-icon">📝</text>
        <text class="tqa-name">开始报税</text>
      </view>
      <view class="tax-qua-item" data-filter="all" bindtap="onTaxHistoryFilter">
        <text class="tqa-icon">📋</text>
        <text class="tqa-name">报税记录</text>
      </view>
      <view class="tax-qua-item" data-filter="已缴款" bindtap="onTaxHistoryFilter">
        <text class="tqa-icon">✅</text>
        <text class="tqa-name">已缴款</text>
      </view>
      <view class="tax-qua-item" data-filter="已申报" bindtap="onTaxHistoryFilter">
        <text class="tqa-icon">⏳</text>
        <text class="tqa-name">已申报</text>
      </view>
    </view>

    <view class="section-header">
      <text class="title">报税日历</text>
    </view>
    <view class="tax-calendar glass-card">
      <block wx:for="{{taxCalendar}}" wx:key="month">
        <view class="tax-cal-month">
          <text class="tcm-label">{{item.month || ''}}</text>
          <view class="tcm-items">
            <view class="tcm-item" wx:for="{{item.items || []}}" wx:key="name">
              <text class="tcm-name">{{item.name || ''}}</text>
              <text class="tcm-deadline">截止 {{item.deadline || ''}}</text>
              <text class="tcm-status tcm-{{item.status === '已截止' ? 'overdue' : 'pending'}}">{{item.status || ''}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view class="section-header">
      <text class="title">简易税额计算器</text>
    </view>
    <view class="tax-calculator glass-card">
      <view class="calc-row">
        <text class="calc-label">收入金额（元）</text>
        <input class="calc-input" type="digit" placeholder="请输入收入" value="{{taxCalcInput.income || ''}}" data-field="income" bindinput="taxCalcInputChange" />
      </view>
      <view class="calc-row">
        <text class="calc-label">扣除金额（元）</text>
        <input class="calc-input" type="digit" placeholder="请输入扣除项（可空）" value="{{taxCalcInput.deductions || ''}}" data-field="deductions" bindinput="taxCalcInputChange" />
      </view>
      <view class="calc-row">
        <text class="calc-label">税率（%）</text>
        <input class="calc-input" type="digit" placeholder="如 3, 6, 13, 25" value="{{taxCalcInput.taxRate || ''}}" data-field="taxRate" bindinput="taxCalcInputChange" />
      </view>
      <view class="calc-actions">
        <view class="btn-gold calc-btn" bindtap="calculateTax">🧮 计算税额</view>
        <view class="btn-outline calc-btn" bindtap="clearTaxCalc">清空</view>
      </view>
      <view wx:if="{{taxCalcResult}}" class="calc-result">
        <text class="cr-title">计算结果</text>
        <view class="cr-row"><text>应纳税所得额</text><text class="cr-val">{{taxCalcResult.taxableAmount || '0.00'}} 元</text></view>
        <view class="cr-row"><text>适用税率</text><text class="cr-val">{{taxCalcResult.taxRate || ''}}</text></view>
        <view class="cr-row cr-total"><text>应缴税额</text><text class="cr-val gold">{{taxCalcResult.taxDue || '0.00'}} 元</text></view>
      </view>
    </view>

    <view class="section-header">
      <text class="title">报税向导</text>
    </view>
    <view class="tax-wizard glass-card">
      <text class="wizard-progress-text">{{wizardProgressText || ''}}</text>
      <view class="wizard-steps">
        <view
          wx:for="{{wizardSteps}}"
          wx:key="*this"
          class="ws-item {{taxCurrentStep > index + 1 ? 'done' : ''}} {{taxCurrentStep === index + 1 ? 'current' : ''}}"
        >
          <view class="ws-circle">{{taxCurrentStep > index + 1 ? '✓' : index + 1}}</view>
          <text class="ws-label">{{item || ''}}</text>
        </view>
      </view>

      <view wx:if="{{taxCurrentStep === 5}}" class="wizard-success">
        <text class="ws-big-icon">✅</text>
        <text class="ws-msg">申报提交成功！</text>
        <text class="ws-sub">您已成功完成报税，请关注审核状态</text>
        <view class="btn-gold" catchtap="resetTaxWizard">继续报税</view>
      </view>

      <view wx:elif="{{taxCurrentStep === 1}}" class="wizard-body">
        <text class="wb-title">请选择纳税人类型</text>
        <view class="taxpayer-options">
          <view
            class="tpo-card {{selectedTaxpayerType && selectedTaxpayerType.id === item.id ? 'selected' : ''}}"
            wx:for="{{taxpayerTypes}}"
            wx:key="id"
            data-id="{{item.id || ''}}"
            bindtap="selectTaxpayerType"
          >
            <text class="tpo-icon">{{item.icon || ''}}</text>
            <text class="tpo-name">{{item.name || ''}}</text>
            <text class="tpo-desc">{{item.label || ''}}</text>
            <text class="tpo-rate">税率 {{item.taxRates || ''}}</text>
          </view>
        </view>
        <view class="wb-actions">
          <view class="btn-outline wb-btn" catchtap="resetTaxWizard">取消</view>
          <view class="btn-gold wb-btn {{selectedTaxpayerType ? '' : 'disabled'}}" catchtap="taxNextStep">下一步</view>
        </view>
      </view>

      <view wx:elif="{{taxCurrentStep === 2}}" class="wizard-body">
        <text class="wb-title">选择报税周期 &amp; 税种</text>
        <text class="wb-label">申报类型</text>
        <view class="decltype-options">
          <view
            class="dto-item {{selectDeclareType && selectDeclareType.id === item.id ? 'selected' : ''}}"
            wx:for="{{declareTypeOptions}}"
            wx:key="id"
            data-id="{{item.id || ''}}"
            bindtap="selectDeclareType"
          >
            <text class="dto-name">{{item.name || ''}}</text>
            <text class="dto-desc">{{item.desc || ''}}</text>
          </view>
        </view>
        <text class="wb-label">报税周期</text>
        <view class="period-options">
          <view
            class="po-item {{selectedTaxPeriod && selectedTaxPeriod.id === item.id ? 'selected' : ''}}"
            wx:for="{{taxPeriods}}"
            wx:key="id"
            data-id="{{item.id || ''}}"
            bindtap="selectTaxPeriod"
          >
            <text class="po-name">{{item.name || ''}}</text>
            <text class="po-desc">{{item.desc || ''}}（{{item.freq || 0}}次/年）</text>
          </view>
        </view>
        <text class="wb-label">税种</text>
        <view class="category-options">
          <view
            class="co-item {{selectedTaxCategory && selectedTaxCategory.id === item.id ? 'selected' : ''}}"
            wx:for="{{taxCategories}}"
            wx:key="id"
            data-id="{{item.id || ''}}"
            bindtap="selectTaxCategory"
          >
            <text class="co-icon">{{item.icon || ''}}</text>
            <view class="co-body">
              <text class="co-name">{{item.name || ''}}</text>
              <text class="co-desc">{{item.desc || ''}}</text>
              <text class="co-rate">税率 {{item.baseRate || ''}}</text>
            </view>
          </view>
        </view>
        <view class="wb-actions">
          <view class="btn-outline wb-btn" catchtap="taxPrevStep">上一步</view>
          <view class="btn-gold wb-btn {{selectedTaxPeriod && selectedTaxCategory && selectDeclareType ? '' : 'disabled'}}" catchtap="taxNextStep">下一步</view>
        </view>
      </view>

      <view wx:elif="{{taxCurrentStep === 3}}" class="wizard-body">
        <text class="wb-title">填写报税数据</text>
        <view wx:if="{{selectDeclareType && selectDeclareType.id === 'zero'}}" class="zero-declare-hint">
          <text class="zdh-icon">ℹ️</text>
          <text class="zdh-text">您选择的是0申报，无需填写收入数据，系统将自动生成零申报表。</text>
        </view>
        <block wx:if="{{!selectDeclareType || selectDeclareType.id === 'normal'}}">
          <view class="form-row">
            <text class="form-label">本期收入（元）</text>
            <input class="form-input" type="digit" placeholder="请输入收入金额" value="{{taxFormData.taxableIncome || ''}}" data-field="taxableIncome" bindinput="taxInputChange" />
          </view>
          <view class="form-row">
            <text class="form-label">成本/扣除项（元）</text>
            <input class="form-input" type="digit" placeholder="请输入可扣除金额" value="{{taxFormData.deductions || ''}}" data-field="deductions" bindinput="taxInputChange" />
          </view>
        </block>
        <view class="form-row">
          <text class="form-label">备注</text>
          <input class="form-input" placeholder="选填" value="{{taxFormData.remarks || ''}}" data-field="remarks" bindinput="taxInputChange" />
        </view>
        <view class="wb-actions">
          <view class="btn-outline wb-btn" catchtap="taxPrevStep">上一步</view>
          <view class="btn-gold wb-btn" catchtap="taxNextStep">预览</view>
        </view>
      </view>

      <view wx:elif="{{taxCurrentStep === 4}}" class="wizard-body">
        <text class="wb-title">预览确认</text>
        <view class="preview-card" wx:if="{{taxPreview}}">
          <view class="pv-row"><text class="pv-label">纳税人类型</text><text class="pv-val">{{taxPreview.taxpayerType || ''}}</text></view>
          <view class="pv-row"><text class="pv-label">申报类型</text><text class="pv-val">{{taxPreview.declareType || ''}}</text></view>
          <view class="pv-row"><text class="pv-label">税种</text><text class="pv-val">{{taxPreview.taxCategory || ''}}</text></view>
          <view class="pv-row"><text class="pv-label">报税周期</text><text class="pv-val">{{taxPreview.period || ''}}</text></view>
          <view class="pv-divider"></view>
          <view class="pv-row"><text class="pv-label">收入金额</text><text class="pv-val">{{taxPreview.taxableIncome || '0.00'}} 元</text></view>
          <view class="pv-row"><text class="pv-label">扣除金额</text><text class="pv-val">{{taxPreview.deductions || '0.00'}} 元</text></view>
          <view class="pv-row"><text class="pv-label">应纳税所得额</text><text class="pv-val">{{taxPreview.taxableAmount || '0.00'}} 元</text></view>
          <view class="pv-row"><text class="pv-label">适用税率</text><text class="pv-val">{{taxPreview.taxRate || ''}}</text></view>
          <view class="pv-divider"></view>
          <view class="pv-row pv-total"><text class="pv-label">应缴税额</text><text class="pv-val gold">{{taxPreview.taxDue || '0.00'}} 元</text></view>
          <view class="pv-row"><text class="pv-label">备注</text><text class="pv-val">{{taxPreview.remarks || '无'}}</text></view>
        </view>
        <view class="wb-actions">
          <view class="btn-outline wb-btn" catchtap="taxPrevStep">修改</view>
          <view class="btn-gold wb-btn" catchtap="submitTax">确认提交</view>
        </view>
      </view>
    </view>

    <view class="section-header">
      <text class="title">报税记录</text>
    </view>
    <view class="tax-history glass-card">
      <view class="th-filters">
        <view class="thf-item {{taxHistoryFilter === 'all' ? 'active' : ''}}" data-filter="all" bindtap="onTaxHistoryFilter">全部</view>
        <view class="thf-item {{taxHistoryFilter === '已申报' ? 'active' : ''}}" data-filter="已申报" bindtap="onTaxHistoryFilter">已申报</view>
        <view class="thf-item {{taxHistoryFilter === '已缴款' ? 'active' : ''}}" data-filter="已缴款" bindtap="onTaxHistoryFilter">已缴款</view>
        <view class="thf-item {{taxHistoryFilter === '已完结' ? 'active' : ''}}" data-filter="已完结" bindtap="onTaxHistoryFilter">已完结</view>
      </view>
      <block wx:for="{{filteredTaxHistory}}" wx:key="id">
        <view class="th-item" bindtap="showTaxDetail" data-id="{{item.id || ''}}">
          <view class="th-head">
            <text class="th-name">{{item.taxCategory || ''}} · {{item.period || ''}}</text>
            <text class="th-status ths-{{item.status === '已缴款' || item.status === '已完结' ? 'done' : item.status === '已申报' ? 'filing' : item.status === '草稿' ? 'draft' : 'pending'}}">{{item.status || ''}}</text>
          </view>
          <text class="th-meta">{{item.taxpayerType || ''}} · {{item.declareType || ''}} · {{item.date || ''}}</text>
          <text class="th-amount" wx:if="{{item.amountPositive}}">¥{{item.amount || '0.00'}}</text>
          <text class="th-amount zero" wx:else>¥0.00（零申报）</text>
        </view>
      </block>
      <view class="empty-tip" wx:if="{{!filteredTaxHistory.length}}">暂无报税记录</view>
    </view>

    <view wx:if="{{selectedHistoryItem}}" class="modal-overlay" catchtap="closeTaxDetail">
      <view class="modal-content glass-card" catchtap="noop">
        <text class="modal-title">报税详情</text>
        <view class="modal-body">
          <view class="md-row"><text>税种</text><text>{{selectedHistoryItem.taxCategory || ''}}</text></view>
          <view class="md-row"><text>纳税人类型</text><text>{{selectedHistoryItem.taxpayerType || ''}}</text></view>
          <view class="md-row"><text>所属周期</text><text>{{selectedHistoryItem.period || ''}}</text></view>
          <view class="md-row"><text>申报类型</text><text>{{selectedHistoryItem.declareType || ''}}</text></view>
          <view class="md-row"><text>申报日期</text><text>{{selectedHistoryItem.date || ''}}</text></view>
          <view class="md-divider"></view>
          <view class="md-row" wx:if="{{selectedHistoryItem.detail.taxableIncome}}"><text>收入金额</text><text>{{selectedHistoryItem.detail.taxableIncome || '0.00'}} 元</text></view>
          <view class="md-row" wx:if="{{selectedHistoryItem.detail.deductions}}"><text>扣除金额</text><text>{{selectedHistoryItem.detail.deductions || '0.00'}} 元</text></view>
          <view class="md-row" wx:if="{{selectedHistoryItem.detail.taxRate}}"><text>适用税率</text><text>{{selectedHistoryItem.detail.taxRate || ''}}</text></view>
          <view class="md-row" wx:if="{{selectedHistoryItem.detail.taxDue}}"><text>应纳税额</text><text>¥{{selectedHistoryItem.detail.taxDue || '0.00'}}</text></view>
          <view class="md-divider"></view>
          <view class="md-row md-total"><text>应缴税额</text><text class="gold">¥{{selectedHistoryItem.amount || '0.00'}}</text></view>
          <view class="md-row" wx:if="{{selectedHistoryItem.detail.paid && selectedHistoryItem.detail.paid !== '-'}}"><text>已缴税额</text><text>¥{{selectedHistoryItem.detail.paid || ''}}</text></view>
          <view class="md-row" wx:if="{{selectedHistoryItem.certificateNo}}"><text>完税凭证号</text><text>{{selectedHistoryItem.certificateNo || ''}}</text></view>
          <view class="md-row" wx:if="{{selectedHistoryItem.detail.remarks}}"><text>备注</text><text>{{selectedHistoryItem.detail.remarks || ''}}</text></view>
        </view>
        <view class="modal-btn-group">
          <view class="btn-danger modal-btn" data-id="{{selectedHistoryItem.id || ''}}" catchtap="deleteTaxRecord">🗑 删除</view>
          <view class="btn-gold modal-btn" catchtap="closeTaxDetail">关闭</view>
        </view>
      </view>
    </view>
  </view>

  <!-- ============================================================ -->
  <!-- TAB 2: 代理商 -->
  <!-- ============================================================ -->
  <view wx:if="{{currentTab === 2}}" class="fade-in-up">
    <view class="sub-tab-bar glass-card">
      <view
        class="sub-tab-item {{agentCurrentTab === item.id ? 'active' : ''}}"
        wx:for="{{agentTabs}}"
        wx:key="id"
        data-tab="{{item.id || ''}}"
        bindtap="switchAgentTab"
      >
        <text class="sti-icon">{{item.icon || ''}}</text>
        <text class="sti-name">{{item.name || ''}}</text>
      </view>
    </view>

    <view wx:if="{{agentCurrentTab === 'apply'}}" class="agent-form glass-card">
      <text class="mp-title">📝 代理商入驻申请</text>
      <view class="form-row">
        <text class="form-label">企业名称 *</text>
        <input class="form-input" placeholder="请输入企业全称" value="{{agentForm.company || ''}}" data-field="company" bindinput="agentFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">联系人 *</text>
        <input class="form-input" placeholder="请输入联系人姓名" value="{{agentForm.contact || ''}}" data-field="contact" bindinput="agentFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">手机号 *</text>
        <input class="form-input" type="number" placeholder="请输入手机号" value="{{agentForm.phone || ''}}" data-field="phone" bindinput="agentFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">所在区域</text>
        <input class="form-input" placeholder="省/市/区" value="{{agentForm.region || ''}}" data-field="region" bindinput="agentFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">资质说明</text>
        <input class="form-input" placeholder="营业执照、许可证等" value="{{agentForm.qualification || ''}}" data-field="qualification" bindinput="agentFormInput" />
      </view>
      <view class="form-row">
        <text class="form-label">备注</text>
        <input class="form-input" placeholder="选填" value="{{agentForm.remark || ''}}" data-field="remark" bindinput="agentFormInput" />
      </view>
      <view class="btn-gold submit-btn" catchtap="submitAgentForm">提交入驻申请</view>
    </view>

    <view wx:elif="{{agentCurrentTab === 'list'}}" class="module-panel">
      <view class="section-header">
        <text class="title">代理商列表</text>
      </view>
      <view class="status-filters">
        <view class="sf-item {{agentStatusFilter === 'all' ? 'active' : ''}}" data-filter="all" bindtap="setAgentStatusFilter">全部</view>
        <view class="sf-item {{agentStatusFilter === '待审核' ? 'active' : ''}}" data-filter="待审核" bindtap="setAgentStatusFilter">待审核</view>
        <view class="sf-item {{agentStatusFilter === '已通过' ? 'active' : ''}}" data-filter="已通过" bindtap="setAgentStatusFilter">已通过</view>
