          <view class="btn-gold modal-btn" catchtap="closeCommissionReport">关闭</view>
        </view>
      </view>
    </view>

    <view wx:elif="{{agentCurrentTab === 'performance'}}" class="module-panel">
      <view class="section-header">
        <text class="title">{{userAccountType === 'staff' ? '我的业绩' : '代理商业绩统计'}}</text>
        <text class="header-sub">{{userAccountType !== 'admin' ? '（已按角色过滤）' : '放款金额（元）'}}</text>
      </view>
