<view class="settings-page page-shell">

  <!-- 账号卡片 -->
  <view class="account-card glass-card fade-in-up" style="animation-delay: 0.05s">
    <safe-image src="{{userInfo.avatar || '/images/avatar.webp'}}" className="avatar" mode="aspectFill" />
    <view class="account-info">
      <text class="name">{{userInfo.nickname || '亮叶用户'}}</text>
      <text class="phone">{{userInfo.phone || '未绑定手机号'}}</text>
      <text class="desc">账号用于接收需求进度、线索跟进和合规服务提醒</text>
    </view>
  </view>

  <!-- 快捷状态 -->
  <view class="stat-row fade-in-up" style="animation-delay: 0.1s">
    <view class="stat-item" wx:for="{{quickStats}}" wx:key="label">
      <text class="stat-icon">{{item.icon}}</text>
      <text class="stat-num">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 开发联调面板 -->
  <view class="glass-card dev-panel fade-in-up" style="animation-delay: 0.15s" wx:if="{{showDevPanel}}">
    <view class="section-header">
      <text class="title">🔧 体验版 / 开发联调</text>
    </view>
    <text class="dev-hint">仅开发版与体验版可见，设置存于本机 Storage</text>
    <picker mode="selector" range="{{envOptions}}" range-key="label" value="{{envPickerIndex}}" bindchange="onEnvPickerChange">
      <view class="setting-row">
        <view class="setting-left">
          <text class="setting-icon">🔧</text>
          <view>
            <text class="setting-title">API 环境</text>
            <text class="setting-desc">当前：{{envPickerLabel || ''}}</text>
          </view>
        </view>
        <text class="arrow">›</text>
      </view>
    </picker>
    <view class="setting-row">
      <view class="setting-left">
        <text class="setting-icon">🌐</text>
        <view>
          <text class="setting-title">CDN 图片</text>
          <text class="setting-desc">生产 CDN 开关（失败自动回退本地 PNG）</text>
        </view>
      </view>
      <switch checked="{{useCdnImages}}" color="#0F3D2E" bindchange="onCdnSwitchChange" />
    </view>
    <view class="runtime-summary">{{runtimeSummary || ''}}</view>
    <view class="runtime-summary" wx:if="{{deviceSummary || ''}}">设备：{{deviceSummary || ''}}</view>
    <button class="reset-env-btn" bindtap="resetRuntimeEnv">恢复自动检测</button>
  </view>

  <!-- 体验版信息 -->
  <view class="glass-card trial-panel fade-in-up" style="animation-delay: 0.2s" wx:if="{{showTrialPanel && trialInfo}}">
    <view class="section-header">
      <text class="title">📦 当前体验版</text>
    </view>
    <text class="trial-version">v{{trialInfo.version || ''}}</text>
    <text class="trial-desc">{{trialInfo.desc || ''}}</text>
    <text class="trial-meta">更新于 {{trialInfo.updatedAtLabel || ''}}</text>
    <text class="trial-note">{{trialInfo.note || ''}}</text>
  </view>

  <!-- 偏好设置 -->
  <view class="glass-card fade-in-up" style="animation-delay: 0.25s">
    <view class="section-header">
      <text class="title">⚙️ 偏好设置</text>
    </view>
    <block wx:for="{{settings}}" wx:key="id">
      <view class="setting-row" bindtap="handleSettingTap" data-id="{{item.id}}">
        <view class="setting-left">
          <text class="setting-icon">{{item.icon || '⚙️'}}</text>
          <view>
            <text class="setting-title">{{item.title || ''}}</text>
            <text class="setting-desc">{{item.desc || ''}}</text>
          </view>
        </view>
        <switch wx:if="{{item.hasSwitch}}" checked="{{item.enabled}}" color="#0F3D2E" data-id="{{item.id}}" catchtap="noop" bindchange="handleSwitchChange" />
        <text class="arrow" wx:else>›</text>
      </view>
    </block>
  </view>

  <!-- 服务与支持 -->
  <view class="glass-card fade-in-up" style="animation-delay: 0.3s">
    <view class="section-header">
      <text class="title">📞 服务与支持</text>
    </view>
    <view class="action-row" bindtap="callService">
      <view class="action-left">
        <text class="action-icon">💬</text>
        <view>
          <text class="action-title">智能客服</text>
          <text class="action-desc">AI合规咨询 · {{servicePhone || ''}}</text>
        </view>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="action-row" bindtap="openPrivacy">
      <view class="action-left">
        <text class="action-icon">🔒</text>
        <view>
          <text class="action-title">隐私政策</text>
          <text class="action-desc">个人信息收集范围与授权说明</text>
        </view>
      </view>
      <text class="tag right-tag">查阅</text>
      <text class="arrow">›</text>
    </view>
    <view class="action-row" bindtap="openAgreement">
      <view class="action-left">
        <text class="action-icon">📜</text>
        <view>
          <text class="action-title">用户服务协议</text>
          <text class="action-desc">信息咨询与居间撮合服务条款</text>
        </view>
      </view>
      <text class="tag right-tag">查阅</text>
      <text class="arrow">›</text>
    </view>
    <view class="action-row" bindtap="goNotifications">
      <view class="action-left">
        <text class="action-icon">🔔</text>
        <view>
          <text class="action-title">消息中心</text>
          <text class="action-desc">查看全部通知与提醒记录</text>
        </view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 底部 -->
  <view class="version-tip fade-in-up" style="animation-delay: 0.35s">亮叶企服 v1.0 · 金融信息咨询与居间撮合</view>
  <button class="logout-btn btn-outline fade-in-up" style="animation-delay: 0.4s" bindtap="logout">退出登录</button>
  <view class="page-safe"></view>
</view>
