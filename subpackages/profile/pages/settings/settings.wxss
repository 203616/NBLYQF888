/* ===== 入场动画 ===== */
.fade-in-up {
  animation: fadeInUp 0.5s ease both;
}

.settings-page {
  padding-bottom: 48rpx;
}

/* ===== 账号卡片 ===== */
.account-card {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 4rpx solid rgba(212, 168, 75, 0.4);
}

.account-info {
  flex: 1;
  min-width: 0;
}

.name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.phone {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
  line-height: 1.5;
}

/* ===== 快捷状态统计 ===== */
.stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.stat-row .stat-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 20rpx 8rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
}

.stat-icon {
  display: block;
  font-size: 28rpx;
}

.stat-num {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-top: 6rpx;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* ===== 偏好/服务分组卡片 ===== */
.glass-card {
  padding: var(--space-md) 28rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.section-header .title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  padding-left: 14rpx;
  border-left: 6rpx solid var(--color-gold);
}

/* ===== 设置行 & 操作行 ===== */
.setting-row,
.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.setting-row:last-child,
.action-row:last-child {
  border-bottom: none;
}

.setting-left,
.action-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex: 1;
  min-width: 0;
}

.setting-icon,
.action-icon {
  font-size: 32rpx;
  flex-shrink: 0;
  width: 48rpx;
  text-align: center;
}

.setting-title,
.action-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.setting-desc,
.action-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
  line-height: 1.4;
}

.arrow {
  color: var(--color-text-muted);
  font-size: 36rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.right-tag {
  margin-right: 6rpx;
  flex-shrink: 0;
}

/* ===== 开发面板 ===== */
.dev-panel {
  border: 1rpx dashed rgba(15, 61, 46, 0.25);
}

.dev-hint {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: var(--space-sm);
  line-height: 1.5;
}

.runtime-summary {
  font-size: 22rpx;
  color: var(--color-text-muted);
  background: var(--color-primary-bg);
  border-radius: 12rpx;
  padding: var(--space-sm) 20rpx;
  margin-top: 8rpx;
  white-space: pre-wrap;
  line-height: 1.6;
}

.reset-env-btn {
  margin-top: var(--space-sm);
  font-size: 26rpx;
  color: var(--color-primary);
  background: transparent;
  border: 1rpx solid var(--color-primary);
  border-radius: 999rpx;
  height: 72rpx;
  line-height: 72rpx;
}

/* ===== 体验版 ===== */
.trial-panel .trial-version {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin: 12rpx 0 8rpx;
}

.trial-desc {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.trial-meta,
.trial-note {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin-top: 6rpx;
}

/* ===== 底部 ===== */
.version-tip {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin: var(--space-md) var(--space-md) var(--space-sm);
}

.logout-btn {
  color: var(--color-primary);
  background: var(--color-bg-card);
  border-radius: 999rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0 var(--space-md);
  font-weight: 600;
  border: 2rpx solid var(--color-primary);
}

.page-safe {
  height: calc(env(safe-area-inset-bottom) + 20rpx);
}
