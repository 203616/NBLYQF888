<view class="notifications-page page-shell">
  <view class="notice-hero premium-hero fadeInUp" style="animation-delay:0s">
    <safe-image className="premium-hero-bg" src="/images/banner1.webp" mode="aspectFill" />
    <view class="premium-hero-body">
      <text class="premium-badge">🔔 消息中心</text>
      <text class="premium-hero-title">消息提醒</text>
      <text class="premium-hero-sub">需求进度 · 线索跟进 · 进件状态 · 合规提示</text>
    </view>
  </view>

  <view class="stat-row fadeInUp" style="animation-delay:0.1s">
    <view class="stat-item glass-card" wx:for="{{summary || []}}" wx:key="label">
      <text class="stat-num">{{item.value || '0'}}</text>
      <text class="stat-label">{{item.label || ''}}</text>
    </view>
  </view>

  <view class="action-bar glass-card fadeInUp" style="animation-delay:0.15s">
    <button class="action-btn primary" bindtap="subscribe">📩 订阅微信提醒</button>
    <button class="action-btn outline" bindtap="markAllRead" wx:if="{{unreadCount > 0}}">✅ 全部已读</button>
  </view>

  <view class="filter-tabs fadeInUp" style="animation-delay:0.2s">
    <text class="filter-tab {{filterType === 'all' ? 'active' : ''}}" data-type="all" bindtap="switchFilter">全部</text>
    <text class="filter-tab {{filterType === 'unread' ? 'active' : ''}}" data-type="unread" bindtap="switchFilter">未读({{unreadCount}})</text>
    <text class="filter-tab {{filterType === 'demand' ? 'active' : ''}}" data-type="demand" bindtap="switchFilter">需求</text>
    <text class="filter-tab {{filterType === 'intake' ? 'active' : ''}}" data-type="intake" bindtap="switchFilter">进件</text>
    <text class="filter-tab {{filterType === 'system' ? 'active' : ''}}" data-type="system" bindtap="switchFilter">系统</text>
  </view>

  <block wx:for="{{filteredList || []}}" wx:key="id">
    <view class="notice-card glass-card fadeInUp {{item.status === 'unread' ? 'unread' : ''}}" style="animation-delay:{{0.25 + index * 0.04}}s" data-id="{{item.id}}" bindtap="openNotification">
      <view class="notice-head">
        <view class="notice-left">
          <view class="notice-icon-wrap {{item.status === 'unread' ? 'unread-dot' : ''}}">
            <text class="notice-icon">{{item.icon || '📬'}}</text>
          </view>
          <view class="notice-info">
            <text class="notice-title">{{item.title || ''}}</text>
            <text class="notice-summary">{{item._summary || item.content || ''}}</text>
          </view>
        </view>
        <text class="type-tag type-{{item.type || 'system'}}" style="background:{{item._typeBg || '#F0F0F0'}};color:{{item._typeBadge || '#666'}}">{{item.typeLabel || item.type || '系统'}}</text>
      </view>
      <view class="notice-foot">
        <text class="time">🕐 {{item.createdAt || ''}}</text>
        <text class="link-hint" wx:if="{{item.link}}">查看详情 ›</text>
      </view>
    </view>
  </block>

  <view class="empty glass-card fadeInUp" style="animation-delay:0.3s" wx:if="{{!loading && filteredList.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-title">暂无消息</text>
    <text class="empty-desc">需求进度、线索跟进和系统公告会在这里展示</text>
  </view>

  <!-- ===== Detail Modal ===== -->
  <view class="detail-mask {{showDetail ? 'show' : ''}}" bindtap="closeDetail"></view>
  <view class="detail-panel {{showDetail ? 'show' : ''}}">
    <view class="detail-head">
      <view class="detail-icon-wrap">
        <text class="detail-icon">{{detailItem.icon || '📬'}}</text>
      </view>
      <view class="detail-info">
        <text class="detail-title">{{detailItem.title || ''}}</text>
        <text class="detail-type" style="background:{{detailItem._typeBg || '#F0F0F0'}};color:{{detailItem._typeBadge || '#666'}}">{{detailItem.typeLabel || detailItem.type || ''}}</text>
      </view>
      <view class="detail-close" bindtap="closeDetail">✕</view>
    </view>
    <view class="detail-body">
      <text class="detail-content">{{detailItem.content || ''}}</text>
    </view>
    <view class="detail-foot">
      <text class="detail-time">🕐 {{detailItem.createdAt || ''}}</text>
      <button class="detail-link-btn" wx:if="{{detailItem.link}}" bindtap="goDetailLink">查看详情 ›</button>
    </view>
  </view>

  <view class="page-safe"></view>
</view>
