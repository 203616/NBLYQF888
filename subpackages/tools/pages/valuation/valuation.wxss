@import "../fuel/fuel.wxss";

.form-card { padding: 28rpx; margin-bottom: 20rpx; }
.field { display: flex; justify-content: space-between; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.label { font-size: 28rpx; color: var(--color-text-primary); }
.value, .field input { font-size: 28rpx; color: var(--color-text-muted); text-align: right; }
.submit-btn { margin-top: 24rpx; width: 100%; height: 88rpx; line-height: 88rpx; border-radius: 999rpx; }
.result-card { padding: 32rpx 28rpx; text-align: center; }
.result-label { display: block; font-size: 24rpx; color: var(--color-text-muted); }
.result-value { display: block; font-size: 44rpx; font-weight: 700; color: var(--color-primary); margin-top: 12rpx; }
.result-sub { display: block; font-size: 28rpx; color: var(--color-text-muted); margin-top: 8rpx; }
.tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 10rpx; margin: 20rpx 0; }
.tag { background: var(--color-primary-bg); color: var(--color-primary); font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 999rpx; }
.result-card .compliance { display: block; font-size: 22rpx; color: #aaa; line-height: 1.6; margin-bottom: 20rpx; }
.result-card button { width: 70%; border-radius: 999rpx; margin: 0 auto; }
