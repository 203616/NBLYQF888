@import "../fuel/fuel.wxss";

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Form Card ===== */
.form-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid var(--color-gold);
}

.field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.field:last-of-type {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: var(--color-text-primary);
  flex-shrink: 0;
}

.value,
.field input {
  font-size: 28rpx;
  color: var(--color-text-muted);
  text-align: right;
}

.submit-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: none;
}

/* ===== Photo Grid ===== */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-slot {
  width: 180rpx;
  height: 140rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.photo-preview {
  width: 100%;
  height: 100%;
}

.photo-placeholder {
  font-size: 24rpx;
  color: var(--color-text-muted);
  text-align: center;
}

/* ===== Tip ===== */
.tip-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
}

/* ===== Result ===== */
.result-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.result-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-top: 12rpx;
}

.result-sub {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.result-card .compliance {
  display: block;
  font-size: 22rpx;
  color: #aaa;
  line-height: 1.6;
  margin-bottom: 20rpx;
  margin-top: 12rpx;
}

.tool-page .card {
  margin-bottom: 20rpx;
}
