.tool-page {
  padding-bottom: 40rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Location ===== */
.loc-arrow {
  margin-left: auto;
  color: var(--color-text-muted);
  font-size: 32rpx;
}

/* ===== Price Card ===== */
.price-card {
  padding: 28rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.meta {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.price-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 24rpx 0;
}

.price-item {
  text-align: center;
  padding: 24rpx 12rpx;
  background: var(--color-bg-page);
  border-radius: 16rpx;
}

.price-item.highlight {
  background: var(--color-primary-bg);
}

.fuel-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.fuel-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-top: 8rpx;
}

.fuel-unit {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.compliance {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  text-align: center;
  margin-top: 16rpx;
}

.tool-page .card {
  margin-bottom: 20rpx;
}
