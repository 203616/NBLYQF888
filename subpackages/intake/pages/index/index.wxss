.intake-index .hero-card {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 24rpx;
  height: 280rpx;
}

.hero-img {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx;
  background: linear-gradient(transparent, rgba(15, 61, 46, 0.92));
  color: #fff;
}

.hero-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
}

.hero-desc {
  display: block;
  font-size: 24rpx;
  margin-top: 8rpx;
  opacity: 0.9;
}

.app-no {
  display: block;
  font-size: 22rpx;
  margin-top: 12rpx;
  opacity: 0.75;
}

.progress-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.progress-head {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.progress-num {
  color: var(--color-primary);
  font-weight: bold;
}

.progress-bar {
  height: 16rpx;
  background: var(--color-primary-bg);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--gradient-hero);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-tip {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 12rpx;
}

.demand-link-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-primary);
}

.intro-card {
  background: var(--color-primary-bg);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.intro-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

.intro-line {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.module-section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin: 8rpx 0 16rpx;
}

.module-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
}

.module-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.module-body {
  flex: 1;
  min-width: 0;
}

.module-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.module-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.status-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.status-done { background: #f6ffed; color: #52c41a; }
.status-pending { background: #fff7e6; color: #faad14; }
.status-processing { background: var(--color-primary-bg); color: var(--color-primary); }
.status-locked { background: #f5f5f5; color: #999; }
.status-active { background: #e6f7ff; color: #1890ff; }

.module-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 8rpx;
}

.action-row {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.export-btn,
.submit-btn {
  width: 100%;
}
