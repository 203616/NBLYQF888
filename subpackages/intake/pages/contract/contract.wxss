@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.contract-page {
  padding-bottom: 40rpx;
}

.view-only-banner,
.contract-hero,
.stat-row,
.section-card,
.action-row {
  animation: fadeInUp 0.5s ease both;
}

.view-only-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: var(--space-sm) 20rpx;
  margin: 0 var(--space-md) var(--space-sm);
  font-size: 24rpx;
  color: var(--color-primary);
}

.banner-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.contract-hero {
  margin-bottom: 20rpx;
  min-height: 260rpx;
  background: var(--gradient-hero);
  border-radius: var(--radius-lg);
}

.contract-hero-body {
  text-align: center;
  padding: 40rpx 32rpx !important;
}

.contract-no {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-top: 8rpx;
}

.contract-status {
  display: inline-block;
  margin-top: var(--space-sm);
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.contract-status.status-signed {
  background: rgba(212, 168, 75, 0.9);
  color: var(--color-primary);
}

.sign-date,
.product-name {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin: 0 var(--space-md) 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-num {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.section-card {
  padding: 28rpx;
  margin: 0 var(--space-md) 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: var(--color-primary);
  padding-left: 14rpx;
  border-left: 6rpx solid var(--color-gold);
}

.party-row,
.term-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 26rpx;
  gap: 20rpx;
}

.party-row .label,
.term-label {
  color: var(--color-text-muted);
  flex-shrink: 0;
}

.party-row .value,
.term-value {
  text-align: right;
  color: var(--color-text-primary);
}

.plan-header,
.plan-row {
  display: grid;
  grid-template-columns: 1fr 1.2fr 1fr;
  padding: 12rpx 0;
  font-size: 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.plan-header {
  font-weight: 600;
  color: var(--color-primary);
  background: #e8f0eb;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.plan-amount {
  color: var(--color-primary);
  font-weight: 600;
}

.plan-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.clause-item {
  display: flex;
  gap: 12rpx;
  margin-bottom: var(--space-sm);
}

.clause-num {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: #e8f0eb;
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.clause-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  flex: 1;
}

.action-row {
  display: flex;
  gap: var(--space-sm);
  margin: 8rpx var(--space-md) 0;
}

.action-row .btn-outline,
.action-row .btn-gold {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  margin: 0;
  padding: 0;
}

.page-safe {
  height: calc(env(safe-area-inset-bottom) + 20rpx);
}
