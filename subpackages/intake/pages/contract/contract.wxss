.contract-page {
  padding-bottom: 40rpx;
}

.view-only-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: var(--color-primary);
}

.banner-icon {
  font-size: 32rpx;
}

.contract-hero {
  margin-bottom: 20rpx;
  min-height: 260rpx;
  background: var(--gradient-hero);
  border-radius: var(--radius-lg);
}

.contract-hero-body {
  text-align: center;
  padding: 40rpx 32rpx !important;
}

.contract-no {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-top: 8rpx;
}

.contract-status {
  display: inline-block;
  margin-top: 16rpx;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.contract-status.status-signed {
  background: rgba(212, 168, 75, 0.9);
  color: #0F3D2E;
}

.sign-date, .product-name {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-num {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.section-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: var(--color-primary);
  padding-left: 14rpx;
  border-left: 6rpx solid #D4A84B;
}

.party-row, .term-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 26rpx;
  gap: 20rpx;
}

.party-row .label, .term-label {
  color: var(--color-text-muted);
  flex-shrink: 0;
}

.party-row .value, .term-value {
  text-align: right;
  color: var(--color-text-primary);
}

.plan-header, .plan-row {
  display: grid;
  grid-template-columns: 1fr 1.2fr 1fr;
  padding: 12rpx 0;
  font-size: 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.plan-header {
  font-weight: 600;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.plan-amount {
  color: var(--color-primary);
  font-weight: 600;
}

.plan-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.clause-item {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.clause-num {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.clause-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  flex: 1;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.action-row button {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  margin: 0;
  padding: 0;
}
