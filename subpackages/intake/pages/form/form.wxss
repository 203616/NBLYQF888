@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.form-hero,
.guide-card,
.checklist-card,
.form-card,
.save-btn {
  animation: fadeInUp 0.5s ease both;
}

.form-hero {
  position: relative;
  height: 220rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin: 0 var(--space-md) var(--space-md);
  box-shadow: var(--shadow-card);
}

.form-cover {
  width: 100%;
  height: 100%;
}

.form-hero-text {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx var(--space-md);
  background: linear-gradient(transparent, rgba(15, 61, 46, 0.9));
  color: #fff;
}

.form-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
}

.form-desc {
  display: block;
  font-size: 24rpx;
  margin-top: 6rpx;
  opacity: 0.9;
}

.step-badge {
  display: inline-block;
  margin-top: 10rpx;
  padding: 4rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.95);
}

.guide-card {
  background: #e8f0eb;
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin: 0 var(--space-md) 20rpx;
}

.guide-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

.guide-line {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.progress-mini {
  margin-top: var(--space-sm);
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: bold;
}

.checklist-card {
  padding: 20rpx var(--space-md);
  margin: 0 var(--space-md) 20rpx;
}

.checklist-title {
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  display: block;
  color: var(--color-text-primary);
}

.checklist-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.check-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  background: #f0f5f3;
  color: var(--color-primary);
  border-radius: 999rpx;
}

.hint {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.hint.block {
  margin-bottom: 0;
  margin-top: 4rpx;
}

.form-card {
  padding: 8rpx var(--space-md);
  margin: 0 var(--space-md);
}

.form-item {
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  white-space: nowrap;
}

.form-item.row .label {
  margin-bottom: 0;
}

.req {
  color: var(--color-danger);
}

.input {
  width: 100%;
  font-size: 30rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.picker-value {
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.picker-value {
  padding: 12rpx 0;
}

.save-btn {
  margin: 32rpx var(--space-md) 0;
  width: auto;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
}

.image-upload {
  margin-top: 8rpx;
}

.image-slot {
  position: relative;
  width: 240rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
}

.image-add {
  width: 240rpx;
  height: 160rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.add-icon {
  font-size: 48rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.ocr-tip {
  display: block;
  font-size: 22rpx;
  color: var(--color-primary);
  margin-top: 8rpx;
}

.page-safe {
  height: calc(env(safe-area-inset-bottom) + 40rpx);
}
