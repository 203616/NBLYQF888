<view class="page-shell intake-list-page">
  <view class="premium-hero list-hero fadeInUp">
    <safe-image className="premium-hero-bg" src="/subpackages/intake/images/intake/basic.webp" mode="aspectFill" />
    <view class="premium-hero-body">
      <text class="premium-badge">材料管理</text>
      <text class="premium-hero-title">我的进件</text>
      <text class="premium-hero-sub">查看历史进件、审核进度与放款状态</text>
    </view>
  </view>

  <view class="stat-row">
    <view class="stat-item glass-card fadeInUp" wx:for="{{stats}}" wx:key="label" style="animation-delay:{{index * 0.08}}s">
      <text class="stat-num">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <scroll-view scroll-x class="filter-tabs" enable-flex>
    <text class="filter-tab {{filterStatus === 'all' ? 'active' : ''}}" data-status="all" bindtap="switchFilter">全部</text>
    <text class="filter-tab {{filterStatus === 'draft' ? 'active' : ''}}" data-status="draft" bindtap="switchFilter">草稿</text>
    <text class="filter-tab {{filterStatus === 'auditing' ? 'active' : ''}}" data-status="auditing" bindtap="switchFilter">审核中</text>
    <text class="filter-tab {{filterStatus === 'done' ? 'active' : ''}}" data-status="done" bindtap="switchFilter">已通过</text>
  </scroll-view>

  <block wx:for="{{filteredList}}" wx:key="applicationNo">
    <view class="intake-card glass-card" bindtap="openIntake" data-type="{{item.productType}}" data-name="{{item.productName}}" data-no="{{item.applicationNo}}">
      <view class="card-head">
        <text class="card-title">{{item.productName}}</text>
        <text class="status-tag status-{{item.status}}">{{item.statusText}}</text>
      </view>
      <text class="card-no sensitive-data {{sensitiveDisplay ? 'active' : ''}}">进件编号 {{item.applicationNo}}</text>
      <view class="meta-row">
        <text>类型：{{item.productType === 'newCar' ? '新车' : item.productType === 'business' ? '经营贷' : item.productType === 'personal' ? '个人贷' : item.productType === 'warranty' ? '延保' : item.productType === 'mortgage' ? '车抵' : '综合'}}</text>
        <text wx:if="{{item.isLocal}}">本地</text>
      </view>
      <view class="progress-row">
        <view class="progress-bar"><view class="progress-fill" style="width: {{item.progress}}%;"></view></view>
        <text class="progress-text">{{item.progress}}%</text>
      </view>
      <text class="time-text" wx:if="{{item.updatedAt}}">更新于 {{item.updatedAt}}</text>
    </view>
  </block>

  <view class="empty glass-card" wx:if="{{!loading && filteredList.length === 0}}">
    <text class="empty-title">暂无进件记录</text>
    <text class="empty-desc">点击下方按钮创建第一份进件材料</text>
  </view>

    <view class="action-row">
    <button class="btn-gold" bindtap="createIntake">新建进件</button>
  </view>

  <!-- 敏感信息开关 -->
  <view class="sensitive-toggle card" bindtap="toggleSensitiveDisplay">
    <text class="toggle-label">敏感信息显示</text>
    <view class="toggle-switch {{sensitiveDisplay ? 'on' : ''}}">
      <view class="toggle-knob"></view>
    </view>
  </view>

  <view class="page-safe"></view>
</view>
