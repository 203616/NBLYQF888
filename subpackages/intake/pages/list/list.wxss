.intake-list-page .list-hero {
  margin-bottom: 24rpx;
}

.filter-tabs {
  display: flex;
  white-space: nowrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.filter-tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--brand-muted, #6b7280);
  background: rgba(255, 255, 255, 0.7);
}

.filter-tab.active {
  color: #fff;
  background: var(--brand-primary, #0F3D2E);
}

.intake-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--brand-primary, #0F3D2E);
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
}

.status-tag.status-auditing { background: #fef3c7; color: #b45309; }
.status-tag.status-approved,
.status-tag.status-disbursed,
.status-tag.status-archived { background: #d1fae5; color: #047857; }
.status-tag.status-draft { background: #e5e7eb; color: #4b5563; }

.card-no {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.progress-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #e5e7eb;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0F3D2E, #2d6a4f);
  border-radius: 999rpx;
}

.progress-text {
  font-size: 24rpx;
  color: var(--brand-primary, #0F3D2E);
  min-width: 64rpx;
}

.time-text {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.empty {
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: var(--brand-primary, #0F3D2E);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #6b7280;
}

.action-row {
  padding: 24rpx 0 48rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #0F3D2E, #1b5e40);
  color: #fff;
  border-radius: 999rpx;
}
