.clue-page {
  padding-bottom: 40rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Location ===== */
.loc-arrow {
  margin-left: auto;
  color: var(--color-text-muted);
  font-size: 32rpx;
}

/* ===== Intro Card ===== */
.intro-card {
  padding: 24rpx var(--space-md);
  margin-bottom: var(--space-md);
}

.intro-row {
  display: flex;
  gap: var(--space-sm);
  align-items: flex-start;
}

.intro-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.intro-body {
  flex: 1;
}

.intro-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-primary);
  margin-bottom: 6rpx;
}

.intro-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* ===== Entry Grid ===== */
.entry-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: var(--space-md);
}

.entry-card {
  text-align: center;
  padding: 24rpx 12rpx;
}

.entry-icon-circle {
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto 10rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(15, 61, 46, 0.1);
}

.entry-icon {
  font-size: 32rpx;
  display: block;
}

.entry-title {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

/* ===== Stat Row ===== */
.stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-num {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* ===== Tabs ===== */
.tabs {
  white-space: nowrap;
  margin-bottom: 20rpx;
  display: flex;
}

/* ===== Clue Card ===== */
.clue-card {
  padding: var(--space-md);
  margin-bottom: 16rpx;
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.card-head .title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  flex: 1;
}

/* ===== Status Tag ===== */
.status-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin-top: 12rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 14rpx;
}

.meta-row.secondary {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.meta-item {
  white-space: nowrap;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tag-row .tag {
  color: var(--color-primary);
  background: var(--color-primary-bg);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
}

/* ===== Empty State ===== */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: var(--color-text-muted);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: var(--color-text-muted);
}
