.clue-detail {
  padding-bottom: 160rpx;
}

.detail-hero {
  margin-bottom: 20rpx;
  min-height: 200rpx;
  background: var(--gradient-hero);
  border-radius: var(--radius-lg);
}

.price {
  font-size: 36rpx !important;
  font-weight: 700;
  color: #D4A84B !important;
  margin-top: 12rpx;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
}

.status-label {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.status-value {
  font-size: 28rpx;
  font-weight: 700;
}

.info-card, .desc-card {
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid #D4A84B;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 26rpx;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  color: var(--color-text-muted);
}

.value {
  color: var(--color-text-primary);
  text-align: right;
  max-width: 60%;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.tag {
  background: #fff;
  color: var(--color-primary);
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  box-shadow: var(--shadow-card);
}

.desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
  line-height: 1.7;
}

.related-action {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f7f9fc;
  border-radius: 14rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
}

.related-action:last-child {
  margin-bottom: 0;
}

.related-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.related-title {
  display: block;
  color: var(--color-primary);
  font-size: 28rpx;
  font-weight: 600;
}

.related-desc {
  display: block;
  color: var(--color-text-muted);
  font-size: 22rpx;
  margin-top: 4rpx;
}

.arrow {
  margin-left: auto;
  color: var(--color-text-muted);
  font-size: 32rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -4rpx 24rpx rgba(15, 61, 46, 0.08);
}

.action-bar button {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  margin: 0;
  padding: 0;
}

.loading {
  text-align: center;
  padding: 120rpx;
  color: var(--color-text-muted);
}
