@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.onboarding-page {
  padding: var(--space-md) 32rpx 160rpx;
}

.onboarding-hero,
.step-indicator,
.panel,
.action-bar {
  animation: fadeInUp 0.5s ease both;
}

.onboarding-hero {
  margin-bottom: 32rpx;
  min-height: 220rpx;
}

.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: #e8ecef;
  color: var(--color-text-muted);
  font-size: 24rpx;
}

.step-dot.active {
  background: var(--color-primary);
  color: #fff;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: #e8ecef;
  margin: 0 8rpx;
}

.step-line.active {
  background: var(--color-primary);
}

.panel {
  padding: 32rpx;
  margin-bottom: var(--space-md);
}

.panel-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

.panel-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  margin-bottom: 28rpx;
}

.agree-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border: 2rpx solid var(--color-primary);
  border-radius: 8rpx;
  margin-right: var(--space-sm);
  font-size: 22rpx;
  color: #fff;
  flex-shrink: 0;
}

.checkbox.checked {
  background: var(--color-primary);
}

.agree-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--color-text-primary);
}

.link {
  color: var(--color-primary);
}

.compliance-note {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin-top: var(--space-sm);
  padding-top: var(--space-sm);
  border-top: 1rpx solid #e8ecef;
}

.phone-btn,
.loc-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  margin-bottom: 20rpx;
  border-radius: 999rpx;
}

.or-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin: var(--space-sm) 0;
}

.phone-input {
  width: 100%;
  height: 88rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  padding: 0 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.loc-status {
  padding: var(--space-md);
  background: #e8f0eb;
  border-radius: var(--radius-md);
  margin-bottom: 20rpx;
}

.loc-ok {
  color: var(--color-primary);
  font-size: 28rpx;
}

.skip-link {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: var(--space-sm);
}

.action-bar {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 48rpx;
}

.action-bar .btn-gold {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
}

.page-safe {
  height: calc(env(safe-area-inset-bottom) + 120rpx);
}
