<view class="auth-page page-shell">
  <view class="auth-hero premium-hero">
    <view class="premium-hero-body">
      <text class="premium-badge">账号安全</text>
      <text class="premium-hero-title">重置密码</text>
      <text class="premium-hero-sub">通过手机验证码重置登录密码</text>
    </view>
  </view>

  <view class="form-card glass-card">
    <view class="field">
      <text class="label">手机号</text>
      <input type="number" placeholder="请输入手机号" bindinput="bindPhoneInput" value="{{phone}}" maxlength="11" />
    </view>
    <view class="field sms-row">
      <view class="sms-input">
        <text class="label">验证码</text>
        <input type="number" placeholder="请输入验证码" bindinput="bindSmsInput" value="{{smsCode}}" maxlength="6" />
      </view>
      <button class="sms-btn" disabled="{{countdown > 0 || !isValidPhone}}" bindtap="sendSmsCode">{{countdown > 0 ? countdown + 's' : '获取验证码'}}</button>
    </view>
    <view class="field">
      <text class="label">新密码</text>
      <input type="password" placeholder="6-20位字符" password bindinput="bindPasswordInput" value="{{password}}" />
    </view>
    <button class="submit-btn btn-gold" bindtap="handleSubmit" disabled="{{isSubmitting}}">{{isSubmitting ? '处理中...' : '重置密码'}}</button>
    <text class="compliance">本平台仅提供信息撮合服务</text>
  </view>
</view>
