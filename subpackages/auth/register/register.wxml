<view class="auth-page page-shell">
  <view class="auth-hero premium-hero">
    <view class="premium-hero-body">
      <text class="premium-badge">账号注册</text>
      <text class="premium-hero-title">加入亮叶企服</text>
      <text class="premium-hero-sub">注册后即可使用进件、需求发布等服务</text>
    </view>
  </view>

  <view class="form-card glass-card">
    <view class="field">
      <text class="label">手机号</text>
      <input type="number" placeholder="请输入手机号" bindinput="bindPhoneInput" value="{{phone}}" maxlength="11" />
    </view>
    <view class="field sms-row">
      <view class="sms-input">
        <text class="label">验证码</text>
        <input type="number" placeholder="请输入验证码" bindinput="bindSmsInput" value="{{smsCode}}" maxlength="6" />
      </view>
      <button class="sms-btn" disabled="{{countdown > 0}}" bindtap="sendSmsCode">{{countdown > 0 ? countdown + 's' : '获取验证码'}}</button>
    </view>
    <view class="field">
      <text class="label">设置密码</text>
      <input type="password" placeholder="6-20位字符" password bindinput="bindPasswordInput" value="{{password}}" maxlength="20" />
    </view>
    <button class="submit-btn btn-gold" bindtap="handleRegister">注册</button>
    <view class="login-link">已有账号？<text bindtap="navigateToLogin">立即登录</text></view>
    <text class="compliance">本平台仅提供信息撮合服务，不发放贷款</text>
  </view>
</view>
