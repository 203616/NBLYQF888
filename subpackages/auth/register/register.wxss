@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.auth-page {
  padding-bottom: 40rpx;
  min-height: 100vh;
}

.auth-hero {
  margin-bottom: var(--space-md);
  min-height: 180rpx;
  background: var(--gradient-hero);
  border-radius: var(--radius-lg);
}

.auth-hero,
.form-card {
  animation: fadeInUp 0.5s ease both;
}

.form-card {
  padding: 32rpx 28rpx;
  margin: 0 var(--space-md);
}

.field {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 10rpx;
}

.field input {
  font-size: 30rpx;
  color: var(--color-text-primary);
  width: 100%;
}

.sms-row {
  display: flex;
  align-items: flex-end;
  gap: var(--space-sm);
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 20rpx;
}

.sms-input {
  flex: 1;
}

.sms-btn {
  flex-shrink: 0;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  background: #e8f0eb;
  color: var(--color-primary);
  border-radius: 999rpx;
  margin: 0;
  padding: 0 var(--space-md);
  border: none;
}

.sms-btn[disabled] {
  opacity: 0.6;
}

.submit-btn {
  margin-top: 32rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
}

.login-link {
  text-align: center;
  margin-top: var(--space-md);
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.login-link text {
  color: var(--color-primary);
  font-weight: 600;
}

.compliance {
  display: block;
  text-align: center;
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #aaa;
}

.page-safe {
  height: calc(env(safe-area-inset-bottom) + 20rpx);
}
