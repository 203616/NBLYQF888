.auth-page { padding-bottom: 40rpx; min-height: 100vh; }
.auth-hero { margin-bottom: 24rpx; min-height: 180rpx; background: var(--gradient-hero); border-radius: var(--radius-lg); }
.form-card { padding: 32rpx 28rpx; }
.field { padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.label { display: block; font-size: 24rpx; color: var(--color-text-muted); margin-bottom: 10rpx; }
.field input { font-size: 30rpx; color: var(--color-text-primary); }
.sms-row { display: flex; align-items: flex-end; gap: 16rpx; border-bottom: 1rpx solid #f0f0f0; padding-bottom: 20rpx; }
.sms-input { flex: 1; }
.sms-btn { flex-shrink: 0; height: 64rpx; line-height: 64rpx; font-size: 24rpx; background: var(--color-primary-bg); color: var(--color-primary); border-radius: 999rpx; margin: 0; padding: 0 24rpx; }
.sms-btn[disabled] { opacity: 0.6; }
.submit-btn { margin-top: 32rpx; width: 100%; height: 88rpx; line-height: 88rpx; border-radius: 999rpx; }
.login-link { text-align: center; margin-top: 24rpx; font-size: 26rpx; color: var(--color-text-muted); }
.login-link text { color: var(--color-primary); font-weight: 600; }
.compliance { display: block; text-align: center; margin-top: 20rpx; font-size: 22rpx; color: #aaa; }
