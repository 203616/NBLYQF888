.tips-page {
  padding-bottom: 40rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Stat Row ===== */
.stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-num {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* ===== Action Bar ===== */
.action-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
}

.action-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  margin: 0;
  padding: 0;
}

/* ===== Filter ===== */
.filter-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

/* ===== Tip Card ===== */
.tip-card {
  display: flex;
  overflow: hidden;
  margin-bottom: 16rpx;
  padding: 0 !important;
}

.cover-thumb {
  width: 180rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.tip-body {
  flex: 1;
  padding: 20rpx;
  min-width: 0;
}

.tip-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.category {
  font-size: 22rpx;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.risk-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.risk-badge.risk-high,
.risk-high {
  background: #f5222d;
  color: #fff;
}

.risk-badge.risk-medium,
.risk-medium {
  background: #faad14;
  color: #fff;
}

.risk-badge.risk-low,
.risk-low {
  background: #52c41a;
  color: #fff;
}

.tip-body .title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.summary {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.tip-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}
