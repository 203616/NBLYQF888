.tip-detail {
  padding-bottom: 160rpx;
}

.detail-hero {
  margin-bottom: 20rpx;
  min-height: 180rpx;
  background: var(--gradient-hero);
  border-radius: var(--radius-lg);
}

.detail-hero.level-high {
  background: linear-gradient(135deg, #8B1A1A, #C0392B);
}

.section {
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid #D4A84B;
}

.paragraph, .rich-content {
  font-size: 26rpx;
  color: var(--color-text-muted);
  line-height: 1.8;
}

.prevention-item {
  display: flex;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.prevention-item:last-child {
  border-bottom: none;
}

.step-num {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  font-size: 22rpx;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

.related-card {
  background: #f7f9fc;
  border-radius: 14rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
}

.related-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.related-desc, .related-meta {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -4rpx 24rpx rgba(15, 61, 46, 0.08);
}

.action-bar button {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  margin: 0;
  padding: 0;
}
