<view class="page-shell finance-page finance-list">
  <view class="finance-hero">
    <safe-image className="finance-hero-img" src="/images/banner1.webp" mode="aspectFill" />
    <view class="finance-hero-mask"></view>
    <view class="finance-hero-body">
      <text class="finance-badge">汽车金融专区</text>
      <text class="finance-hero-title">汽车融资服务</text>
      <text class="finance-hero-sub">新车按揭 · 二手车融资 · 车抵周转 · 配套计算器与估值工具</text>
    </view>
  </view>

  <view class="stat-strip">
    <view class="stat-chip glass-card" wx:for="{{stats}}" wx:key="label">
      <text class="stat-chip-num">{{item.value}}</text>
      <text class="stat-chip-label">{{item.label}}</text>
    </view>
  </view>

  <view class="section-block">
    <view class="section-head">
      <text class="section-head-title">持牌机构产品</text>
      <text class="section-head-more">共 {{products.length}} 款 · 宁波地区</text>
    </view>
    <scroll-view scroll-x class="filter-tabs" enable-flex>
      <block wx:for="{{filterTypes}}" wx:key="id">
        <view class="filter-tab {{filterType === item.id ? 'active' : ''}}" data-type="{{item.id}}" bindtap="switchFilter">{{item.name}}</view>
      </block>
    </scroll-view>
    <block wx:for="{{filteredProducts}}" wx:key="id">
      <view class="product-card glass-card">
        <safe-image className="product-cover" src="{{item.cover || ''}}" mode="aspectFill" bindtap="navigateToPage" data-url="{{item.url}}" />
        <view class="product-body" bindtap="navigateToPage" data-url="{{item.url}}">
          <view class="product-top">
            <text class="iconfont product-icon">{{item.icon}}</text>
            <view class="info">
              <text class="title">{{item.title}}</text>
              <text class="institution">{{item.institution}} · {{item.region}}</text>
              <view class="tag-row">
                <text class="mini-tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
              </view>
            </view>
          </view>
          <text class="desc">{{item.desc}}</text>
          <view class="product-meta">
            <text class="meta-item">额度 {{item.amount}}</text>
            <text class="meta-item">期限 {{item.term}}</text>
          </view>
          <text class="rate">{{item.rate}}</text>
        </view>
        <button class="apply-mini btn-gold" catchtap="goIntake" data-item="{{item}}">咨询进件</button>
      </view>
    </block>
  </view>

  <view class="section-block">
    <view class="section-head">
      <text class="section-head-title">为什么选择亮叶</text>
    </view>
    <view class="feature-grid">
      <block wx:for="{{advantages}}" wx:key="title">
        <view class="feature-cell">
          <text class="feature-cell-icon">{{item.icon}}</text>
          <text class="feature-cell-title">{{item.title}}</text>
          <text class="feature-cell-desc">{{item.desc}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="section-block">
    <view class="section-head">
      <text class="section-head-title">实用工具</text>
    </view>
    <view class="tool-grid">
      <block wx:for="{{tools}}" wx:key="id">
        <view class="tool-card glass-card" bindtap="navigateToPage" data-url="{{item.url}}">
          <text class="iconfont tool-icon">{{item.icon}}</text>
          <text class="title">{{item.title}}</text>
          <text class="desc">{{item.desc}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="section-block">
    <view class="section-head">
      <text class="section-head-title">办理流程</text>
    </view>
    <view class="info-card glass-card">
      <view class="process-timeline">
        <block wx:for="{{processSteps}}" wx:key="title">
          <view class="process-node">
            <text class="process-dot">{{index + 1}}</text>
            <view class="process-content">
              <text class="process-title">{{item.title}}</text>
              <text class="process-desc">{{item.desc}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="section-block">
    <view class="section-head">
      <text class="section-head-title">常见问题</text>
    </view>
    <view class="info-card glass-card">
      <block wx:for="{{faqs}}" wx:key="q">
        <view class="faq-item">
          <text class="faq-q">Q：{{item.q}}</text>
          <text class="faq-a">{{item.a}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="compliance-banner">
    <text>{{complianceNote}}</text>
  </view>
</view>
