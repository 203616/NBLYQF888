@import '../common/finance-theme.wxss';

.finance-list {
  padding-bottom: 40rpx;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Product Card ===== */
.product-card {
  display: flex;
  flex-wrap: wrap;
  align-items: stretch;
  margin-bottom: 20rpx;
  overflow: hidden;
  padding: 0;
  position: relative;
}

.product-cover {
  width: 180rpx;
  flex-shrink: 0;
  border-radius: var(--radius-md) 0 0 var(--radius-md);
  overflow: hidden;
}

.product-body {
  flex: 1;
  padding: 20rpx;
  min-width: 0;
}

.product-top {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

/* ===== Icon Wrapper ===== */
.product-icon-wrap {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-icon {
  font-size: 32rpx;
}

.info { flex: 1; min-width: 0; }

/* ===== Title Row with Badge ===== */
.title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.product-body .title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  display: block;
  flex: 1;
}

/* ===== Badge Styles ===== */
.badge {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.badge-hot {
  background: linear-gradient(135deg, #FF6B6B, #EE4444);
  color: #fff;
}

.badge-value {
  background: linear-gradient(135deg, #FFB74D, #FF9800);
  color: #fff;
}

.badge-fast {
  background: linear-gradient(135deg, #66BB6A, #43A047);
  color: #fff;
}

.desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
  display: block;
  line-height: 1.5;
}

.product-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 10rpx;
}

.meta-item {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.rate {
  font-size: 22rpx;
  color: var(--color-primary);
  margin-top: 8rpx;
  display: block;
}

/* ===== Tool Grid ===== */
.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.tool-card {
  text-align: center;
  padding: 28rpx 20rpx;
}

.tool-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 12rpx;
  border-radius: 20rpx;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-icon {
  font-size: 36rpx;
}

.tool-card .title {
  font-size: 28rpx;
}

.tool-card .desc {
  font-size: 22rpx;
  margin-top: 6rpx;
}

/* ===== Feat Icon Wrapper ===== */
.feat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 16rpx;
  border-radius: 20rpx;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.feat-icon {
  font-size: 36rpx;
}

/* ===== Filters ===== */
.filter-tabs {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.filter-tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  font-size: 24rpx;
  background: var(--color-primary-bg);
  color: var(--color-text-secondary);
  border-radius: 999rpx;
}

.filter-tab.active {
  background: var(--color-primary);
  color: #fff;
}

/* ===== Institution ===== */
.institution {
  display: block;
  font-size: 22rpx;
  color: var(--color-primary);
  margin: 4rpx 0;
}

/* ===== Apply Button ===== */
.apply-mini {
  font-size: 24rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  padding: 0 24rpx !important;
  margin: 12rpx 20rpx 20rpx;
  width: auto !important;
  display: inline-block;
  border: none;
}
