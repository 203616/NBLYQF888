/* 汽车金融子包 — 共享视觉主题 */
.finance-page {
  padding-bottom: 140rpx;
  background: var(--color-bg-page, #f7f9fc);
}

.finance-hero {
  position: relative;
  min-height: 360rpx;
  margin-bottom: 24rpx;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  overflow: hidden;
}

.finance-hero-img {
  width: 100%;
  height: 360rpx;
}

.finance-hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(15, 61, 46, 0.15) 0%, rgba(15, 61, 46, 0.88) 100%);
}

.finance-hero-body {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx;
  color: #fff;
}

.finance-badge {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(212, 168, 75, 0.95);
  color: #0F3D2E;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.finance-hero-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.finance-hero-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.92);
}

.stat-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin: -48rpx 24rpx 24rpx;
  position: relative;
  z-index: 2;
}

.stat-chip {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-chip-num {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-chip-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.section-block {
  margin: 0 24rpx 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-head-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.section-head-more {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.info-card {
  padding: 28rpx;
  margin-bottom: 16rpx;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.feature-cell {
  padding: 20rpx;
  background: var(--color-primary-bg);
  border-radius: var(--radius-md);
}

.feature-cell-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
  display: block;
}

.feature-cell-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.feature-cell-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
  line-height: 1.5;
}

.process-timeline {
  padding-left: 8rpx;
}

.process-node {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.process-dot {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--gradient-hero);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.process-content {
  flex: 1;
  padding-bottom: 8rpx;
  border-bottom: 1rpx dashed #e5e7eb;
}

.process-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.process-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
  line-height: 1.5;
}

.faq-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.faq-q {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.faq-a {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 10rpx;
  line-height: 1.6;
}

.compliance-banner {
  margin: 0 24rpx 24rpx;
  padding: 20rpx 24rpx;
  background: #fff8e6;
  border-radius: var(--radius-md);
  border-left: 6rpx solid #D4A84B;
}

.compliance-banner text {
  display: block;
  font-size: 22rpx;
  color: #8a6d2b;
  line-height: 1.7;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -4rpx 24rpx rgba(15, 61, 46, 0.08);
  display: flex;
  gap: 16rpx;
}

.action-bar .btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  background: #f0f5f3;
  color: var(--color-primary);
  border: none;
}

.action-bar .btn-primary {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  background: var(--gradient-hero);
  color: #fff;
  border: none;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.mini-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(15, 61, 46, 0.08);
  color: var(--color-primary);
}
