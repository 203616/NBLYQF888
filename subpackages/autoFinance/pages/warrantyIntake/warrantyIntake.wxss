/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Step Bar ===== */
.step-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: var(--space-md);
}

.step-item {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  background: #eee;
  border-radius: 8rpx;
  color: var(--color-text-secondary);
}

.step-item.active {
  background: var(--color-primary);
  color: #fff;
}

/* ===== Panel ===== */
.panel {
  padding: 28rpx;
  margin-bottom: var(--space-md);
}

.panel-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-primary);
  margin-bottom: 20rpx;
  display: block;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--color-gold);
}

/* ===== Field ===== */
.field {
  width: 100%;
  height: 80rpx;
  background: var(--color-bg-page);
  border-radius: 12rpx;
  padding: 0 var(--space-md);
  margin-bottom: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

/* ===== Photo Row ===== */
.photo-row {
  padding: var(--space-md);
  background: var(--color-primary-bg);
  border-radius: 12rpx;
  margin-top: 12rpx;
  color: var(--color-primary);
  font-size: 26rpx;
  text-align: center;
}

/* ===== Actions ===== */
.actions {
  display: flex;
  gap: 16rpx;
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 40rpx;
}

.actions button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  margin: 0;
}

/* ===== Misc ===== */
.hint {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 16rpx;
  line-height: 1.6;
}

.contract-preview {
  margin-top: 16rpx;
  padding: 16rpx;
  background: var(--color-bg-page);
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  max-height: 400rpx;
  overflow-y: auto;
}

.plan-desc {
  display: block;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
