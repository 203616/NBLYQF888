/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Block Title ===== */
.block-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid var(--color-gold);
}

/* ===== Cards ===== */
.claim-page .card {
  margin-bottom: var(--space-sm);
  padding: var(--space-md);
}

/* ===== Flow Items ===== */
.flow-item {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.flow-item:last-child {
  border-bottom: none;
}

.flow-num {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: var(--color-primary);
  color: #fff;
  border-radius: 50%;
  font-size: 22rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.flow-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.flow-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* ===== Field Row ===== */
.field-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.field-row:last-child {
  border-bottom: none;
}

.field-row.column {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.input,
.textarea,
.picker-val {
  font-size: 28rpx;
}

.input:placeholder,
.textarea:placeholder {
  color: var(--color-text-muted);
}

.textarea {
  width: 100%;
  min-height: 120rpx;
  background: var(--color-bg-page);
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

/* ===== Photo Grid ===== */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.photo-item {
  position: relative;
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.photo-item .safe-image {
  width: 100%;
  height: 100%;
}

.remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 28rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  z-index: 1;
}

.photo-add {
  width: 160rpx;
  height: 120rpx;
  border: 2rpx dashed #ccc;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
  background: var(--color-bg-page);
}

/* ===== Actions ===== */
.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.actions button {
  flex: 1;
  margin: 0;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
}

/* ===== Claim History ===== */
.claim-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.claim-row:last-child {
  border-bottom: none;
}

.claim-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.claim-meta {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.claim-status {
  font-size: 24rpx;
  color: var(--color-primary);
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.muted {
  color: var(--color-text-muted);
  font-size: 24rpx;
}

/* ===== Override premium-hero min-height ===== */
.premium-hero {
  margin-bottom: 20rpx;
}
