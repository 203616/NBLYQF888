.claim-page { padding-bottom: 40rpx; }
.claim-hero { min-height: 200rpx; margin-bottom: 20rpx; background: var(--gradient-hero); border-radius: var(--radius-lg); }
.block-title { display: block; font-size: 30rpx; font-weight: 700; color: var(--color-primary); margin-bottom: 16rpx; padding-left: 14rpx; border-left: 6rpx solid #D4A84B; }
.flow-card, .form-card, .history-card { padding: 24rpx; margin-bottom: 16rpx; }
.flow-item { display: flex; gap: 16rpx; padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.flow-item:last-child { border-bottom: none; }
.flow-num { width: 40rpx; height: 40rpx; line-height: 40rpx; text-align: center; background: var(--color-primary); color: #fff; border-radius: 50%; font-size: 22rpx; flex-shrink: 0; }
.flow-title { display: block; font-size: 28rpx; font-weight: 600; }
.flow-desc { display: block; font-size: 24rpx; color: var(--color-text-muted); margin-top: 4rpx; }
.field-row { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.field-row.column { border-bottom: none; }
.label { display: block; font-size: 26rpx; color: var(--color-text-secondary); margin-bottom: 8rpx; }
.input, .textarea, .picker-val { font-size: 28rpx; }
.textarea { width: 100%; min-height: 120rpx; }
.photo-grid { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 8rpx; }
.photo-item { position: relative; width: 160rpx; height: 120rpx; border-radius: 8rpx; overflow: hidden; }
.photo-item image { width: 100%; height: 100%; }
.remove { position: absolute; top: 4rpx; right: 4rpx; width: 32rpx; height: 32rpx; line-height: 28rpx; text-align: center; background: rgba(0,0,0,0.5); color: #fff; border-radius: 50%; }
.photo-add { width: 160rpx; height: 120rpx; border: 2rpx dashed #ccc; border-radius: 8rpx; display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: #999; }
.actions { display: flex; gap: 16rpx; margin-top: 20rpx; }
.actions button { flex: 1; margin: 0; }
.claim-row { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.claim-desc { display: block; font-size: 26rpx; }
.claim-meta { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.claim-status { font-size: 24rpx; color: var(--color-primary); flex-shrink: 0; }
.muted { color: #999; font-size: 24rpx; }
