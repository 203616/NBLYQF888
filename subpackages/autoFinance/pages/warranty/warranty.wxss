.warranty-page {
  padding-bottom: 40rpx;
  background: var(--color-bg-page, #f7f9fc);
  min-height: 100vh;
}

.warranty-hero {
  position: relative;
  height: 380rpx;
  overflow: hidden;
}

.warranty-hero-img {
  width: 100%;
  height: 100%;
}

.warranty-hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(15, 61, 46, 0.1) 0%, rgba(15, 61, 46, 0.9) 100%);
}

.warranty-hero-body {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx;
  color: #fff;
}

.warranty-badge {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(212, 168, 75, 0.95);
  color: #0F3D2E;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.warranty-hero-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
}

.warranty-hero-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.92);
}

.plan-tabs {
  display: flex;
  margin: -40rpx 24rpx 20rpx;
  position: relative;
  z-index: 2;
  padding: 8rpx;
  gap: 8rpx;
}

.plan-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 12rpx;
  border-radius: var(--radius-md);
  transition: all 0.2s;
}

.plan-tab.active {
  background: var(--gradient-hero);
  color: #fff;
}

.plan-tab-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
}

.plan-tab-price {
  display: block;
  font-size: 22rpx;
  margin-top: 4rpx;
  opacity: 0.85;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin: 0 24rpx 24rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-num {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.section-block {
  margin: 0 24rpx 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-head-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.plan-price-tag {
  font-size: 28rpx;
  font-weight: 700;
  color: #D4A84B;
}

.plan-card {
  padding: 28rpx;
}

.plan-intro {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.benefit-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.benefit-check {
  color: var(--color-primary);
  font-weight: 700;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.benefit-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.coverage-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.coverage-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.compare-card {
  padding: 0;
  overflow: hidden;
}

.compare-header,
.compare-row {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  text-align: center;
}

.compare-header {
  background: var(--color-primary-bg);
  font-weight: 600;
  font-size: 24rpx;
  color: var(--color-primary);
}

.compare-header .compare-col,
.compare-row .compare-col {
  padding: 18rpx 8rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 24rpx;
}

.compare-row .compare-col.name {
  text-align: left;
  padding-left: 20rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.process-card {
  padding: 24rpx;
}

.flow-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.flow-index {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--gradient-hero);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.flow-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.flow-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
  line-height: 1.5;
}

.faq-card {
  padding: 8rpx 24rpx;
}

.faq-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.faq-q {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.faq-a {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 10rpx;
  line-height: 1.6;
}

.apply-card {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
}

.apply-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.apply-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin: 10rpx 0 20rpx;
  line-height: 1.5;
}

.apply-input {
  background: #f7f9fc;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.apply-actions {
  display: flex;
  gap: 16rpx;
}

.apply-actions button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  margin: 0;
  padding: 0;
}

.compliance-tip {
  margin: 0 24rpx;
  padding: 20rpx;
  text-align: center;
}

.compliance-tip text {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.7;
}
