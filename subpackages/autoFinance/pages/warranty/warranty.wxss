.warranty-page {
  padding-bottom: 40rpx;
  background: var(--color-bg-page);
  min-height: 100vh;
}

/* ===== Animations ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fadeInUp {
  animation: fadeInUp 0.5s ease both;
}

/* ===== Plan Tabs ===== */
.plan-tabs {
  display: flex;
  margin: -40rpx var(--space-md) 20rpx;
  position: relative;
  z-index: 2;
  padding: 8rpx;
  gap: 8rpx;
}

.plan-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 12rpx;
  border-radius: var(--radius-md);
  transition: all 0.2s;
}

.plan-tab.active {
  background: var(--gradient-hero);
  color: #fff;
}

.plan-tab-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
}

.plan-tab-price {
  display: block;
  font-size: 22rpx;
  margin-top: 4rpx;
  opacity: 0.85;
}

/* ===== Stat Row ===== */
.stat-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin: 0 var(--space-md) var(--space-md);
}

.stat-item {
  text-align: center;
  padding: 20rpx 8rpx;
}

.stat-item .stat-num {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-item .stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* ===== Section Block ===== */
.section-block {
  margin: 0 var(--space-md) var(--space-md);
}

.plan-price-tag {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-gold);
}

/* ===== Plan Card ===== */
.plan-card {
  padding: 28rpx;
}

.plan-intro {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.benefit-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.benefit-check-wrap {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 12rpx;
  font-size: 20rpx;
}

.benefit-check-wrap.inc {
  background: var(--color-primary-bg);
}

.benefit-check-wrap.exc {
  background: #FEE2E2;
}

.benefit-check {
  font-size: 20rpx;
  line-height: 1;
}

.benefit-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
  flex: 1;
}

.benefit-text.excluded {
  color: #999;
  text-decoration: line-through;
}

.coverage-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.coverage-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

/* ===== Compare Card ===== */
.compare-card {
  padding: 0;
  overflow: hidden;
}

.compare-header,
.compare-row {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  text-align: center;
}

.compare-header {
  background: var(--color-primary-bg);
  font-weight: 600;
  font-size: 24rpx;
  color: var(--color-primary);
}

.compare-header .compare-col,
.compare-row .compare-col {
  padding: 18rpx 8rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 24rpx;
}

.compare-row .compare-col.name {
  text-align: left;
  padding-left: 20rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

/* ===== Service Cards (feature-grid) ===== */
.service-card {
  padding: 24rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.service-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto 14rpx;
  border-radius: 50%;
  background: var(--gradient-hero);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(15, 61, 46, 0.15);
}

.service-icon {
  font-size: 30rpx;
  line-height: 1;
}

.service-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.service-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
}

/* ===== FAQ ===== */
.faq-card {
  padding: 8rpx 24rpx;
}

.faq-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-q {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.faq-a {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 10rpx;
  line-height: 1.6;
}

/* ===== Apply Card ===== */
.apply-card {
  margin: 0 var(--space-md) var(--space-md);
  padding: 28rpx;
}

.apply-header {
  display: flex;
  gap: var(--space-sm);
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.apply-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.apply-header-body {
  flex: 1;
}

.apply-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.apply-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
  line-height: 1.5;
}

.apply-input {
  background: var(--color-bg-page);
  border-radius: 12rpx;
  padding: 20rpx var(--space-md);
  font-size: 28rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.apply-actions {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.apply-actions button {
  flex: 1;
  min-width: 180rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  margin: 0;
  padding: 0;
}

/* ===== Compliance ===== */
.compliance-tip {
  margin: 0 var(--space-md);
  padding: 20rpx;
  text-align: center;
}

.compliance-tip text {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.7;
}
