@import '../common/finance-theme.wxss';

.loan-detail {
  padding-bottom: 160rpx;
}

.rate-tag {
  background: var(--color-primary-bg);
  color: var(--color-primary);
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  display: inline-block;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
  margin: 24rpx 0 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #D4A84B;
}

.feature-item, .material-item {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  display: flex;
  align-items: flex-start;
  line-height: 1.5;
}

.feature-check {
  color: var(--color-primary);
  font-weight: bold;
  margin-right: 12rpx;
}

.calculator-card {
  background: var(--gradient-hero);
  border-radius: var(--radius-lg);
  margin: 0 24rpx 24rpx;
  padding: 32rpx 28rpx;
  color: #fff;
  box-shadow: var(--shadow-hero);
}

.calc-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
}

.calc-tip {
  display: block;
  font-size: 22rpx;
  opacity: 0.85;
  margin: 8rpx 0 20rpx;
}

.slider-group {
  margin-bottom: 24rpx;
}

.slider-group text {
  font-size: 28rpx;
  display: block;
  margin-bottom: 8rpx;
}

.result {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
  font-size: 30rpx;
}

.amount {
  font-size: 44rpx;
  font-weight: 700;
  color: #D4A84B;
}

.related-tools {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.related-tools .tool-card {
  background: var(--color-primary-bg);
  border-radius: var(--radius-md);
  padding: 20rpx;
}

.tool-title {
  display: block;
  color: var(--color-primary);
  font-size: 26rpx;
  font-weight: 600;
}

.tool-desc {
  display: block;
  color: var(--color-text-muted);
  font-size: 22rpx;
  margin-top: 6rpx;
}
