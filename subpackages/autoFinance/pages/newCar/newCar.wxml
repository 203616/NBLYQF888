<view class="page-shell loan-detail">
  <view class="premium-hero fadeInUp">
    <safe-image className="premium-hero-bg" src="/subpackages/product/images/products/product-1.webp" mode="aspectFill" />
    <view class="premium-hero-body">
      <text class="premium-badge">新车按揭</text>
      <text class="premium-hero-title">{{productDetail.title || ''}}</text>
      <text class="premium-hero-sub">{{productDetail.bank || ''}} · {{productDetail.amountRange || ''}} · {{productDetail.term || ''}}</text>
    </view>
  </view>

  <view class="stat-row fadeInUp" style="animation-delay:0.1s">
    <view class="stat-item" wx:for="{{stats}}" wx:key="label">
      <text class="stat-num">{{item.value || ''}}</text>
      <text class="stat-label">{{item.label || ''}}</text>
    </view>
  </view>

  <view class="section-block fadeInUp" style="animation-delay:0.15s">
    <view class="card">
      <view class="rate-tag"><text>{{productDetail.rate || ''}}</text></view>
      <view class="tag-row">
        <text class="tag" wx:for="{{productDetail.tags || []}}" wx:key="*this">{{item}}</text>
      </view>
      <text class="subtitle">产品亮点</text>
      <block wx:for="{{productDetail.features || []}}" wx:key="*this">
        <view class="feature-item"><text class="feature-check">✓</text><text>{{item || ''}}</text></view>
      </block>
    </view>
  </view>

  <view class="calculator-card fadeInUp" style="animation-delay:0.2s">
    <text class="calc-title">月供计算器</text>
    <text class="calc-tip">以下为参考测算，实际以机构审批定价为准</text>
    <view class="slider-group">
      <text>贷款金额: {{loanAmount || 0}}元</text>
      <slider value="{{loanAmount}}" min="50000" max="500000" step="10000" activeColor="#D4A84B" bindchange="handleAmountChange" />
    </view>
    <view class="slider-group">
      <text>贷款期限: {{loanTerm || 0}}个月</text>
      <slider value="{{loanTerm}}" min="12" max="60" step="6" activeColor="#D4A84B" bindchange="handleTermChange" />
    </view>
    <view class="result">
      <text>预估月供</text>
      <text class="amount">¥{{monthlyPayment || 0}}</text>
    </view>
  </view>

  <view class="section-block fadeInUp" style="animation-delay:0.25s">
    <view class="card">
      <text class="subtitle">准入要求</text>
      <block wx:for="{{productDetail.requirements || []}}" wx:key="*this">
        <view class="material-item"><text>• {{item || ''}}</text></view>
      </block>
    </view>
  </view>

  <view class="section-block fadeInUp" style="animation-delay:0.3s">
    <view class="card">
      <text class="subtitle">申请材料</text>
      <block wx:for="{{productDetail.materials || []}}" wx:key="*this">
        <view class="material-item"><text>• {{item || ''}}</text></view>
      </block>
    </view>
  </view>

  <view class="section-block fadeInUp" style="animation-delay:0.35s">
    <view class="card">
      <text class="subtitle">办理流程</text>
      <view class="process-timeline">
        <block wx:for="{{productDetail.process || []}}" wx:key="*this">
          <view class="process-node fadeInUp" style="animation-delay:{{0.35 + index * 0.05}}s">
            <text class="process-dot">{{index + 1}}</text>
            <view class="process-content">
              <text class="process-title">{{item || ''}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="section-block fadeInUp" style="animation-delay:0.4s">
    <view class="card">
      <text class="subtitle">合作品牌</text>
      <view class="tag-row">
        <text class="tag" wx:for="{{productDetail.partnerBrands || []}}" wx:key="*this">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section-block fadeInUp" style="animation-delay:0.45s">
    <view class="card">
      <text class="subtitle">相关工具</text>
      <view class="related-tools">
        <view class="tool-card" bindtap="navigateToPrepayment">
          <text class="tool-title">提前还款计算器</text>
          <text class="tool-desc">测算剩余本金与违约金</text>
        </view>
        <view class="tool-card" bindtap="navigateToFinanceList">
          <text class="tool-title">全部汽车融资</text>
          <text class="tool-desc">比较新车/二手车/车抵方案</text>
        </view>
      </view>
    </view>
  </view>

  <view class="compliance-banner fadeInUp" style="animation-delay:0.5s">
    <text>{{productDetail.complianceNote || ''}}</text>
  </view>

  <view class="action-bar">
    <button class="btn-secondary" bindtap="contactService">咨询客服</button>
    <button class="btn-primary" bindtap="handleApply">立即申请</button>
  </view>
  <view class="page-safe"></view>
</view>
