.product-detail {
  padding-bottom: 160rpx;
}

.cover-wrap {
  position: relative;
  margin-bottom: 20rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.product-cover {
  width: 100%;
  height: 360rpx;
  display: block;
}

.cover-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: auto;
  padding: 28rpx;
  background: linear-gradient(transparent, rgba(15, 61, 46, 0.92));
  border-radius: 0;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.tag {
  color: var(--color-primary);
  background: rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
  font-size: 20rpx;
}

.rate-box {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.12);
}

.rate {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #D4A84B;
}

.rate-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.info-card {
  text-align: center;
  padding: 24rpx;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.info-value {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-top: 8rpx;
}

.section {
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid #D4A84B;
}

.paragraph, .list-row, .step-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
  line-height: 1.8;
}

.step-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.step-index {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  color: #fff;
  background: var(--color-primary);
  border-radius: 50%;
  font-size: 22rpx;
  flex-shrink: 0;
}

.faq-item {
  margin-bottom: 18rpx;
}

.faq-q {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.faq-a {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
}

.compliance {
  padding: 20rpx 24rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -4rpx 24rpx rgba(15, 61, 46, 0.08);
}

.action-bar button {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  margin: 0;
  padding: 0;
}
